@model AlAdeeb.Models.Quiz
@using System.Text.Json
@{
    ViewData["Title"] = Model.Title;
    Layout = null; 
}
<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - منصة الأديب</title>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">

    <style>
        @@font-face {
            font-family: 'Hayah';
            src: url('/fonts/Hayah.otf') format('opentype');
        }

        :root {
            --c-primary: #0a3254;
            --c-secondary: #af8f42;
            --c-bg: #f4f7f9;
            --c-white: #ffffff;
            --shadow-soft: 0 15px 35px rgba(10, 50, 84, 0.08);
            --shadow-glow: 0 10px 25px rgba(175, 143, 66, 0.3);
            --radius-lg: 2rem;
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background-color: var(--c-bg);
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            color: #1e293b;
            overflow-x: hidden;
        }

        * {
            box-sizing: border-box;
        }

        h1, h2, h3, .q-text { font-family: 'Hayah', sans-serif; }

        .quiz-header {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid rgba(175, 143, 66, 0.2);
            padding: 1rem 2rem;
            position: sticky;
            top: 0;
            z-index: 50;
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        }

        .header-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .student-info {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .student-avatar {
            width: 3rem;
            height: 3rem;
            background: var(--c-primary);
            color: var(--c-secondary);
            border-radius: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            font-weight: 900;
        }

        .student-text h1 {
            margin: 0 0 0.2rem 0;
            font-size: 1.2rem;
            color: var(--c-primary);
            font-weight: 900;
        }

        .student-text p {
            margin: 0;
            font-size: 0.9rem;
            color: #64748b;
            font-weight: bold;
        }

        .timer-box {
            background: var(--c-white);
            border: 1px solid #e2e8f0;
            padding: 0.5rem 1.5rem;
            border-radius: 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            box-shadow: 0 4px 10px rgba(0,0,0,0.02);
        }

        .timer-icon {
            color: var(--c-secondary);
            font-size: 1.5rem;
            animation: pulse 2s infinite;
        }

        .timer-text {
            text-align: left;
            direction: ltr;
        }

        .timer-text span {
            display: block;
            font-size: 0.75rem;
            color: #94a3b8;
            font-weight: 900;
            text-transform: uppercase;
            margin-bottom: 0.1rem;
        }

        .timer-text strong {
            font-size: 1.5rem;
            color: var(--c-primary);
            font-family: Arial, sans-serif;
            font-weight: 900;
        }

        .timer-danger strong {
            color: #dc2626;
            animation: pulse 1s infinite;
        }

        .progress-bar {
            width: 100%;
            height: 6px;
            background: #e2e8f0;
        }

        .progress-fill {
            height: 100%;
            background: var(--c-secondary);
            width: 0%;
            transition: width 0.5s ease;
        }

        .quiz-main {
            flex: 1;
            display: flex;
            justify-content: center;
            padding: 3rem 1.5rem;
            position: relative;
        }

        .quiz-card {
            background: var(--c-white);
            width: 100%;
            max-width: 900px;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-soft);
            border: 1px solid rgba(10,50,84,0.05);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            position: relative;
            z-index: 10;
            animation: fadeUp 0.6s ease;
        }

        .quiz-body {
            padding: 3rem;
            flex-grow: 1;
        }

        .q-counter {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            padding: 0.5rem 1rem;
            border-radius: 0.8rem;
            font-size: 1rem;
            font-weight: bold;
            color: #64748b;
            margin-bottom: 2rem;
        }

        .q-counter i {
            color: var(--c-secondary);
        }

        .q-text {
            font-size: 2.2rem;
            font-weight: 900;
            color: var(--c-primary);
            line-height: 1.6;
            margin: 0 0 2.5rem 0;
            white-space: pre-wrap; /* يحافظ على الأسطر الجديدة */
        }

        .q-image {
            max-width: 100%;
            max-height: 350px;
            border-radius: 1.5rem;
            margin-bottom: 2.5rem;
            border: 1px solid #e2e8f0;
            object-fit: contain;
            display: block;
        }

        .hidden {
            display: none !important;
        }

        .options-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1rem;
        }

        @@media(min-width: 768px) {
            .options-grid {
                grid-template-columns: 1fr 1fr;
                gap: 1.5rem;
            }
        }

        .option-item {
            background: var(--c-white);
            border: 2px solid #e2e8f0;
            border-radius: 1.5rem;
            padding: 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            cursor: pointer;
            transition: var(--transition);
        }

        .option-item:hover {
            border-color: rgba(175, 143, 66, 0.5);
            background: rgba(175, 143, 66, 0.02);
            transform: translateY(-3px);
        }

        .option-item:active {
            transform: scale(0.98);
        }

        .option-item.selected {
            border-color: var(--c-secondary);
            background: rgba(175, 143, 66, 0.05);
            box-shadow: var(--shadow-glow);
        }

        .opt-indicator {
            width: 2.5rem;
            height: 2.5rem;
            background: #f1f5f9;
            border-radius: 0.8rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            font-weight: 900;
            color: #94a3b8;
            transition: var(--transition);
            flex-shrink: 0;
        }

        .option-item:hover .opt-indicator {
            color: var(--c-secondary);
        }

        .option-item.selected .opt-indicator {
            background: var(--c-secondary);
            color: var(--c-white);
        }

        .opt-text {
            font-size: 1.2rem;
            font-weight: bold;
            color: var(--c-primary);
            white-space: pre-wrap;
        }

        .quiz-footer {
            background: #f8fafc;
            padding: 1.5rem 3rem;
            border-top: 1px solid #e2e8f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .btn-flag {
            background: transparent;
            border: none;
            color: #94a3b8;
            font-size: 1.1rem;
            font-weight: bold;
            font-family: inherit;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
        }

        .btn-flag:hover {
            color: var(--c-secondary);
        }

        .btn-next {
            background: #e2e8f0;
            color: #94a3b8;
            border: none;
            padding: 1rem 2.5rem;
            border-radius: 1rem;
            font-size: 1.3rem;
            font-weight: 900;
            font-family: inherit;
            display: flex;
            align-items: center;
            gap: 0.8rem;
            cursor: not-allowed;
            transition: var(--transition);
        }

        .btn-next.active {
            background: var(--c-primary);
            color: var(--c-secondary);
            cursor: pointer;
            box-shadow: 0 10px 20px rgba(10,50,84,0.2);
        }

        .btn-next.active:hover {
            background: var(--c-secondary);
            color: var(--c-primary);
            transform: translateY(-3px);
            box-shadow: var(--shadow-glow);
        }

        .result-screen {
            background: var(--c-white);
            max-width: 600px;
            width: 100%;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-soft);
            text-align: center;
            padding: 4rem 3rem;
            margin: auto;
            border: 1px solid rgba(175,143,66,0.2);
            position: relative;
            overflow: hidden;
            animation: zoomIn 0.5s ease;
        }

        .result-bg {
            position: absolute;
            inset: 0;
            background-image: radial-gradient(rgba(175,143,66,0.1) 2px, transparent 2px);
            background-size: 20px 20px;
            z-index: 0;
            opacity: 0.5;
        }

        .result-content {
            position: relative;
            z-index: 10;
        }

        .result-icon {
            width: 8rem;
            height: 8rem;
            background: var(--c-secondary);
            color: var(--c-white);
            border-radius: 2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 4rem;
            margin: 0 auto 2rem auto;
            box-shadow: var(--shadow-glow);
            transform: rotate(5deg);
        }

        .result-title {
            font-size: 2.5rem;
            color: var(--c-primary);
            font-weight: 900;
            margin: 0 0 1rem 0;
        }

        .result-score-box {
            background: #f8fafc;
            border: 2px solid #e2e8f0;
            border-radius: 1.5rem;
            padding: 2rem;
            margin: 2rem 0;
        }

        .result-score {
            font-size: 5rem;
            font-weight: 900;
            color: var(--c-secondary);
            font-family: Arial, sans-serif;
            line-height: 1;
        }

        .btn-home {
            display: inline-block;
            width: 100%;
            background: var(--c-primary);
            color: var(--c-secondary);
            padding: 1.2rem;
            border-radius: 1.2rem;
            font-size: 1.4rem;
            font-weight: 900;
            text-decoration: none;
            transition: var(--transition);
        }

        .btn-home:hover {
            background: var(--c-secondary);
            color: var(--c-primary);
        }
        
        .btn-cert {
            display: inline-block;
            width: 100%;
            background: #059669;
            color: #fff;
            padding: 1.2rem;
            border-radius: 1.2rem;
            font-size: 1.4rem;
            font-weight: 900;
            text-decoration: none;
            transition: var(--transition);
            margin-top: 1rem;
        }
        .btn-cert:hover { background: #047857; }

        @@keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.5; }
            100% { opacity: 1; }
        }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @@keyframes zoomIn {
            from { opacity: 0; transform: scale(0.9); }
            to { opacity: 1; transform: scale(1); }
        }
        
        .swal2-custom-popup { font-family: 'Cairo', sans-serif !important; border-radius: 1.5rem !important; }
        .swal2-custom-title { font-family: 'Hayah', sans-serif !important; color: var(--c-primary) !important; font-size: 2rem !important; }
    </style>
</head>
<body>

    <header class="quiz-header">
        <div class="header-container">
            <div class="student-info">
                <div class="student-avatar">@User.Identity.Name?.Substring(0, 1)</div>
                <div class="student-text">
                    <h1>@User.Identity.Name</h1>
                    <p>@Model.Title</p>
                </div>
            </div>
            <div class="timer-box" id="timerBox">
                <i class="fa-solid fa-hourglass-half timer-icon"></i>
                <div class="timer-text">
                    <span>الوقت المتبقي</span>
                    <strong id="timerDisplay">@Model.DurationInMinutes:00</strong>
                </div>
            </div>
        </div>
    </header>
    <div class="progress-bar"><div class="progress-fill" id="progressBar"></div></div>

    <main class="quiz-main">

        <div class="quiz-card" id="quizContainer">
            <div class="quiz-body">
                <div class="q-counter"><i class="fa-solid fa-clipboard-question"></i> <span id="questionCounter"></span></div>

                <h2 class="q-text" id="questionText">جاري تحميل الاختبار...</h2>
                <img id="questionImage" src="" class="q-image hidden" />

                <div class="options-grid" id="optionsContainer"></div>
            </div>
            <div class="quiz-footer">
                <button class="btn-flag"><i class="fa-regular fa-flag"></i> تعليم السؤال</button>
                <button class="btn-next" id="nextBtn" disabled>السؤال التالي <i class="fa-solid fa-arrow-left"></i></button>
            </div>
        </div>

        <div class="result-screen hidden" id="resultContainer">
            <div class="result-bg"></div>
            <div class="result-content">
                <div class="result-icon" id="resIcon"><i class="fa-solid fa-award"></i></div>
                <h2 class="result-title" id="resTitle">تم إنجاز الاختبار!</h2>
                <p style="color:#64748b; font-size:1.2rem; margin:0;" id="resMsg">تم حفظ إجاباتك بنجاح، نتيجتك هي:</p>
                <div class="result-score-box">
                    <div class="result-score" id="finalScoreDisplay">--%</div>
                </div>
                
                <a href="/Student/Results" class="btn-home">العودة إلى سجل الإنجاز</a>
                <div id="certBtnContainer" class="hidden">
                     <!-- سيتم حقن زر الشهادة هنا عبر الجافاسكريبت -->
                </div>
            </div>
        </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // استخدام JsonSerializer الآمن 100% لمنع كسر الجافاسكريبت نهائياً
        const questions = @Html.Raw(JsonSerializer.Serialize(Model.Questions.Select(q => new {
            id = q.Id,
            text = q.QuestionText ?? "",
            image = q.QuestionImagePath ?? "",
            options = new {
                A = q.OptionA ?? "",
                B = q.OptionB ?? "",
                C = q.OptionC ?? "",
                D = q.OptionD ?? ""
            }
        })));

        const quizId = @Model.Id;
        const studentId = @User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        let currentQ = 0;
        let selectedOpt = null;
        let timeLeft = @(Model.DurationInMinutes * 60);
        let studentAnswers = {};
        let isSubmitting = false;

        function renderQuestion() {
            if(questions.length === 0) return;
            const q = questions[currentQ];
            document.getElementById('questionCounter').innerText = `السؤال ${currentQ + 1} من ${questions.length}`;

            const txtEl = document.getElementById('questionText');
            const imgEl = document.getElementById('questionImage');

            if(q.text === "[سؤال مصور]" || q.text.trim() === "") { 
                txtEl.classList.add('hidden'); 
            } else { 
                txtEl.innerText = q.text; 
                txtEl.classList.remove('hidden'); 
            }

            if(q.image) { 
                imgEl.src = q.image; 
                imgEl.classList.remove('hidden'); 
            } else { 
                imgEl.classList.add('hidden'); 
            }

            document.getElementById('progressBar').style.width = `${((currentQ) / questions.length) * 100}%`;

            const optsContainer = document.getElementById('optionsContainer');
            optsContainer.innerHTML = '';

            Object.entries(q.options).forEach(([key, val]) => {
                if(val.trim() === "") return;
                const div = document.createElement('div');
                div.className = 'option-item';
                
                const indicatorText = key === 'A' ? 'أ' : (key === 'B' ? 'ب' : (key === 'C' ? 'ج' : 'د'));
                
                div.innerHTML = `<div class="opt-indicator">${indicatorText}</div><span class="opt-text">${escapeHtml(val)}</span>`;
                div.onclick = () => selectOption(key, div);
                optsContainer.appendChild(div);
            });

            selectedOpt = null;
            updateBtn();

            const btn = document.getElementById('nextBtn');
            btn.innerHTML = currentQ === questions.length - 1 ? 'إنهاء الاختبار <i class="fa-solid fa-flag-checkered"></i>' : 'السؤال التالي <i class="fa-solid fa-arrow-left"></i>';
        }

        // دالة حماية للخيارات لمنع أي أخطاء عرض
        function escapeHtml(unsafe) {
            return unsafe
                 .replace(/&/g, "&amp;")
                 .replace(/</g, "&lt;")
                 .replace(/>/g, "&gt;")
                 .replace(/"/g, "&quot;")
                 .replace(/'/g, "&#039;");
         }

        function selectOption(key, element) {
            selectedOpt = key;
            studentAnswers[questions[currentQ].id] = key;
            document.querySelectorAll('.option-item').forEach(el => el.classList.remove('selected'));
            element.classList.add('selected');
            updateBtn();
        }

        function updateBtn() {
            const btn = document.getElementById('nextBtn');
            if (selectedOpt) {
                btn.disabled = false; btn.classList.add('active');
            } else {
                btn.disabled = true; btn.classList.remove('active');
            }
        }

        async function submitQuiz() {
            if(isSubmitting) return;
            isSubmitting = true;
            
            document.getElementById('progressBar').style.width = `100%`;
            document.getElementById('quizContainer').style.display = 'none';
            document.getElementById('timerBox').style.display = 'none';
            
            Swal.fire({
                title: 'جاري تصحيح الاختبار...',
                text: 'الرجاء الانتظار لحظات',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); },
                customClass: { popup: 'swal2-custom-popup', title: 'swal2-custom-title' }
            });

            try {
                const response = await fetch('/api/Quiz/submit', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ QuizId: quizId, StudentId: parseInt(studentId), Answers: studentAnswers })
                });
                
                Swal.close();
                
                if(response.ok) {
                    const data = await response.json();
                    document.getElementById('resultContainer').classList.remove('hidden');
                    document.getElementById('finalScoreDisplay').innerText = data.score + "%";
                    
                    if(data.passed){
                        document.getElementById('resIcon').innerHTML = '<i class="fa-solid fa-trophy"></i>';
                        document.getElementById('resIcon').style.background = '#059669';
                        document.getElementById('resTitle').innerText = 'مبارك! لقد اجتزت الاختبار بنجاح.';
                        document.getElementById('finalScoreDisplay').style.color = '#059669';
                        
                        if(data.isFinal && data.certificateSerial){
                            const certDiv = document.getElementById('certBtnContainer');
                            certDiv.classList.remove('hidden');
                            certDiv.innerHTML = `<a href="/Student/Certificate?serial=${data.certificateSerial}" class="btn-cert"><i class="fa-solid fa-file-certificate"></i> عرض وطباعة الشهادة</a>`;
                        }
                    } else {
                        document.getElementById('resIcon').innerHTML = '<i class="fa-solid fa-face-frown"></i>';
                        document.getElementById('resIcon').style.background = '#dc2626';
                        document.getElementById('resTitle').innerText = 'للأسف، لم تجتز الاختبار.';
                        document.getElementById('finalScoreDisplay').style.color = '#dc2626';
                        document.getElementById('resMsg').innerText = 'حاول مراجعة الدروس وإعادة المحاولة لاحقاً.';
                    }
                }
            } catch (e) {
                Swal.fire('خطأ!', 'حدثت مشكلة أثناء إرسال الإجابات.', 'error');
            }
        }

        document.getElementById('nextBtn').addEventListener('click', () => {
            if (currentQ < questions.length - 1) { 
                currentQ++; 
                renderQuestion(); 
            } else { 
                submitQuiz(); 
            }
        });

        const timerDisplay = document.getElementById('timerDisplay');
        const timerBox = document.getElementById('timerBox');
        const timerInterval = setInterval(() => {
            if(timeLeft > 0) {
                timeLeft--;
                const m = Math.floor(timeLeft / 60).toString().padStart(2, '0');
                const s = (timeLeft % 60).toString().padStart(2, '0');
                timerDisplay.innerText = `${m}:${s}`;
                if(timeLeft <= 60) timerBox.classList.add('timer-danger');
            } else {
                clearInterval(timerInterval); submitQuiz();
            }
        }, 1000);

        window.onload = renderQuestion;
    </script>
</body>
</html>