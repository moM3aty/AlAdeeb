@model AlAdeeb.Models.Course
@{
    ViewData["Title"] = "تأكيد الاشتراك";
}

<style>
    :root {
        --c-primary: #0a3254;
        --c-secondary: #af8f42;
        --c-bg: #f4f7f9;
        --c-white: #ffffff;
        --shadow-card: 0 10px 30px rgba(10, 50, 84, 0.08);
        --transition: all 0.3s ease;
    }

    .subscribe-page {
        padding: 3rem 1.5rem;
        max-width: 1000px;
        margin: 0 auto;
        direction: rtl;
    }

    .sub-card {
        background: var(--c-white);
        border-radius: 2rem;
        box-shadow: var(--shadow-card);
        border: 1px solid rgba(175,143,66,0.1);
        animation: fadeUp 0.6s ease forwards;
        overflow: visible;
    }

    .sub-header {
        background: linear-gradient(135deg, var(--c-primary) 0%, #051b2e 100%);
        padding: 2.5rem 2rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: center;
        gap: 1.5rem;
        position: relative;
        border-radius: 2rem 2rem 0 0;
        overflow: hidden;
    }

    @@media(min-width: 768px) {
        .sub-header {
            flex-direction: row;
            padding: 3rem;
        }
    }

    .sub-header::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: radial-gradient(rgba(175,143,66,0.2) 2px, transparent 2px);
        background-size: 20px 20px;
        opacity: 0.5;
    }

    .course-info {
        position: relative;
        z-index: 10;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        text-align: right;
        width: 100%;
    }

    .course-icon {
        width: 4.5rem;
        height: 4.5rem;
        background: rgba(255,255,255,0.1);
        border: 2px solid rgba(175,143,66,0.5);
        border-radius: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: var(--c-secondary);
        backdrop-filter: blur(5px);
        flex-shrink: 0;
    }

    .course-info h2 {
        font-family: 'Hayah', sans-serif;
        font-size: 2rem;
        color: var(--c-white);
        margin: 0 0 0.2rem 0;
    }

    .course-info p {
        font-size: 1.1rem;
        color: var(--c-secondary);
        margin: 0;
        font-weight: 700;
    }

    .price-tag {
        position: relative;
        z-index: 10;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        padding: 1rem 2rem;
        border-radius: 1.2rem;
        text-align: center;
        backdrop-filter: blur(10px);
        min-width: 180px;
    }

        .price-tag span {
            display: block;
            font-size: 0.85rem;
            color: #cbd5e1;
            font-weight: 800;
            text-transform: uppercase;
            margin-bottom: 0.3rem;
        }

        .price-tag strong {
            font-size: 2.2rem;
            color: var(--c-white);
            font-family: Arial, sans-serif;
            font-weight: 900;
            line-height: 1;
        }

        .price-tag small {
            font-size: 1rem;
            color: var(--c-secondary);
            font-family: 'Hayah', sans-serif;
        }

    .sub-body {
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 3rem;
    }

    @@media(min-width: 768px) {
        .sub-body {
            padding: 3rem;
        }
    }

    .section-title {
        font-family: 'Hayah', sans-serif;
        font-size: 1.6rem;
        color: var(--c-primary);
        margin: 0 0 1.5rem 0;
        display: flex;
        align-items: center;
        gap: 0.8rem;
    }

        .section-title i {
            color: var(--c-secondary);
        }

    /* Payment Methods Grid */
    .payment-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    @@media(min-width: 768px) {
        .payment-grid {
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        }
    }

    .bank-card {
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 1.5rem;
        padding: 2rem 1.5rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        transition: var(--transition);
    }

        .bank-card:hover {
            border-color: var(--c-secondary);
            box-shadow: 0 10px 25px rgba(175,143,66,0.1);
            transform: translateY(-5px);
            background: var(--c-white);
        }

    .qr-container {
        width: 140px;
        height: 140px;
        background: var(--c-white);
        border: 3px solid var(--c-primary);
        border-radius: 1.2rem;
        padding: 8px;
        margin-bottom: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

        .qr-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 0.8rem;
        }

    .bank-logo-icon {
        width: 140px;
        height: 140px;
        background: #5031a9; /* STC Pay Color */
        color: var(--c-white);
        border-radius: 1.2rem;
        margin-bottom: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        box-shadow: 0 5px 15px rgba(80,49,169,0.3);
    }

    .bank-card h4 {
        font-size: 1.3rem;
        color: var(--c-primary);
        margin: 0 0 0.5rem 0;
        font-weight: 800;
    }

    .bank-card p {
        font-size: 0.95rem;
        color: #64748b;
        margin: 0 0 1.5rem 0;
        font-weight: 700;
    }

    .iban-box {
        background: var(--c-white);
        border: 1px solid #e2e8f0;
        border-radius: 1rem;
        padding: 0.6rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        margin-top: auto;
    }

    .iban-text {
        font-family: Arial, sans-serif;
        font-weight: 800;
        color: var(--c-primary);
        font-size: 0.95rem;
        direction: ltr;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        padding: 0 0.5rem;
    }

    .copy-btn {
        background: #f1f5f9;
        border: none;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 0.5rem;
        color: var(--c-primary);
        cursor: pointer;
        transition: var(--transition);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

        .copy-btn:hover {
            background: var(--c-secondary);
            color: var(--c-white);
        }

    /* Upload Form */
    .upload-area {
        border: 2px dashed #cbd5e1;
        border-radius: 1.5rem;
        background: #f8fafc;
        padding: 3rem 2rem;
        text-align: center;
        cursor: pointer;
        transition: var(--transition);
        position: relative;
        min-height: 200px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        margin-bottom: 1.5rem;
    }

        .upload-area:hover {
            border-color: var(--c-secondary);
            background: rgba(175,143,66,0.02);
        }

    .upload-input {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        cursor: pointer;
        z-index: 10;
    }

    .upload-icon {
        width: 4rem;
        height: 4rem;
        background: var(--c-white);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        color: #94a3b8;
        margin: 0 auto 1rem auto;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        transition: var(--transition);
    }

    .upload-area:hover .upload-icon {
        color: var(--c-secondary);
    }

    .upload-text {
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--c-primary);
        margin: 0 0 0.5rem 0;
    }

    .upload-hint {
        font-size: 0.95rem;
        color: #64748b;
        margin: 0;
        font-weight: 600;
    }

    .preview-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: contain;
        background: var(--c-white);
        z-index: 5;
        border-radius: 1.3rem;
        display: none;
    }

    .submit-btn {
        width: 100%;
        max-width: 400px;
        margin: 0 auto;
        background: var(--c-primary);
        color: var(--c-secondary);
        border: none;
        padding: 1.2rem;
        border-radius: 1.2rem;
        font-size: 1.4rem;
        font-weight: 900;
        font-family: 'Hayah', sans-serif;
        cursor: pointer;
        transition: var(--transition);
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.8rem;
        box-shadow: 0 10px 20px rgba(10,50,84,0.2);
    }

        .submit-btn:hover {
            background: var(--c-secondary);
            color: var(--c-primary);
            transform: translateY(-3px);
            box-shadow: 0 15px 25px rgba(175,143,66,0.3);
        }

    .whatsapp-support {
        text-align: center;
        margin-top: 3rem;
        padding: 2rem;
        border-top: 1px solid #e2e8f0;
    }

    .whatsapp-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        background: #edf7ed;
        color: #2e7d32;
        padding: 0.8rem 2rem;
        border-radius: 50px;
        font-size: 1.1rem;
        font-weight: 800;
        text-decoration: none;
        border: 1px solid #c8e6c9;
        transition: var(--transition);
    }

        .whatsapp-btn:hover {
            background: #2e7d32;
            color: var(--c-white);
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="subscribe-page">
    <div class="sub-card">

        <div class="sub-header">
            <div class="course-info">
                <div class="course-icon"><i class="fa-solid fa-cart-shopping"></i></div>
                <div>
                    <h2>تأكيد حجز الدورة</h2>
                    <p>@Model.Title</p>
                </div>
            </div>
            <div class="price-tag">
                <span>المبلغ المطلوب</span>
                <strong>@Model.Price <small>ريال</small></strong>
            </div>
        </div>

        <div class="sub-body">

            <!-- طرق الدفع -->
            <div class="bank-section">
                <h3 class="section-title"><i class="fa-solid fa-money-check-dollar"></i> 1. اختر طريقة الدفع الأنسب لك وحول المبلغ</h3>

                <div class="payment-grid">

                    <!-- بنك الإنماء -->
                    <div class="bank-card">
                        <div class="qr-container">
                            <img src="~/images/1.jpg" alt="QR بنك الإنماء" />
                        </div>
                        <h4>بنك الإنماء</h4>
                        <p>صلاح الدين فتحي عبدالعال</p>
                        <div class="iban-box">
                            <span class="iban-text" id="iban1">SA9405000068205855779000</span>
                            <button type="button" class="copy-btn" onclick="copyText('SA9405000068205855779000')" title="نسخ الآيبان"><i class="fa-regular fa-copy"></i></button>
                        </div>
                    </div>

                    <!-- بنك الراجحي -->
                    <div class="bank-card">
                        <div class="qr-container">
                            <img src="~/images/2.jpg" alt="QR بنك الراجحي" />
                        </div>
                        <h4>بنك الراجحي</h4>
                        <p>صلاح الدين فتحي عبدالعال</p>
                        <div class="iban-box">
                            <span class="iban-text" id="iban2">SA6880000694608016626187</span>
                            <button type="button" class="copy-btn" onclick="copyText('SA6880000694608016626187')" title="نسخ الآيبان"><i class="fa-regular fa-copy"></i></button>
                        </div>
                    </div>

                    <!-- STC Pay -->
                    <div class="bank-card">
                        <div class="bank-logo-icon">
                            <i class="fa-solid fa-wallet"></i>
                        </div>
                        <h4>STC Pay</h4>
                        <p>صلاح الدين فتحي عبدالعال</p>
                        <div class="iban-box">
                            <span class="iban-text" id="stcpay">0540091992</span>
                            <button type="button" class="copy-btn" onclick="copyText('0540091992')" title="نسخ رقم المحفظة"><i class="fa-regular fa-copy"></i></button>
                        </div>
                    </div>

                </div>
            </div>

            <!-- رفع الإيصال -->
            <div class="upload-section">
                <h3 class="section-title"><i class="fa-solid fa-cloud-arrow-up"></i> 2. إرفاق إيصال التحويل</h3>
                <form asp-controller="Student" asp-action="SubmitSubscription" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="courseId" value="@Model.Id" />

                    <div class="upload-area">
                        <input type="file" name="receiptImage" id="receiptImage" required accept="image/*" class="upload-input" onchange="previewImg(this)">
                        <img id="preview" src="" class="preview-img" />
                        <div id="upload-content">
                            <div class="upload-icon"><i class="fa-solid fa-file-invoice"></i></div>
                            <h4 class="upload-text">اضغط لرفع صورة الإيصال</h4>
                            <p class="upload-hint">يجب أن تكون صورة واضحة (JPG, PNG)</p>
                        </div>
                    </div>

                    <button type="submit" class="submit-btn">
                        إرسال الإيصال للتفعيل <i class="fa-solid fa-paper-plane"></i>
                    </button>
                </form>
            </div>

        </div>

        <div class="whatsapp-support">
            <p style="color: #64748b; font-weight: bold; margin-bottom: 1rem; font-size: 0.95rem;">هل واجهت مشكلة في الدفع؟ فريق الدعم متواجد لخدمتك</p>
            <a href="https://wa.me/966540091992" target="_blank" class="whatsapp-btn">
                <i class="fa-brands fa-whatsapp"></i> تواصل مع خدمة العملاء
            </a>
        </div>

    </div>
</div>

<script>
    function copyText(text) {
        navigator.clipboard.writeText(text).then(function() {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'success',
                    title: 'تم نسخ الرقم بنجاح',
                    showConfirmButton: false,
                    timer: 3000,
                    timerProgressBar: true,
                    customClass: { popup: 'swal2-custom-popup' }
                });
            } else {
                alert('تم النسخ: ' + text);
            }
        }, function(err) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: 'خطأ',
                    text: 'تعذر النسخ تلقائياً، يرجى تحديده ونسخه يدوياً.',
                    confirmButtonColor: '#dc2626',
                    customClass: { popup: 'swal2-custom-popup', title: 'swal2-custom-title' }
                });
            } else {
                alert('فشل النسخ.');
            }
        });
    }

    function previewImg(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('preview').src = e.target.result;
                document.getElementById('preview').style.display = 'block';
                document.getElementById('upload-content').style.opacity = '0';
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>