@model AlAdeeb.Models.Course
@{
    ViewData["Title"] = "قاعة المذاكرة";
    var liveSessions = ViewBag.LiveSessions as IEnumerable<AlAdeeb.Models.LiveSession>;
    bool isExpired = ViewBag.IsExpired != null && (bool)ViewBag.IsExpired;
    var unlockedLessonIds = ViewBag.UnlockedLessonIds as List<int> ?? new List<int>();
    double progress = ViewBag.ProgressPercentage != null ? (double)ViewBag.ProgressPercentage : 0;
    var leaderboard = ViewBag.Leaderboard as IEnumerable<AlAdeeb.Controllers.LeaderboardDto>;
}

<style>
    @@keyframes pulse-live {
        0% {
            transform: scale(1);
            box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4);
        }

        70% {
            transform: scale(1.1);
            box-shadow: 0 0 0 10px rgba(239, 68, 68, 0);
        }

        100% {
            transform: scale(1);
            box-shadow: 0 0 0 0 rgba(239, 68, 68, 0);
        }
    }

    .live-pulse-icon {
        animation: pulse-live 2s infinite;
    }

    @@font-face {
        font-family: 'Hayah';
        src: url('/fonts/Hayah.otf') format('opentype');
    }

    :root {
        --c-primary: #0a3254;
        --c-primary-dark: #051b2e;
        --c-secondary: #af8f42;
        --c-bg: #f4f7f9;
        --c-white: #ffffff;
        --shadow-panel: 0 20px 40px rgba(0, 0, 0, 0.05);
        --radius-lg: 2rem;
        --transition: all 0.3s ease;
    }

    .viewer-page {
        font-family: 'Hayah', sans-serif;
        background: var(--c-bg);
        min-height: calc(100vh - 100px);
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 2rem;
        direction: rtl;
        max-width: 1600px;
        margin: 0 auto;
    }

    @@media(min-width: 992px) {
        .viewer-page {
            flex-direction: row;
            height: calc(100vh - 100px);
            align-items: stretch;
        }
    }

    .main-area {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        min-width: 0;
    }

    .player-container {
        background: #000;
        border-radius: var(--radius-lg);
        flex-grow: 1;
        position: relative;
        overflow: hidden;
        box-shadow: 0 30px 60px rgba(10,50,84,0.3);
        border: 2px solid rgba(175,143,66,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 400px;
    }

    .player-iframe {
        width: 100%;
        height: 100%;
        position: absolute;
        inset: 0;
        border: none;
        z-index: 10;
        background: #000;
    }

    video.player-iframe {
        object-fit: contain;
    }

    .watermark-container {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 40;
        overflow: hidden;
    }

    .watermark-text {
        position: absolute;
        font-family: Arial, sans-serif;
        font-size: 1.8rem;
        font-weight: 900;
        color: rgba(255, 255, 255, 0.35);
        text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
        white-space: nowrap;
        user-select: none;
        animation: floatWatermark 18s linear infinite;
    }

    @@keyframes floatWatermark {
        0% {
            top: 10%;
            left: -10%;
            transform: rotate(-15deg);
        }

        25% {
            top: 70%;
            left: 30%;
            transform: rotate(15deg);
        }

        50% {
            top: 40%;
            left: 80%;
            transform: rotate(-10deg);
        }

        75% {
            top: 80%;
            left: 50%;
            transform: rotate(20deg);
        }

        100% {
            top: 10%;
            left: -10%;
            transform: rotate(-15deg);
        }
    }

    .player-placeholder {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        z-index: 20;
        background: radial-gradient(circle at center, var(--c-primary), var(--c-primary-dark));
        text-align: center;
        padding: 2rem;
    }

    .play-icon-wrapper {
        width: 6rem;
        height: 6rem;
        background: var(--c-secondary);
        border-radius: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        color: var(--c-primary-dark);
        margin-bottom: 1.5rem;
        box-shadow: 0 10px 30px rgba(175,143,66,0.4);
    }

    .player-placeholder h3 {
        color: var(--c-white);
        font-size: 2.5rem;
        margin: 0 0 0.5rem 0;
        font-weight: 900;
    }

    .player-placeholder p {
        color: rgba(255,255,255,0.6);
        font-size: 1.2rem;
        margin: 0;
    }

    .lesson-info {
        background: var(--c-white);
        padding: 1.5rem 2rem;
        border-radius: 1.5rem;
        box-shadow: var(--shadow-panel);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
    }

    .info-text .label {
        font-size: 0.9rem;
        font-weight: 800;
        color: var(--c-secondary);
        text-transform: uppercase;
        margin-bottom: 0.2rem;
        display: block;
    }

    .info-text h2 {
        font-size: 1.6rem;
        color: var(--c-primary);
        margin: 0 0 0.2rem 0;
        font-weight: 900;
    }

    .info-text p {
        font-size: 1rem;
        color: #64748b;
        margin: 0;
    }

    .sidebar {
        width: 100%;
        background: var(--c-white);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-panel);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        flex-shrink: 0;
    }

    @@media(min-width: 992px) {
        .sidebar {
            width: 420px;
            height: calc(100vh - 140px);
        }
    }

    .sidebar-tabs {
        display: flex;
        border-bottom: 1px solid #e2e8f0;
        background: #f8fafc;
        flex-shrink: 0;
    }

    .s-tab {
        flex: 1;
        text-align: center;
        padding: 1.2rem 0.5rem;
        font-size: 1.1rem;
        font-weight: 900;
        color: var(--c-text-muted);
        cursor: pointer;
        border-bottom: 3px solid transparent;
        transition: var(--transition);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
    }

        .s-tab.active {
            color: var(--c-primary);
            border-bottom-color: var(--c-secondary);
            background: var(--c-white);
        }

        .s-tab:hover:not(.active) {
            color: var(--c-primary);
            background: rgba(10,50,84,0.02);
        }

    .playlist-content {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        min-height: 0;
    }

        .playlist-content::-webkit-scrollbar {
            width: 6px;
        }

        .playlist-content::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }

    .curr-progress-box {
        background: rgba(10,50,84,0.03);
        border: 1px solid rgba(10,50,84,0.05);
        padding: 1rem 1.5rem;
        border-radius: 1rem;
        margin-bottom: 0.5rem;
        flex-shrink: 0;
    }

        .curr-progress-box h4 {
            margin: 0 0 0.5rem 0;
            color: var(--c-primary);
            font-size: 1.1rem;
            display: flex;
            justify-content: space-between;
        }

            .curr-progress-box h4 span {
                color: var(--c-secondary);
                font-family: Arial;
            }

    .cp-bar-bg {
        width: 100%;
        height: 8px;
        background: #e2e8f0;
        border-radius: 50px;
        overflow: hidden;
    }

    .cp-bar-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--c-secondary), #fbbf24);
        border-radius: 50px;
        transition: width 1s ease;
    }

    .lesson-group {
        background: #fdfdfd;
        border: 1px solid rgba(0,0,0,0.05);
        border-radius: 1.2rem;
        margin-bottom: 1rem;
        position: relative;
    }

    .lesson-group-title {
        background: rgba(10,50,84,0.03);
        padding: 1rem 1.2rem;
        font-size: 1.1rem;
        font-weight: 900;
        color: var(--c-primary);
        border-bottom: 1px solid rgba(0,0,0,0.05);
        display: flex;
        align-items: center;
        gap: 0.8rem;
    }

    .lesson-items {
        padding: 0.8rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .item-btn {
        width: 100%;
        text-align: right;
        background: var(--c-white);
        border: 1px solid #e2e8f0;
        padding: 0.8rem;
        border-radius: 0.8rem;
        display: flex;
        align-items: flex-start;
        gap: 0.8rem;
        cursor: pointer;
        transition: var(--transition);
        font-family: inherit;
    }

        .item-btn:not(:disabled):hover {
            background: #f8fafc;
            border-color: rgba(175,143,66,0.3);
        }

        .item-btn.active {
            background: rgba(10,50,84,0.03);
            border-color: var(--c-primary);
            box-shadow: 0 4px 15px rgba(10,50,84,0.05);
        }

        .item-btn:disabled {
            background: #f1f5f9;
            cursor: not-allowed;
            opacity: 0.7;
            border-color: #e2e8f0;
        }

    .item-icon {
        width: 2.2rem;
        height: 2.2rem;
        background: #f1f5f9;
        color: #94a3b8;
        border-radius: 0.6rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        flex-shrink: 0;
        transition: var(--transition);
    }

    .item-btn.active .item-icon {
        background: var(--c-primary);
        color: var(--c-secondary);
    }

    .item-btn:disabled .item-icon {
        background: #e2e8f0;
        color: #cbd5e1;
    }

    .item-text {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
    }

    .item-title {
        font-size: 1rem;
        font-weight: 800;
        color: var(--c-primary);
        margin: 0;
    }

    .item-meta {
        font-size: 0.8rem;
        font-weight: bold;
        color: #64748b;
        margin: 0;
        display: flex;
        gap: 0.5rem;
        align-items: center;
    }

    .badge-free {
        background: #ecfccb;
        color: #ca8a04;
        border: 1px solid #fef08a;
        padding: 0.1rem 0.5rem;
        border-radius: 4px;
        font-size: 0.75rem;
    }

    .alert-expired {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
        padding: 1rem;
        border-radius: 1rem;
        font-weight: bold;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.8rem;
    }

    .lesson-locked-overlay {
        position: absolute;
        inset: 0;
        background: rgba(248, 250, 252, 0.85);
        backdrop-filter: blur(2px);
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        border-radius: 1.2rem;
        border: 1px dashed #cbd5e1;
    }

        .lesson-locked-overlay i {
            font-size: 2rem;
            color: #94a3b8;
            margin-bottom: 0.5rem;
        }

        .lesson-locked-overlay span {
            color: var(--c-primary);
            font-weight: bold;
            font-size: 0.95rem;
            background: var(--c-white);
            padding: 0.3rem 1rem;
            border-radius: 50px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }

    .lb-header {
        text-align: center;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px dashed #e2e8f0;
    }

        .lb-header i {
            font-size: 3rem;
            color: #fbbf24;
            margin-bottom: 0.5rem;
            filter: drop-shadow(0 5px 10px rgba(251,191,36,0.3));
        }

        .lb-header h3 {
            font-family: 'Hayah';
            color: var(--c-primary);
            font-size: 1.8rem;
            margin: 0;
        }

    .lb-card {
        display: flex;
        align-items: center;
        gap: 1rem;
        background: var(--c-white);
        padding: 1rem;
        border-radius: 1rem;
        margin-bottom: 0.8rem;
        border: 1px solid #e2e8f0;
        transition: var(--transition);
    }

        .lb-card:hover {
            transform: translateX(-5px);
            box-shadow: var(--shadow-panel);
            border-color: var(--c-secondary);
        }

    .rank-badge {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 1.2rem;
        color: white;
        flex-shrink: 0;
        font-family: Arial;
    }

    .rank-1 {
        background: #fbbf24;
        box-shadow: 0 4px 10px rgba(251,191,36,0.4);
    }

    .rank-2 {
        background: #94a3b8;
        box-shadow: 0 4px 10px rgba(148,163,184,0.4);
    }

    .rank-3 {
        background: #b45309;
        box-shadow: 0 4px 10px rgba(180,83,9,0.4);
    }

    .rank-other {
        background: var(--c-primary);
        opacity: 0.8;
    }

    .lb-info {
        flex: 1;
    }

        .lb-info h5 {
            margin: 0 0 0.2rem 0;
            font-size: 1.1rem;
            color: var(--c-primary);
            font-weight: 800;
        }

        .lb-info p {
            margin: 0;
            font-size: 0.85rem;
            color: #64748b;
            font-weight: bold;
        }

    .lb-score {
        font-family: Arial;
        font-weight: 900;
        font-size: 1.3rem;
        color: var(--c-secondary);
        background: rgba(175,143,66,0.1);
        padding: 0.3rem 0.8rem;
        border-radius: 0.6rem;
    }

    .forum-container {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        padding-bottom: 2rem;
    }

    .forum-add-post {
        background: var(--c-white);
        border: 1px solid #e2e8f0;
        border-radius: 1rem;
        padding: 1rem;
        box-shadow: 0 4px 10px rgba(0,0,0,0.02);
    }

    .forum-textarea {
        width: 100%;
        border: none;
        background: #f8fafc;
        border-radius: 0.8rem;
        padding: 1rem;
        font-family: inherit;
        font-size: 1rem;
        resize: none;
        min-height: 80px;
        margin-bottom: 0.8rem;
        color: var(--c-primary);
        font-weight: 600;
        outline: none;
    }

    .btn-publish {
        background: var(--c-primary);
        color: var(--c-secondary);
        border: none;
        padding: 0.6rem 1.5rem;
        border-radius: 0.8rem;
        font-weight: 800;
        font-family: inherit;
        cursor: pointer;
        transition: var(--transition);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-right: auto;
    }

    .post-card {
        background: var(--c-white);
        border: 1px solid #e2e8f0;
        border-radius: 1rem;
        padding: 1.2rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .post-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .post-user {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        font-weight: 800;
        color: var(--c-primary);
        font-size: 1.1rem;
    }

    .post-avatar {
        width: 2.5rem;
        height: 2.5rem;
        background: rgba(10,50,84,0.05);
        color: var(--c-primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
    }

    .badge-admin {
        background: var(--c-secondary);
        color: var(--c-white);
        font-size: 0.75rem;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        margin-right: 0.5rem;
    }

    .post-content {
        font-size: 1rem;
        color: #475569;
        line-height: 1.6;
        margin: 0;
        white-space: pre-wrap;
    }

    .replies-section {
        margin-top: 0.5rem;
        padding-top: 1rem;
        border-top: 1px dashed #e2e8f0;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .reply-card {
        background: #f8fafc;
        border-radius: 0.8rem;
        padding: 1rem;
        margin-right: 2rem;
        border-right: 3px solid var(--c-secondary);
    }

    .reply-add {
        margin-right: 2rem;
        display: flex;
        gap: 0.5rem;
    }

        .reply-add input {
            flex: 1;
            border: 1px solid #e2e8f0;
            border-radius: 0.8rem;
            padding: 0.6rem 1rem;
            font-family: inherit;
            font-size: 0.95rem;
            outline: none;
        }

    .btn-reply {
        background: #e2e8f0;
        color: var(--c-primary);
        border: none;
        padding: 0 1rem;
        border-radius: 0.8rem;
        font-weight: bold;
        cursor: pointer;
    }

    .hidden {
        display: none !important;
    }
</style>

<div class="viewer-page">
    <div class="main-area">
        @if (isExpired)
        {
            <div class="alert-expired">
                <i class="fa-solid fa-lock" style="font-size: 1.5rem;"></i>
                عفواً، لقد انتهت صلاحية اشتراكك في هذه الدورة. يمكنك فقط مشاهدة المقاطع التجريبية المجانية.
            </div>
        }

        <div class="player-container" id="playerWrapper">
            <div class="watermark-container hidden" id="watermarkOverlay"><div class="watermark-text">@(User.Identity.IsAuthenticated? User.Identity.Name : "عينة مجانية")</div></div>

            <iframe id="mainViewer" class="player-iframe hidden" src="" allow="autoplay; fullscreen" allowfullscreen></iframe>
            <video id="videoViewer" class="player-iframe hidden" controls controlsList="nodownload"></video>

            <div id="placeholder" class="player-placeholder">
                <div class="play-icon-wrapper"><i class="fa-solid fa-play"></i></div>
                <h3>@Model.Title</h3>
                <p>اختر درساً من القائمة الجانبية لبدء المذاكرة</p>
            </div>
        </div>

        <div class="lesson-info">
            <div class="info-text">
                <span class="label">يتم عرض الآن</span>
                <h2 id="currentTitle">غرفة الانتظار</h2>
                <p id="currentDesc">يرجى التركيز وتدوين الملاحظات.</p>
            </div>
        </div>
    </div>

    <div class="sidebar">
        <div class="sidebar-tabs">
            <div class="s-tab active" onclick="switchTab('curriculum', this)"><i class="fa-solid fa-bars-staggered"></i> المنهج</div>
            <div class="s-tab" onclick="switchTab('forum', this)"><i class="fa-solid fa-comments"></i> النقاشات</div>
            <div class="s-tab" onclick="switchTab('leaderboard', this)"><i class="fa-solid fa-trophy"></i> المسابقات</div>
        </div>

        <div id="tab-curriculum" class="playlist-content">

            <div class="curr-progress-box">
                <h4>نسبة إنجازك بالدورة <span>@progress%</span></h4>
                <div class="cp-bar-bg">
                    <div class="cp-bar-fill" style="width: @progress%;"></div>
                </div>
            </div>

            @if (liveSessions != null && liveSessions.Any())
            {
                <div class="lesson-group" style="border-color: #bfdbfe; box-shadow: 0 10px 25px rgba(59, 130, 246, 0.1);">
                    <div class="lesson-group-title" style="background: #eff6ff; color: #1d4ed8; border-bottom-color: #bfdbfe;">
                        <i class="fa-solid fa-tower-broadcast" style="color: #ef4444;"></i> لقاءات البث المباشر
                    </div>
                    <div class="lesson-items">
                        @foreach (var session in liveSessions.OrderBy(l => l.ScheduledDate))
                        {
                            bool isLocked = isExpired;

                            if (session.IsCompleted)
                            {
                                if (!string.IsNullOrEmpty(session.RecordedVideoUrl))
                                {
                                    <button onclick="loadContent('@session.RecordedVideoUrl', '@session.Title (تسجيل البث)', 'RecordedLive', this)" class="item-btn" @(isLocked ? "disabled" : "")>
                                        <div class="item-icon" style="background:#f3e8ff; color:#a855f7;"><i class="fa-solid fa-video"></i></div>
                                        <div class="item-text">
                                            <p class="item-title">@session.Title</p>
                                            <p class="item-meta"><i class="fa-solid fa-clock-rotate-left"></i> بث مسجل - تم بتاريخ @session.ScheduledDate.ToString("yyyy/MM/dd")</p>
                                        </div>
                                    </button>
                                }
                            }
                            else
                            {
                                <button onclick="window.open('@session.LiveUrl', '_blank')" class="item-btn" style="border-color: #93c5fd; background: #f8fafc;" @(isLocked ? "disabled" : "")>
                                    <div class="item-icon live-pulse-icon" style="background:#fee2e2; color:#ef4444;"><i class="fa-solid fa-headset"></i></div>
                                    <div class="item-text">
                                        <p class="item-title" style="color: #2563eb; font-size: 1.1rem;">@session.Title</p>
                                        <p class="item-meta" style="color: #ef4444; font-weight: 900; font-size: 0.9rem;">
                                            <i class="fa-regular fa-calendar-check"></i> موعد الدخول: @session.ScheduledDate.ToString("yyyy/MM/dd - hh:mm tt")
                                        </p>
                                    </div>
                                </button>
                            }
                        }
                    </div>
                </div>
            }
            @if (Model.Lessons != null && Model.Lessons.Any())
            {
                foreach (var lesson in Model.Lessons.OrderBy(l => l.OrderIndex))
                {
                    bool isLessonUnlocked = unlockedLessonIds.Contains(lesson.Id);

                    <div class="lesson-group" style="@(!isLessonUnlocked ? "opacity:0.8;" : "")">
                        @if (!isLessonUnlocked)
                        {
                            <div class="lesson-locked-overlay">
                                <i class="fa-solid fa-lock"></i>
                                <span>اجتز اختبار الدرس السابق لتتمكن من فتحه</span>
                            </div>
                        }

                        <div class="lesson-group-title"><i class="fa-solid fa-book"></i> @lesson.Title</div>
                        <div class="lesson-items">
                            @if (lesson.Materials != null)
                            {
                                foreach (var item in lesson.Materials.OrderBy(m => m.OrderIndex))
                                {
                                    bool isLocked = (isExpired && !item.IsFreeSample) || !isLessonUnlocked;
                                    string icon = isLocked ? "fa-lock" : (item.MaterialType == "PDF" ? "fa-file-pdf" : (item.MaterialType == "Link" ? "fa-link" : "fa-play"));
                                    string typeLabel = item.MaterialType == "PDF" ? "مذكرة تفاعلية" : (item.MaterialType == "Link" ? "رابط خارجي" : "فيديو مسجل");

                                    <button onclick="loadContent('@item.UrlOrPath', '@item.Title', '@item.MaterialType', this)" class="item-btn" @(isLocked ? "disabled" : "")>
                                        <div class="item-icon"><i class="fa-solid @icon"></i></div>
                                        <div class="item-text">
                                            <p class="item-title">@item.Title</p>
                                            <div class="item-meta">
                                                @typeLabel
                                                @if (item.IsFreeSample)
                                                {
                                                    <span class="badge-free"><i class="fa-solid fa-star"></i> متاح للتقييم</span>
                                                }
                                            </div>
                                        </div>
                                    </button>
                                }
                            }
                            @if (lesson.Quizzes != null)
                            {
                                foreach (var quiz in lesson.Quizzes)
                                {
                                    bool isLocked = isExpired || !isLessonUnlocked;
                                    <button class="item-btn" onclick="location.href='/Student/TakeQuiz/@quiz.Id'" @(isLocked ? "disabled" : "")>
                                        <div class="item-icon" style="color:#2e7d32; background:#edf7ed;"><i class="fa-solid @(isLocked ? "fa-lock" : "fa-clipboard-check")"></i></div>
                                        <div class="item-text">
                                            <p class="item-title" style="color:#1b5e20;">@quiz.Title</p>
                                            <p class="item-meta"><i class="fa-regular fa-clock"></i> @quiz.DurationInMinutes دقيقة - اختبار</p>
                                        </div>
                                    </button>
                                }
                            }
                        </div>
                    </div>
                }
            }
        </div>

        <div id="tab-forum" class="playlist-content hidden">
            <div class="forum-container">
                <div class="forum-add-post">
                    <textarea id="postContent" class="forum-textarea" placeholder="هل لديك سؤال حول محتوى الدورة؟ اطرحه هنا ليجيب عليه المدرب..."></textarea>
                    <button onclick="submitPost()" class="btn-publish"><i class="fa-solid fa-paper-plane"></i> نشر السؤال</button>
                </div>
                <div id="postsList" style="display: flex; flex-direction: column; gap: 1rem;">
                    <div style="text-align:center; color:#94a3b8; padding: 2rem;"><i class="fa-solid fa-spinner fa-spin"></i> جاري تحميل النقاشات...</div>
                </div>
            </div>
        </div>

        <div id="tab-leaderboard" class="playlist-content hidden">
            <div class="lb-header">
                <i class="fa-solid fa-trophy"></i>
                <h3>لوحة شرف الدورة</h3>
                <p style="color:#64748b; font-size:0.9rem; margin:0; font-weight:bold;">ترتيب أفضل الطلاب بناءً على متوسط درجاتهم</p>
            </div>

            <div class="leaderboard-wrapper">
                @if (leaderboard != null && leaderboard.Any())
                {
                    int rank = 1;
                    foreach (var student in leaderboard)
                    {
                        string rankClass = rank == 1 ? "rank-1" : (rank == 2 ? "rank-2" : (rank == 3 ? "rank-3" : "rank-other"));
                        <div class="lb-card">
                            <div class="rank-badge @rankClass">@rank</div>
                            <div class="lb-info">
                                <h5>@student.StudentName</h5>
                                <p>اجتاز @student.TotalExamsTaken اختبارات</p>
                            </div>
                            <div class="lb-score">@student.AverageScore%</div>
                        </div>
                        rank++;
                    }
                }
                else
                {
                    <div style="text-align:center; color:#94a3b8; padding: 2rem;">
                        <i class="fa-solid fa-medal" style="font-size:3rem; margin-bottom:1rem; opacity:0.5;"></i>
                        <p style="font-weight:bold; margin:0;">لم يقم أي طالب بإجراء الاختبارات بعد. كن أنت الأول!</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    const currentCourseId = @Model.Id;
    let isForumLoaded = false;

    function switchTab(tabId, element) {
        document.querySelectorAll('.s-tab').forEach(t => t.classList.remove('active'));
        element.classList.add('active');
        document.getElementById('tab-curriculum').classList.add('hidden');
        document.getElementById('tab-forum').classList.add('hidden');
        document.getElementById('tab-leaderboard').classList.add('hidden');
        document.getElementById('tab-' + tabId).classList.remove('hidden');

        if(tabId === 'forum' && !isForumLoaded) {
            loadForumPosts();
        }
    }

    function getYouTubeEmbedUrl(url) {
        if (!url) return "";
        var regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=|shorts\/)([^#\&\?]*).*/;
        var match = url.match(regExp);
        if (match && match[2].length === 11) {
            return "https://www.youtube.com/embed/" + match[2] + "?rel=0&modestbranding=1&controls=1&showinfo=0&iv_load_policy=3&disablekb=1&playsinline=1&widget_referrer=" + window.location.origin + "&autoplay=1";
        }
        return url;
    }

    function loadContent(url, title, type, btnElement) {
        if (btnElement.disabled) return;

        if (type === 'Link') {
            window.open(url, '_blank');
            return;
        }

        document.getElementById('placeholder').style.display = 'none';

        var iframeViewer = document.getElementById('mainViewer');
        var videoViewer = document.getElementById('videoViewer');

        var watermark = document.getElementById('watermarkOverlay');

        iframeViewer.classList.add('hidden');
        videoViewer.classList.add('hidden');
        watermark.classList.add('hidden');

        iframeViewer.src = "";
        videoViewer.pause();

        if(type === 'PDF') {
            iframeViewer.src = url;
            iframeViewer.classList.remove('hidden');
        }
        else if (url.includes('.mp4') || type === 'RecordedLive') {
            videoViewer.src = url;
            videoViewer.classList.remove('hidden');
            watermark.classList.remove('hidden');
            videoViewer.play();
        }
        else {
            var embedUrl = getYouTubeEmbedUrl(url);
            iframeViewer.src = embedUrl;
            iframeViewer.classList.remove('hidden');

            watermark.classList.remove('hidden');
        }

        document.getElementById('currentTitle').innerText = title;

        document.querySelectorAll('.item-btn').forEach(el => el.classList.remove('active'));
        if(btnElement) btnElement.classList.add('active');
    }

    // --- Forum Functions ---
    async function loadForumPosts() {
        try {
            const response = await fetch(`/api/Forum/${currentCourseId}`);
            if(response.ok) {
                const posts = await response.json();
                renderPosts(posts);
                isForumLoaded = true;
            }
        } catch (error) { console.error(error); }
    }

    function renderPosts(posts) {
        const container = document.getElementById('postsList');
        container.innerHTML = '';
        if(posts.length === 0) {
            container.innerHTML = '<div style="text-align:center; color:#94a3b8; padding: 2rem;">لا توجد أسئلة حالياً.</div>';
            return;
        }

        posts.forEach(post => {
            let repliesHtml = '';
            post.replies.forEach(r => {
                let badge = (r.userRole === 'Admin' || r.userRole === 'Teacher') ? '<span class="badge-admin"><i class="fa-solid fa-crown"></i> الإدارة</span>' : '';
                repliesHtml += `
                    <div class="reply-card">
                        <div class="post-head" style="margin-bottom:0.5rem;">
                            <div class="post-user"><div class="post-avatar" style="width:2rem; height:2rem;">${r.userName.substring(0,1)}</div> ${r.userName} ${badge}</div>
                            <span class="post-date">${r.createdAt}</span>
                        </div>
                        <p class="post-content">${r.content}</p>
                    </div>`;
            });

            let adminBadge = (post.userRole === 'Admin' || post.userRole === 'Teacher') ? '<span class="badge-admin"><i class="fa-solid fa-crown"></i> الإدارة</span>' : '';
            const postHtml = `
                <div class="post-card">
                    <div class="post-head">
                        <div class="post-user"><div class="post-avatar">${post.userName.substring(0,1)}</div> ${post.userName} ${adminBadge}</div>
                        <span class="post-date">${post.createdAt}</span>
                    </div>
                    <p class="post-content">${post.content}</p>
                    <div class="replies-section">
                        ${repliesHtml}
                        <div class="reply-add">
                            <input type="text" id="replyInput_${post.id}" placeholder="اكتب رداً..." onkeypress="if(event.key === 'Enter') submitReply(${post.id})" />
                            <button onclick="submitReply(${post.id})" class="btn-reply">رد</button>
                        </div>
                    </div>
                </div>`;
            container.insertAdjacentHTML('beforeend', postHtml);
        });
    }

    async function submitPost() {
        const contentBox = document.getElementById('postContent');
        const content = contentBox.value.trim();
        if(!content) return;
        try {
            const res = await fetch('/api/Forum/post', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ CourseId: currentCourseId, Content: content }) });
            if(res.ok) { contentBox.value = ''; loadForumPosts(); }
        } catch(e) { console.error(e); }
    }

    async function submitReply(postId) {
        const inputBox = document.getElementById(`replyInput_${postId}`);
        const content = inputBox.value.trim();
        if(!content) return;
        try {
            const res = await fetch('/api/Forum/reply', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ PostId: postId, Content: content }) });
            if(res.ok) { inputBox.value = ''; loadForumPosts(); }
        } catch(e) { console.error(e); }
    }
</script>