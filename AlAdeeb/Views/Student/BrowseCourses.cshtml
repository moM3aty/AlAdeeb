@model IEnumerable<AlAdeeb.Models.Course>
@{
    ViewData["Title"] = "استكشاف الدورات التدريبية";
    var mySubscriptions = ViewBag.MySubscriptions as List<int> ?? new List<int>();
}

<style>
    @@font-face {
        font-family: 'Hayah';
        src: url('/fonts/Hayah.otf') format('opentype');
    }

    :root {
        --c-primary: #0a3254;
        --c-secondary: #af8f42;
        --c-bg: #f8fafc;
        --c-white: #ffffff;
        --shadow-card: 0 10px 30px rgba(10, 50, 84, 0.08);
        --transition: all 0.4s ease;
    }

    .browse-page {
        font-family: 'Hayah', sans-serif;
        background: var(--c-bg);
        min-height: 100vh;
        padding: 4rem 1.5rem;
        direction: rtl;
    }

    .page-header {
        text-align: center;
        margin-bottom: 4rem;
    }

        .page-header h2 {
            font-size: 3.5rem;
            color: var(--c-primary);
            margin: 0 0 1rem 0;
            font-weight: 900;
        }

        .page-header p {
            font-size: 1.3rem;
            color: #64748b;
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.6;
        }

    .course-grid {
        max-width: 1300px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr;
        gap: 2.5rem;
    }

    @@media(min-width: 768px) {
        .course-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media(min-width: 1024px) {
        .course-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .course-card {
        background: var(--c-white);
        border-radius: 2rem;
        overflow: hidden;
        box-shadow: var(--shadow-card);
        transition: var(--transition);
        border: 1px solid rgba(0,0,0,0.03);
        position: relative;
        display: flex;
        flex-direction: column;
    }

        .course-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(175, 143, 66, 0.15);
            border-color: rgba(175, 143, 66, 0.3);
        }

    /* شريط الخصم */
    .discount-badge {
        position: absolute;
        top: 1.5rem;
        left: -2rem;
        background: #ef4444;
        color: white;
        padding: 0.5rem 3rem;
        font-size: 1.1rem;
        font-weight: 900;
        transform: rotate(-45deg);
        z-index: 10;
        box-shadow: 0 4px 10px rgba(239, 68, 68, 0.4);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .c-cover {
        height: 220px;
        background: var(--c-primary);
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

        .c-cover img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.8;
            transition: var(--transition);
        }

    .course-card:hover .c-cover img {
        transform: scale(1.1);
        opacity: 1;
    }

    .c-body {
        padding: 2rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .c-title {
        font-size: 1.6rem;
        color: var(--c-primary);
        margin: 0 0 1rem 0;
        font-weight: 900;
        line-height: 1.4;
    }

    .c-desc {
        font-size: 1.1rem;
        color: #64748b;
        margin: 0 0 2rem 0;
        line-height: 1.7;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* منطقة السعر */
    .price-box {
        margin-top: auto;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
        background: #f8fafc;
        padding: 1rem;
        border-radius: 1rem;
        border: 1px dashed #cbd5e1;
        text-align: center;
    }

    .old-price {
        color: #94a3b8;
        font-size: 1.2rem;
        text-decoration: line-through;
        font-family: Arial, sans-serif;
        font-weight: bold;
    }

    .current-price {
        color: var(--c-primary);
        font-size: 2rem;
        font-weight: 900;
        font-family: Arial, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

        .current-price span {
            font-size: 1.2rem;
            color: var(--c-secondary);
            font-family: 'Hayah';
        }

    .btn-action {
        width: 100%;
        text-align: center;
        padding: 1.2rem;
        border-radius: 1rem;
        font-size: 1.3rem;
        font-weight: 900;
        text-decoration: none;
        transition: var(--transition);
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.8rem;
    }

    .btn-buy {
        background: var(--c-primary);
        color: var(--c-secondary);
        box-shadow: 0 10px 20px rgba(10,50,84,0.15);
    }

        .btn-buy:hover {
            background: var(--c-secondary);
            color: var(--c-primary);
            transform: translateY(-3px);
        }

    .btn-owned {
        background: #10b981;
        color: white;
        cursor: default;
    }
</style>

<div class="browse-page">
    <div class="page-header">
        <h2>استكشف برامجنا التدريبية</h2>
        <p>باقات متنوعة مصممة خصيصاً لتأسيسك وتدريبك حتى تصل إلى العلامة الكاملة 100%.</p>
    </div>

    <div class="course-grid">
        @foreach (var course in Model)
        {
            bool isOwned = mySubscriptions.Contains(course.Id);

            <div class="course-card">
                @if (course.OldPrice.HasValue && course.OldPrice.Value > course.Price)
                {
                    <div class="discount-badge">عرض خاص</div>
                }

                <div class="c-cover">
                    @if (!string.IsNullOrEmpty(course.ImageUrl))
                    {
                        <img src="@course.ImageUrl" alt="@course.Title" />
                    }
                    else
                    {
                        <i class="fa-solid fa-graduation-cap" style="font-size: 5rem; color: rgba(255,255,255,0.2); position:absolute;"></i>
                    }
                </div>

                <div class="c-body">
                    <h3 class="c-title">@course.Title</h3>
                    <p class="c-desc">@course.Description</p>

                    <div class="price-box">
                        @if (course.OldPrice.HasValue && course.OldPrice.Value > course.Price)
                        {
                            <div class="old-price">@course.OldPrice ريال</div>
                        }
                        <div class="current-price">@course.Price <span>ريال سعودي</span></div>
                    </div>

                    @if (isOwned)
                    {
                        <a href="/Student/Dashboard" class="btn-action btn-owned"><i class="fa-solid fa-circle-check"></i> مشترك بالفعل</a>
                    }
                    else
                    {
                        <a href="/Home/Checkout/@course.Id" class="btn-action btn-buy"><i class="fa-solid fa-cart-shopping"></i> اشترك الآن</a>
                    }
                </div>
            </div>
        }
    </div>
</div>