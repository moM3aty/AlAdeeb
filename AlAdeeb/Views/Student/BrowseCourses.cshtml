@model IEnumerable<AlAdeeb.Models.Course>
@{
    ViewData["Title"] = "استكشاف الكورسات";
}

<style>
    @@font-face {
        font-family: 'Hayah';
        src: url('/fonts/Hayah.otf') format('opentype');
    }

    :root {
        --c-primary: #0a3254;
        --c-secondary: #af8f42;
        --c-bg: #f4f7f9;
        --c-white: #ffffff;
        --shadow-card: 0 15px 35px rgba(10, 50, 84, 0.08);
        --radius-lg: 2.5rem;
        --transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    .browse-page {
        font-family: 'Hayah', sans-serif;
        padding: 4rem 1.5rem;
        max-width: 1280px;
        margin: 0 auto;
        direction: rtl;
    }

    .page-header {
        text-align: center;
        margin-bottom: 4rem;
        position: relative;
    }

    .header-badge {
        display: inline-block;
        background: rgba(175,143,66,0.1);
        color: var(--c-secondary);
        padding: 0.4rem 1.2rem;
        border-radius: 50px;
        border: 1px solid rgba(175,143,66,0.3);
        font-weight: bold;
        font-size: 1rem;
        margin-bottom: 1rem;
    }

    .page-header h2 {
        font-size: clamp(2.5rem, 5vw, 3.5rem);
        color: var(--c-primary);
        font-weight: 900;
        margin: 0 0 1rem 0;
    }

    .page-header p {
        font-size: 1.2rem;
        color: #64748b;
        max-width: 600px;
        margin: 0 auto;
        line-height: 1.6;
    }

    .course-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2.5rem;
    }

    @@media(min-width: 768px) {
        .course-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media(min-width: 1024px) {
        .course-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .course-card {
        background: var(--c-white);
        border-radius: var(--radius-lg);
        padding: 2.5rem;
        box-shadow: var(--shadow-card);
        border: 1px solid rgba(255,255,255,0.8);
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: var(--transition);
        animation: fadeUp 0.8s ease backwards;
    }

        .course-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 30px 60px rgba(10, 50, 84, 0.15);
            border-color: rgba(175,143,66,0.3);
        }

    .card-deco {
        position: absolute;
        top: 0;
        right: 0;
        width: 150px;
        height: 150px;
        background: linear-gradient(135deg, rgba(175,143,66,0.1), transparent);
        border-radius: 0 0 0 100%;
        pointer-events: none;
    }

    .card-icon {
        width: 4rem;
        height: 4rem;
        background: var(--c-primary);
        color: var(--c-secondary);
        border-radius: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        margin-bottom: 1.5rem;
        position: relative;
        z-index: 2;
        box-shadow: 0 10px 20px rgba(10,50,84,0.2);
    }

    .card-title {
        font-size: 1.8rem;
        color: var(--c-primary);
        font-weight: 900;
        margin: 0 0 1rem 0;
        line-height: 1.3;
        transition: var(--transition);
    }

    .course-card:hover .card-title {
        color: var(--c-secondary);
    }

    .card-desc {
        font-size: 1.1rem;
        color: #64748b;
        line-height: 1.6;
        margin: 0 0 2rem 0;
        flex-grow: 1;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
        margin-bottom: 1.5rem;
    }

    .price-label {
        font-size: 0.9rem;
        font-weight: 800;
        color: #94a3b8;
        text-transform: uppercase;
    }

    .price-value {
        font-size: 2rem;
        font-weight: 900;
        color: var(--c-primary);
        font-family: Arial, sans-serif;
        display: flex;
        align-items: baseline;
        gap: 0.3rem;
    }

        .price-value span {
            font-size: 1rem;
            font-family: 'Hayah', sans-serif;
            color: var(--c-secondary);
        }

    .btn-subscribe {
        background: var(--c-primary);
        color: var(--c-secondary);
        text-align: center;
        padding: 1.2rem;
        border-radius: 1.2rem;
        font-size: 1.4rem;
        font-weight: 900;
        text-decoration: none;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.8rem;
        transition: var(--transition);
        border: none;
    }

    .course-card:hover .btn-subscribe {
        background: var(--c-secondary);
        color: var(--c-primary);
        box-shadow: 0 10px 20px rgba(175,143,66,0.3);
    }

    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        background: var(--c-white);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-card);
    }

        .empty-state i {
            font-size: 4rem;
            color: #cbd5e1;
            margin-bottom: 1rem;
        }

        .empty-state h3 {
            font-size: 2rem;
            color: var(--c-primary);
            margin: 0;
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="browse-page">
    <div class="page-header">
        <div class="header-badge">الاستثمار الأفضل</div>
        <h2>استثمر في مستقبلك 🚀</h2>
        <p>اختر الدورة المناسبة لك وابدأ التدريب المكثف مع أ. صلاح عبد العال للوصول إلى الدرجة النهائية.</p>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="course-grid">
            @foreach (var course in Model)
            {
                <div class="course-card">
                    <div class="card-deco"></div>
                    <div class="card-icon"><i class="fa-solid fa-star"></i></div>

                    <h3 class="card-title">@course.Title</h3>
                    <p class="card-desc">@course.Description</p>

                    <div class="card-footer">
                        <span class="price-label">تكلفة الدورة</span>
                        <div class="price-value">@course.Price <span>ريال</span></div>
                    </div>

                    <a href="/Student/Subscribe/@course.Id" class="btn-subscribe">
                        اشتراك الآن <i class="fa-solid fa-arrow-left"></i>
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="fa-solid fa-face-frown"></i>
            <h3>لا توجد دورات جديدة!</h3>
            <p style="color:#64748b; margin-top:1rem; font-size:1.2rem;">أنت بالفعل مشترك في جميع الدورات المتاحة أو لا توجد دورات مفعلة حالياً.</p>
        </div>
    }
</div>