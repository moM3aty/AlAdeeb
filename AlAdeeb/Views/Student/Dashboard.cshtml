@model IEnumerable<AlAdeeb.Models.SubscriptionRequest>
@{
    ViewData["Title"] = "منصتي التعليمية";
}

<style>
    @@font-face {
        font-family: 'Hayah';
        src: url('/fonts/Hayah.otf') format('opentype');
    }

    :root {
        --c-primary: #0a3254;
        --c-secondary: #af8f42;
        --c-bg: #f4f7f9;
        --c-white: #ffffff;
        --shadow-soft: 0 10px 30px rgba(10, 50, 84, 0.08);
        --shadow-glow: 0 15px 30px rgba(175, 143, 66, 0.2);
        --radius-lg: 2rem;
        --radius-md: 1.2rem;
        --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    .student-dashboard {
        font-family: 'Hayah', sans-serif;
        padding: 3rem 1.5rem;
        max-width: 1280px;
        margin: 0 auto;
        direction: rtl;
    }

    /* Alerts */
    .alert-msg {
        padding: 1.2rem 1.5rem;
        border-radius: 1rem;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 1.2rem;
        font-weight: bold;
        animation: fadeUp 0.5s ease;
    }

    .alert-success {
        background: #edf7ed;
        color: #2e7d32;
        border: 1px solid #c8e6c9;
        border-right: 5px solid #2e7d32;
    }

    .alert-error {
        background: #fdeded;
        color: #c62828;
        border: 1px solid #ffcdd2;
        border-right: 5px solid #c62828;
    }

    .alert-icon {
        font-size: 1.5rem;
    }

    /* Welcome Banner */
    .welcome-banner {
        background: linear-gradient(135deg, var(--c-primary) 0%, #061c31 100%);
        border-radius: var(--radius-lg);
        padding: 3rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow-soft);
        margin-bottom: 3rem;
        gap: 2rem;
        animation: fadeUp 0.6s ease;
    }

    @@media(min-width: 768px) {
        .welcome-banner {
            flex-direction: row;
        }
    }

    .banner-bg-shape {
        position: absolute;
        top: -50px;
        left: -50px;
        width: 300px;
        height: 300px;
        background: var(--c-secondary);
        border-radius: 50%;
        opacity: 0.1;
        filter: blur(60px);
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        position: relative;
        z-index: 2;
    }

    .user-avatar {
        width: 5rem;
        height: 5rem;
        background: rgba(255,255,255,0.1);
        border: 2px solid rgba(175,143,66,0.5);
        border-radius: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        font-weight: 900;
        color: var(--c-secondary);
        backdrop-filter: blur(10px);
    }

    .user-text h2 {
        color: var(--c-white);
        font-size: 2.2rem;
        margin: 0 0 0.5rem 0;
        font-weight: 900;
    }

    .user-text p {
        color: rgba(255,255,255,0.7);
        font-size: 1.1rem;
        margin: 0;
    }

    .banner-actions {
        display: flex;
        gap: 1rem;
        position: relative;
        z-index: 2;
    }

    .btn-gold {
        background: var(--c-secondary);
        color: var(--c-primary);
        padding: 0.8rem 1.5rem;
        border-radius: 1rem;
        font-size: 1.1rem;
        font-weight: 800;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        box-shadow: var(--shadow-glow);
        transition: var(--transition);
        border: none;
    }

        .btn-gold:hover {
            transform: translateY(-3px);
            background: #cfa858;
        }

    .btn-glass {
        background: rgba(255,255,255,0.1);
        color: var(--c-white);
        padding: 0.8rem 1.5rem;
        border-radius: 1rem;
        font-size: 1.1rem;
        font-weight: 800;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.2);
        transition: var(--transition);
    }

        .btn-glass:hover {
            background: rgba(255,255,255,0.2);
            transform: translateY(-3px);
            color: var(--c-secondary);
        }

    /* Section Title */
    .section-head {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .section-head-icon {
        width: 3rem;
        height: 3rem;
        background: rgba(10,50,84,0.05);
        color: var(--c-primary);
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }

    .section-head h3 {
        font-size: 1.8rem;
        color: var(--c-primary);
        margin: 0;
        font-weight: 900;
    }

    /* Course Grid */
    .course-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    @@media(min-width: 768px) {
        .course-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media(min-width: 1024px) {
        .course-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .course-card {
        background: var(--c-white);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-soft);
        transition: var(--transition);
        border: 1px solid rgba(0,0,0,0.03);
        display: flex;
        flex-direction: column;
        animation: fadeUp 0.8s ease backwards;
    }

        .course-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(10, 50, 84, 0.12);
            border-color: rgba(175, 143, 66, 0.3);
        }

    .card-cover {
        height: 160px;
        background: var(--c-primary);
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

        .card-cover img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.5;
            mix-blend-mode: overlay;
            transition: var(--transition);
        }

    .course-card:hover .card-cover img {
        transform: scale(1.1);
        opacity: 0.7;
    }

    .card-cover-icon {
        position: absolute;
        font-size: 4rem;
        color: rgba(175, 143, 66, 0.3);
        transition: var(--transition);
    }

    .course-card:hover .card-cover-icon {
        color: rgba(175, 143, 66, 0.6);
        transform: scale(1.1);
    }

    .status-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: #edf7ed;
        color: #2e7d32;
        padding: 0.4rem 1rem;
        border-radius: 0.8rem;
        font-size: 0.9rem;
        font-weight: 900;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .status-dot {
        width: 8px;
        height: 8px;
        background: #2e7d32;
        border-radius: 50%;
    }

    .card-body {
        padding: 2rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .card-title {
        font-size: 1.4rem;
        color: var(--c-primary);
        margin: 0 0 1rem 0;
        font-weight: 900;
        line-height: 1.3;
    }

    .card-desc {
        font-size: 1rem;
        color: #64748b;
        margin: 0 0 2rem 0;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .btn-enter {
        margin-top: auto;
        background: rgba(10,50,84,0.03);
        color: var(--c-primary);
        text-align: center;
        padding: 1rem;
        border-radius: var(--radius-md);
        text-decoration: none;
        font-weight: 900;
        font-size: 1.2rem;
        transition: var(--transition);
        border: 1px solid rgba(10,50,84,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .course-card:hover .btn-enter {
        background: var(--c-primary);
        color: var(--c-secondary);
        border-color: var(--c-primary);
    }

    /* Empty State */
    .empty-state {
        background: var(--c-white);
        border-radius: var(--radius-lg);
        padding: 4rem 2rem;
        text-align: center;
        box-shadow: var(--shadow-soft);
        border: 1px dashed rgba(10,50,84,0.2);
    }

    .empty-icon {
        width: 6rem;
        height: 6rem;
        background: rgba(10,50,84,0.03);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        color: var(--c-secondary);
        margin: 0 auto 1.5rem auto;
    }

    .empty-state h3 {
        font-size: 2rem;
        color: var(--c-primary);
        margin: 0 0 1rem 0;
    }

    .empty-state p {
        color: #64748b;
        font-size: 1.1rem;
        margin-bottom: 2rem;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="student-dashboard">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-msg alert-success">
            <i class="fa-solid fa-circle-check alert-icon"></i>
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-msg alert-error">
            <i class="fa-solid fa-triangle-exclamation alert-icon"></i>
            <span>@TempData["ErrorMessage"]</span>
        </div>
    }

    <div class="welcome-banner">
        <div class="banner-bg-shape"></div>
        <div class="user-info">
            <div class="user-avatar">
                @ViewBag.StudentName?.Substring(0, 1)
            </div>
            <div class="user-text">
                <h2>مرحباً بك، @ViewBag.StudentName!</h2>
                <p>استكمل رحلة تفوقك واجتياز القدرات اللفظي بنجاح.</p>
            </div>
        </div>
        <div class="banner-actions">
            <a href="/Student/BrowseCourses" class="btn-gold"><i class="fa-solid fa-compass"></i> استكشاف الدورات</a>
            <a href="/Student/Results" class="btn-glass"><i class="fa-solid fa-chart-line"></i> نتائجي</a>
        </div>
    </div>

    <div class="section-head">
        <div class="section-head-icon"><i class="fa-solid fa-book-open-reader"></i></div>
        <h3>دوراتي التعليمية</h3>
    </div>

    @if (Model != null && Model.Any(r => r.Status == "Approved"))
    {
        <div class="course-grid">
            @foreach (var request in Model.Where(r => r.Status == "Approved"))
            {
                <div class="course-card">
                    <div class="card-cover">
                        @if (!string.IsNullOrEmpty(request.Course.ImageUrl))
                        {
                            <img src="@request.Course.ImageUrl" alt="@request.Course.Title" />
                        }
                        <i class="fa-solid fa-graduation-cap card-cover-icon"></i>
                        <div class="status-badge"><span class="status-dot"></span> مفعل</div>
                    </div>
                    <div class="card-body">
                        <h4 class="card-title">@request.Course.Title</h4>
                        <p class="card-desc">@request.Course.Description</p>
                        <a href="/Student/CourseContent/@request.Course.Id" class="btn-enter">
                            دخول الدورة <i class="fa-solid fa-arrow-left"></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="fa-solid fa-box-open"></i></div>
            <h3>لا توجد دورات مفعلة بعد</h3>
            <p>لم تقم بالاشتراك في أي دورة حتى الآن، أو أن طلبك لا يزال قيد المراجعة من الإدارة.</p>
            <a href="/Student/BrowseCourses" class="btn-gold" style="display: inline-flex; width: fit-content; margin: 0 auto;">تصفح الدورات المتاحة</a>
        </div>
    }
</div>