@model IEnumerable<AlAdeeb.Models.SubscriptionRequest>
@{
    ViewData["Title"] = "منصتي التعليمية";
    var progressDict = ViewBag.ProgressDict as Dictionary<int, double> ?? new Dictionary<int, double>();
}

<style>
    @@font-face { font-family: 'Hayah'; src: url('/fonts/Hayah.otf') format('opentype'); }
    :root { --c-primary: #0a3254; --c-secondary: #af8f42; --c-bg: #f4f7f9; --c-white: #ffffff; --shadow-soft: 0 15px 40px rgba(10, 50, 84, 0.08); --shadow-glow: 0 15px 30px rgba(175, 143, 66, 0.3); --radius-lg: 2.5rem; --radius-md: 1.5rem; --transition: all 0.5s cubic-bezier(0.25, 0.8, 0.25, 1); }
    .student-dashboard { font-family: 'Hayah', sans-serif; padding: 4rem 1.5rem; max-width: 1300px; margin: 0 auto; direction: rtl; }
    .alert-msg { padding: 1.5rem 2rem; border-radius: 1.5rem; margin-bottom: 2.5rem; display: flex; align-items: center; gap: 1.2rem; font-size: 1.3rem; font-weight: bold; animation: fadeUp 0.5s ease; }
    .alert-success { background: #edf7ed; color: #2e7d32; border: 1px solid #c8e6c9; border-right: 6px solid #2e7d32; box-shadow: 0 10px 20px rgba(46,125,50,0.1); }
    .alert-error { background: #fdeded; color: #c62828; border: 1px solid #ffcdd2; border-right: 6px solid #c62828; box-shadow: 0 10px 20px rgba(198,40,40,0.1); }
    .alert-icon { font-size: 1.8rem; }
    .welcome-banner { background: linear-gradient(135deg, var(--c-primary) 0%, #051b2e 100%); border-radius: var(--radius-lg); padding: 4rem; display: flex; flex-direction: column; justify-content: space-between; align-items: center; position: relative; overflow: hidden; box-shadow: var(--shadow-soft); margin-bottom: 4rem; gap: 3rem; animation: fadeUp 0.6s ease; border-bottom: 6px solid var(--c-secondary); }
    @@media(min-width: 992px) { .welcome-banner { flex-direction: row; } }
    .banner-bg-shape { position: absolute; top: -100px; left: -100px; width: 400px; height: 400px; background: var(--c-secondary); border-radius: 50%; opacity: 0.15; filter: blur(80px); animation: pulseBg 8s infinite alternate; }
    .user-info { display: flex; align-items: center; gap: 2rem; position: relative; z-index: 2; }
    .user-avatar { width: 7rem; height: 7rem; background: rgba(255,255,255,0.05); border: 2px solid rgba(175,143,66,0.6); border-radius: 2rem; display: flex; align-items: center; justify-content: center; font-size: 3rem; font-weight: 900; color: var(--c-secondary); backdrop-filter: blur(10px); box-shadow: 0 15px 30px rgba(0,0,0,0.2); }
    .user-text h2 { color: var(--c-white); font-size: 2.8rem; margin: 0 0 0.5rem 0; font-weight: 900; }
    .user-text p { color: rgba(255,255,255,0.8); font-size: 1.3rem; margin: 0; }
    .banner-actions { display: flex; gap: 1.5rem; position: relative; z-index: 2; flex-wrap: wrap; }
    .btn-gold { background: var(--c-secondary); color: var(--c-primary); padding: 1.2rem 2.2rem; border-radius: 1.5rem; font-size: 1.3rem; font-weight: 900; text-decoration: none; display: flex; align-items: center; gap: 0.8rem; box-shadow: var(--shadow-glow); transition: var(--transition); border: none; }
    .btn-gold:hover { transform: translateY(-5px); background: var(--c-secondary-light); box-shadow: 0 20px 40px rgba(175, 143, 66, 0.4); }
    .btn-glass { background: rgba(255,255,255,0.05); color: var(--c-white); padding: 1.2rem 2.2rem; border-radius: 1.5rem; font-size: 1.3rem; font-weight: 900; text-decoration: none; display: flex; align-items: center; gap: 0.8rem; backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.2); transition: var(--transition); }
    .btn-glass:hover { background: rgba(255,255,255,0.15); transform: translateY(-5px); color: var(--c-secondary); border-color: var(--c-secondary); }
    .section-head { display: flex; align-items: center; gap: 1.2rem; margin-bottom: 3rem; }
    .section-head-icon { width: 4rem; height: 4rem; background: rgba(10,50,84,0.05); color: var(--c-primary); border-radius: 1.2rem; display: flex; align-items: center; justify-content: center; font-size: 2rem; border: 1px solid rgba(10,50,84,0.1); }
    .section-head h3 { font-size: 2.2rem; color: var(--c-primary); margin: 0; font-weight: 900; }
    .course-grid { display: grid; grid-template-columns: 1fr; gap: 3rem; }
    @@media(min-width: 768px) { .course-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media(min-width: 1024px) { .course-grid { grid-template-columns: repeat(3, 1fr); } }
    .course-card { background: var(--c-white); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-soft); transition: var(--transition); border: 1px solid rgba(175,143,66,0.15); display: flex; flex-direction: column; animation: fadeUp 0.8s ease backwards; position: relative; }
    .course-card:hover { transform: translateY(-12px); box-shadow: 0 25px 50px rgba(10, 50, 84, 0.15); border-color: var(--c-secondary); }
    .card-cover { height: 180px; background: var(--c-primary); position: relative; display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .card-cover img { width: 100%; height: 100%; object-fit: cover; opacity: 0.5; mix-blend-mode: overlay; transition: var(--transition); }
    .course-card:hover .card-cover img { transform: scale(1.1); opacity: 0.8; }
    .card-cover-icon { position: absolute; font-size: 5rem; color: rgba(175, 143, 66, 0.3); transition: var(--transition); }
    .course-card:hover .card-cover-icon { color: rgba(175, 143, 66, 0.7); transform: scale(1.1); }
    .status-badge { position: absolute; top: 1.5rem; right: 1.5rem; background: rgba(255,255,255,0.9); backdrop-filter: blur(5px); color: #2e7d32; padding: 0.5rem 1.2rem; border-radius: 1rem; font-size: 1rem; font-weight: 900; display: flex; align-items: center; gap: 0.5rem; box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
    .status-dot { width: 10px; height: 10px; background: #2e7d32; border-radius: 50%; animation: pulseBg 2s infinite alternate; }
    .card-body { padding: 2.5rem; display: flex; flex-direction: column; flex-grow: 1; background: linear-gradient(to bottom, #ffffff, #fdfdfd); }
    .card-title { font-size: 1.6rem; color: var(--c-primary); margin: 0 0 1rem 0; font-weight: 900; line-height: 1.3; }
    .card-desc { font-size: 1.1rem; color: #64748b; margin: 0 0 1.5rem 0; line-height: 1.7; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

    /* شريط التقدم */
    .course-progress { margin-bottom: 2.5rem; }
    .prog-labels { display: flex; justify-content: space-between; font-size: 0.95rem; font-weight: 800; color: var(--c-primary); margin-bottom: 0.5rem; }
    .prog-labels span:last-child { color: var(--c-secondary); font-family: Arial, sans-serif; }
    .prog-bar-bg { width: 100%; height: 10px; background: #e2e8f0; border-radius: 50px; overflow: hidden; }
    .prog-bar-fill { height: 100%; background: linear-gradient(90deg, var(--c-secondary), #fbbf24); border-radius: 50px; transition: width 1.5s ease-in-out; }

    .btn-enter { margin-top: auto; background: rgba(10,50,84,0.03); color: var(--c-primary); text-align: center; padding: 1.2rem; border-radius: var(--radius-md); text-decoration: none; font-weight: 900; font-size: 1.3rem; transition: var(--transition); border: 1px solid rgba(10,50,84,0.1); display: flex; align-items: center; justify-content: center; gap: 0.8rem; }
    .course-card:hover .btn-enter { background: var(--c-primary); color: var(--c-secondary); border-color: var(--c-primary); box-shadow: 0 10px 20px rgba(10,50,84,0.15); }

    .empty-state { background: var(--c-white); border-radius: var(--radius-lg); padding: 6rem 2rem; text-align: center; box-shadow: var(--shadow-soft); border: 1px dashed rgba(175,143,66,0.3); }
    .empty-icon { width: 8rem; height: 8rem; background: rgba(175,143,66,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 4rem; color: var(--c-secondary); margin: 0 auto 2rem auto; }
    .empty-state h3 { font-size: 2.5rem; color: var(--c-primary); margin: 0 0 1rem 0; }
    .empty-state p { color: #64748b; font-size: 1.3rem; margin-bottom: 3rem; }

    .expiry-tag { margin-bottom: 1.5rem; font-size: 0.95rem; font-weight: bold; display: flex; align-items: center; gap: 0.5rem; }
    .exp-active { color: #ca8a04; }
    .exp-ended { color: #dc2626; }

    @@keyframes fadeUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes pulseBg { from { opacity: 0.5; transform: scale(1); } to { opacity: 1; transform: scale(1.2); } }
</style>

<div class="student-dashboard">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-msg alert-success"><i class="fa-solid fa-circle-check alert-icon"></i> <span>@TempData["SuccessMessage"]</span></div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-msg alert-error"><i class="fa-solid fa-triangle-exclamation alert-icon"></i> <span>@TempData["ErrorMessage"]</span></div>
    }

    <div class="welcome-banner">
        <div class="banner-bg-shape"></div>
        <div class="user-info">
            <div class="user-avatar">
                @ViewBag.StudentName?.Substring(0, 1)
            </div>
            <div class="user-text">
                <h2>مرحباً بك، @ViewBag.StudentName!</h2>
                <p>استكمل رحلة تفوقك واجتياز القدرات اللفظي بنجاح.</p>
            </div>
        </div>
        <div class="banner-actions">
            <a href="/Student/BrowseCourses" class="btn-gold"><i class="fa-solid fa-compass"></i> استكشاف الدورات</a>
            <a href="/Student/Results" class="btn-glass"><i class="fa-solid fa-chart-line"></i> نتائجي وتقييمي</a>
        </div>
    </div>

    <div class="section-head">
        <div class="section-head-icon"><i class="fa-solid fa-book-open-reader"></i></div>
        <h3>دوراتي التعليمية</h3>
    </div>

    @if (Model != null && Model.Any(r => r.Status == "Approved"))
    {
        <div class="course-grid">
            @foreach (var request in Model.Where(r => r.Status == "Approved"))
            {
                double prog = progressDict.ContainsKey(request.Course.Id) ? progressDict[request.Course.Id] : 0;

                <div class="course-card">
                    <div class="card-cover">
                        @if (!string.IsNullOrEmpty(request.Course.ImageUrl))
                        {
                            <img src="@request.Course.ImageUrl" alt="@request.Course.Title" />
                        }
                        <i class="fa-solid fa-graduation-cap card-cover-icon"></i>
                        <div class="status-badge"><span class="status-dot"></span> مفعل</div>
                    </div>
                    <div class="card-body">
                        <h4 class="card-title">@request.Course.Title</h4>

                        @if (request.ExpiryDate.HasValue)
                        {
                            var daysLeft = (request.ExpiryDate.Value - DateTime.Now).TotalDays;
                            if (daysLeft > 0)
                            {
                                <div class="expiry-tag exp-active"><i class="fa-regular fa-clock"></i> متبقي لاشتراكك: @Math.Ceiling(daysLeft) يوم</div>
                            }
                            else
                            {
                                <div class="expiry-tag exp-ended"><i class="fa-solid fa-ban"></i> انتهت فترة اشتراكك الأساسية</div>
                            }
                        }

                        <p class="card-desc">@request.Course.Description</p>

                        <!-- شريط التقدم الجديد -->
                        <div class="course-progress">
                            <div class="prog-labels">
                                <span>إنجازك في الدورة</span>
                                <span>@prog%</span>
                            </div>
                            <div class="prog-bar-bg">
                                <div class="prog-bar-fill" style="width: @prog%;"></div>
                            </div>
                        </div>

                        <a href="/Student/CourseContent/@request.Course.Id" class="btn-enter">
                            دخول الدورة والمذاكرة <i class="fa-solid fa-arrow-left"></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="fa-solid fa-box-open"></i></div>
            <h3>لا توجد دورات مفعلة بعد</h3>
            <p>لم تقم بالاشتراك في أي دورة حتى الآن، أو أن طلبك لا يزال قيد المراجعة من الإدارة.</p>
            <a href="/Student/BrowseCourses" class="btn-gold" style="display: inline-flex; width: fit-content; margin: 0 auto; font-size:1.4rem; padding: 1.2rem 3rem;">تصفح الدورات المتاحة الآن</a>
        </div>
    }
</div>