@{
    ViewData["Title"] = "نسيت كلمة المرور";
}

<style>
    @@font-face { font-family: 'Hayah'; src: url('/fonts/Hayah.otf') format('opentype'); }
    :root { --c-primary: #0a3254; --c-secondary: #af8f42; --c-bg: #f4f7f9; --c-white: #ffffff; --shadow-card: 0 25px 50px -12px rgba(10, 50, 84, 0.25); --transition: all 0.3s ease; }
    .auth-page { font-family: 'Hayah', sans-serif; background-color: var(--c-bg); min-height: 100vh; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; direction: rtl; padding: 2rem; }
    .auth-card { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(20px); width: 100%; max-width: 480px; padding: 3.5rem 3rem; border-radius: 2.5rem; box-shadow: var(--shadow-card); border: 1px solid rgba(255,255,255,0.5); border-top: 5px solid var(--c-secondary); position: relative; z-index: 10; animation: fadeUp 0.6s ease-out; }
    .auth-header { text-align: center; margin-bottom: 2.5rem; }
    .auth-logo { width: 5rem; height: 5rem; background: var(--c-primary); color: var(--c-secondary); border-radius: 1.5rem; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; margin: 0 auto 1.5rem auto; box-shadow: 0 10px 25px rgba(10, 50, 84, 0.2); }
    .auth-title { font-size: 2.2rem; font-weight: 900; color: var(--c-primary); margin: 0 0 0.5rem 0; }
    .auth-subtitle { color: #64748b; font-size: 1.1rem; margin: 0; }
    .form-group { margin-bottom: 1.5rem; position: relative; }
    .form-label { display: block; font-size: 1rem; font-weight: 800; color: var(--c-primary); margin-bottom: 0.5rem; }
    .form-control { width: 100%; background: #f8fafc; border: 2px solid #e2e8f0; border-radius: 1.2rem; padding: 1.2rem; font-size: 1.1rem; font-family: Arial, sans-serif; font-weight: bold; color: var(--c-primary); transition: var(--transition); box-sizing: border-box; text-align: left; direction: ltr; }
    .form-control:focus { outline: none; background: var(--c-white); border-color: var(--c-secondary); }
    .btn-submit { width: 100%; background: var(--c-primary); color: var(--c-secondary); border: none; padding: 1.2rem; border-radius: 1.2rem; font-size: 1.4rem; font-weight: 900; font-family: 'Hayah', sans-serif; cursor: pointer; transition: var(--transition); box-shadow: 0 10px 20px rgba(10, 50, 84, 0.2); }
    .btn-submit:hover { background: var(--c-secondary); color: var(--c-primary); transform: translateY(-2px); }
    .auth-footer { margin-top: 2rem; text-align: center; padding-top: 1.5rem; border-top: 1px solid #e2e8f0; font-size: 1.1rem; font-weight: bold; }
    .auth-footer a { color: var(--c-secondary); text-decoration: none; }
    @@keyframes fadeUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-logo"><i class="fa-solid fa-key"></i></div>
            <h2 class="auth-title">استعادة كلمة المرور</h2>
            <p class="auth-subtitle">أدخل رقم جوالك المسجل لنرسل لك رمز التحقق</p>
        </div>

        <form asp-action="ForgotPassword" method="post">
            <div asp-validation-summary="ModelOnly" style="color:red; font-weight:bold; margin-bottom:1rem;"></div>

            <div class="form-group">
                <label class="form-label">رقم الجوال المسجل</label>
                <input type="text" name="phoneNumber" class="form-control" placeholder="05xxxxxxxx" required />
            </div>

            <button type="submit" class="btn-submit">إرسال رمز التحقق</button>
        </form>

        <div class="auth-footer">
            تذكرت كلمة المرور؟ <a href="/Account/Login">العودة لتسجيل الدخول</a>
        </div>
    </div>
</div>