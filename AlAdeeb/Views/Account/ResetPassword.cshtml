@{
    ViewData["Title"] = "تعيين كلمة مرور جديدة";
}

<style>
    /* Same premium styling as ForgotPassword */
    @@font-face {
        font-family: 'Hayah';
        src: url('/fonts/Hayah.otf') format('opentype');
    }

    :root {
        --c-primary: #0a3254;
        --c-secondary: #af8f42;
        --c-bg: #f4f7f9;
        --c-white: #ffffff;
        --shadow-card: 0 25px 50px -12px rgba(10, 50, 84, 0.25);
        --transition: all 0.3s ease;
    }

    .auth-page {
        font-family: 'Hayah', sans-serif;
        background-color: var(--c-bg);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        direction: rtl;
    }

    .auth-card {
        background: rgba(255, 255, 255, 0.95);
        width: 100%;
        max-width: 480px;
        padding: 3.5rem 3rem;
        border-radius: 2.5rem;
        box-shadow: var(--shadow-card);
        border-top: 5px solid var(--c-secondary);
        text-align: center;
    }

    .auth-logo {
        width: 5rem;
        height: 5rem;
        background: var(--c-primary);
        color: var(--c-secondary);
        border-radius: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        margin: 0 auto 1.5rem auto;
    }

    .auth-title {
        font-size: 2.2rem;
        font-weight: 900;
        color: var(--c-primary);
        margin: 0 0 0.5rem 0;
    }

    .form-group {
        margin-bottom: 1.5rem;
        text-align: right;
    }

    .form-label {
        display: block;
        font-size: 1rem;
        font-weight: 800;
        color: var(--c-primary);
        margin-bottom: 0.5rem;
    }

    .form-control {
        width: 100%;
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 1.2rem;
        padding: 1.2rem;
        font-size: 1.1rem;
        font-family: Arial, sans-serif;
        font-weight: bold;
        color: var(--c-primary);
        transition: var(--transition);
        box-sizing: border-box;
        text-align: center;
        letter-spacing: 2px;
    }

        .form-control:focus {
            outline: none;
            border-color: var(--c-secondary);
            background: var(--c-white);
        }

    .btn-submit {
        width: 100%;
        background: var(--c-primary);
        color: var(--c-secondary);
        border: none;
        padding: 1.2rem;
        border-radius: 1.2rem;
        font-size: 1.4rem;
        font-weight: 900;
        font-family: 'Hayah', sans-serif;
        cursor: pointer;
        transition: var(--transition);
    }

        .btn-submit:hover {
            background: var(--c-secondary);
            color: var(--c-primary);
            transform: translateY(-2px);
        }

    .dev-alert {
        background: #dcfce7;
        color: #166534;
        padding: 1rem;
        border-radius: 1rem;
        font-weight: bold;
        margin-bottom: 1.5rem;
        border: 1px dashed #4ade80;
        text-align: center;
    }
</style>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-logo"><i class="fa-solid fa-lock-open"></i></div>
        <h2 class="auth-title">تعيين كلمة المرور</h2>
        <p style="color: #64748b; margin-bottom: 2rem;">تم إرسال رمز التحقق إلى جوالك</p>

        @if (TempData["DevCode"] != null)
        {
            <div class="dev-alert">
                <i class="fa-solid fa-circle-info"></i> رسالة النظام (للتجربة): <br />
                @TempData["DevCode"]
            </div>
        }

        <form asp-action="ResetPassword" method="post">
            <div asp-validation-summary="ModelOnly" style="color:red; font-weight:bold; margin-bottom:1rem;"></div>

            <input type="hidden" name="phoneNumber" value="@ViewBag.Phone" />

            <div class="form-group">
                <label class="form-label">رمز التحقق (4 أرقام)</label>
                <input type="text" name="code" class="form-control" placeholder="----" maxlength="4" required />
            </div>

            <div class="form-group">
                <label class="form-label">كلمة المرور الجديدة</label>
                <input type="password" name="newPassword" class="form-control" placeholder="••••••••" style="letter-spacing:normal; text-align:right;" required />
            </div>

            <button type="submit" class="btn-submit">حفظ كلمة المرور</button>
        </form>
    </div>
</div>