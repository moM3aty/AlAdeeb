@model IEnumerable<AlAdeeb.Models.ForumPost>
@{
    ViewData["Title"] = "إدارة منتدى النقاشات";
    Layout = "_AdminLayout";
    var courses = ViewBag.Courses as IEnumerable<AlAdeeb.Models.Course>;
}

<style>
    .page-header {
        background: url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyMCIgaGVpZ2h0PSIyMCI+PHBhdGggZD0iTTAgMGgyMHYyMEgweiIgZmlsbD0iI2FmOGY0MiIgZmlsbC1vcGFjaXR5PSIwLjA1Ii8+PC9zdmc+'), var(--c-primary);
        border-radius: var(--radius-xl);
        padding: 2.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        box-shadow: var(--shadow-md);
        margin-bottom: 2.5rem;
        color: var(--c-white);
        position: relative;
        overflow: hidden;
    }

    @@media(min-width: 768px) {
        .page-header {
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
        }
    }

    .header-info {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        position: relative;
        z-index: 2;
    }

    .header-icon {
        width: 5rem;
        height: 5rem;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        color: var(--c-secondary);
        border-radius: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
        backdrop-filter: blur(5px);
    }

    .header-text h2 {
        font-family: 'Hayah', sans-serif;
        font-size: 2.2rem;
        margin: 0 0 0.3rem 0;
        line-height: 1.2;
    }

    .header-text p {
        margin: 0;
        color: rgba(255,255,255,0.7);
        font-weight: 700;
        font-size: 1rem;
    }

    .filter-form {
        background: var(--c-white);
        padding: 1.5rem;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        border: 1px solid rgba(0,0,0,0.04);
        margin-bottom: 2rem;
        display: flex;
        gap: 1rem;
        align-items: center;
    }

        .filter-form select {
            flex: 1;
            padding: 1rem;
            border-radius: 1rem;
            border: 2px solid #e2e8f0;
            font-family: inherit;
            font-size: 1.1rem;
            font-weight: 800;
            color: var(--c-primary);
            outline: none;
            background: #f8fafc;
        }

        .filter-form button {
            background: var(--c-secondary);
            color: var(--c-primary-dark);
            padding: 1rem 2rem;
            border-radius: 1rem;
            font-weight: 900;
            border: none;
            cursor: pointer;
            transition: var(--transition);
        }

            .filter-form button:hover {
                background: var(--c-secondary-light);
                transform: translateY(-2px);
            }

    .post-card {
        background: var(--c-white);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        border: 1px solid rgba(0,0,0,0.04);
        margin-bottom: 2rem;
        overflow: hidden;
    }

    .post-header {
        padding: 1.5rem 2rem;
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .user-avatar {
        width: 3rem;
        height: 3rem;
        background: var(--c-primary);
        color: var(--c-secondary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        font-weight: 900;
    }

    .user-details h4 {
        margin: 0 0 0.2rem 0;
        color: var(--c-primary);
        font-size: 1.1rem;
        font-weight: 800;
    }

    .user-details span {
        font-size: 0.85rem;
        color: #64748b;
        font-family: Arial;
    }

    .course-badge {
        background: rgba(175,143,66,0.1);
        color: #a16207;
        padding: 0.4rem 1rem;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 900;
        border: 1px solid rgba(175,143,66,0.3);
    }

    .post-body {
        padding: 2rem;
        font-size: 1.2rem;
        color: var(--c-text-main);
        line-height: 1.6;
        white-space: pre-wrap;
    }

    .replies-section {
        background: #fdfdfd;
        padding: 1.5rem 2rem;
        border-top: 1px dashed #e2e8f0;
    }

    .reply-item {
        background: #f8fafc;
        border-radius: 1rem;
        padding: 1rem 1.5rem;
        margin-bottom: 1rem;
        border-right: 4px solid #cbd5e1;
    }

        .reply-item.admin-reply {
            border-right-color: var(--c-secondary);
            background: rgba(175,143,66,0.02);
        }

    .reply-head {
        display: flex;
        justify-content: space-between;
        margin-bottom: 0.5rem;
    }

        .reply-head strong {
            color: var(--c-primary);
            font-size: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

    .admin-badge {
        background: var(--c-secondary);
        color: var(--c-white);
        font-size: 0.7rem;
        padding: 0.1rem 0.4rem;
        border-radius: 4px;
    }

    .reply-head span {
        font-size: 0.8rem;
        color: #94a3b8;
        font-family: Arial;
    }

    .reply-form {
        display: flex;
        gap: 1rem;
        margin-top: 1.5rem;
    }

        .reply-form input {
            flex: 1;
            padding: 1rem 1.5rem;
            border-radius: 1rem;
            border: 2px solid #e2e8f0;
            font-family: inherit;
            font-size: 1rem;
            font-weight: 600;
            outline: none;
            background: var(--c-white);
            transition: var(--transition);
        }

            .reply-form input:focus {
                border-color: var(--c-secondary);
            }

    .btn-send {
        background: var(--c-primary);
        color: var(--c-secondary);
        padding: 0 2rem;
        border-radius: 1rem;
        font-weight: 900;
        border: none;
        cursor: pointer;
        transition: var(--transition);
    }

        .btn-send:hover {
            background: var(--c-secondary);
            color: var(--c-primary);
        }

    .btn-delete {
        background: none;
        border: none;
        color: #ef4444;
        font-size: 1.2rem;
        cursor: pointer;
        transition: 0.3s;
        padding: 0.5rem;
    }

        .btn-delete:hover {
            color: #b91c1c;
            transform: scale(1.1);
        }
</style>

<div class="page-header">
    <div class="header-info">
        <div class="header-icon"><i class="fa-solid fa-users-rays"></i></div>
        <div class="header-text">
            <h2>إدارة النقاشات</h2>
            <p>تواصل مع طلابك، أجب عن استفساراتهم، وأدر مجتمع المنصة من مكان واحد.</p>
        </div>
    </div>
</div>

<form method="get" asp-action="Discussions" class="filter-form">
    <select name="courseId">
        <option value="">-- عرض جميع أسئلة الدورات --</option>
        @if (courses != null)
        {
            foreach (var c in courses)
            {
                if (ViewBag.SelectedCourseId != null && (int)ViewBag.SelectedCourseId == c.Id)
                {
                    <option value="@c.Id" selected>@c.Title</option>
                }
                else
                {
                    <option value="@c.Id">@c.Title</option>
                }
            }
        }
    </select>
    <button type="submit"><i class="fa-solid fa-filter"></i> تصفية</button>
</form>

@if (Model != null && Model.Any())
{
    foreach (var post in Model)
    {
        <div class="post-card">
            <div class="post-header">
                <div class="user-info">
                    <div class="user-avatar">@post.User.FullName.Substring(0, 1)</div>
                    <div class="user-details">
                        <h4>@post.User.FullName</h4>
                        <span dir="ltr">@post.CreatedAt.ToString("yyyy/MM/dd hh:mm tt")</span>
                    </div>
                </div>
                <div style="display:flex; align-items:center; gap:1rem;">
                    <span class="course-badge"><i class="fa-solid fa-book"></i> @post.Course.Title</span>
                    <form asp-action="DeleteForumPost" method="post" onsubmit="return confirm('هل أنت متأكد من حذف هذا السؤال وكل الردود عليه؟');">
                        <input type="hidden" name="postId" value="@post.Id" />
                        <button type="submit" class="btn-delete" title="حذف السؤال"><i class="fa-solid fa-trash-can"></i></button>
                    </form>
                </div>
            </div>

            <div class="post-body">
                @post.Content
            </div>

            <div class="replies-section">
                @if (post.Replies != null && post.Replies.Any())
                {
                    foreach (var reply in post.Replies.OrderBy(r => r.CreatedAt))
                    {
                        bool isAdmin = reply.User.Role == "Admin" || reply.User.Role == "Teacher";
                        <div class="reply-item @(isAdmin ? "admin-reply" : "")">
                            <div class="reply-head">
                                <strong>
                                    @reply.User.FullName
                                    @if (isAdmin)
                                    {
                                        <span class="admin-badge"><i class="fa-solid fa-crown"></i> الإدارة</span>
                                    }
                                </strong>
                                <span dir="ltr">@reply.CreatedAt.ToString("MM/dd hh:mm tt")</span>
                            </div>
                            <div style="color: #475569; line-height: 1.6;">@reply.Content</div>
                        </div>
                    }
                }

                <form asp-action="AdminReply" method="post" class="reply-form">
                    <input type="hidden" name="postId" value="@post.Id" />
                    <input type="text" name="content" required placeholder="اكتب ردك هنا ليظهر للطلاب فوراً..." autocomplete="off" />
                    <button type="submit" class="btn-send"><i class="fa-solid fa-paper-plane"></i> إرسال الرد</button>
                </form>
            </div>
        </div>
    }
}
else
{
    <div style="text-align:center; padding: 5rem 2rem; background: var(--c-white); border-radius: var(--radius-xl);">
        <i class="fa-solid fa-mug-hot" style="font-size: 5rem; color:#cbd5e1; margin-bottom: 1rem;"></i>
        <h3 style="font-family:'Hayah',sans-serif; color:var(--c-primary); font-size:2rem;">لا توجد نقاشات حالياً</h3>
        <p style="color:#64748b; font-size:1.1rem; font-weight:600;">كل شيء هادئ، لم يقم أي طالب بطرح أسئلة بعد.</p>
    </div>
}