@model AlAdeeb.Models.Course
@{
    ViewData["Title"] = "بناء اختبار جديد";
    Layout = "_AdminLayout";
}

<style>
    .quiz-form {
        max-width: 1000px;
        margin: 0 auto;
        animation: fadeIn 0.8s ease;
        padding-bottom: 100px;
    }

    .quiz-config {
        background: var(--c-primary);
        padding: 3rem;
        border-radius: 3rem;
        color: #fff;
        margin-bottom: 3rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        border-bottom: 8px solid var(--c-secondary);
        position: relative;
        overflow: hidden;
    }

        .quiz-config::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(rgba(255,255,255,0.05) 2px, transparent 2px);
            background-size: 20px 20px;
        }

    .q-card {
        background: #fff;
        border-radius: 2.5rem;
        padding: 3rem;
        margin-bottom: 2rem;
        border: 2px solid #f1f5f9;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        position: relative;
    }

        .q-card:hover {
            border-color: var(--c-secondary);
        }

    .q-num {
        width: 50px;
        height: 50px;
        background: var(--c-primary);
        color: var(--c-secondary);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 900;
        position: absolute;
        top: -20px;
        right: 40px;
        border: 4px solid #fff;
    }

    .options-setup {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-top: 2rem;
    }

    .opt-box {
        display: flex;
        align-items: center;
        gap: 1rem;
        background: #f8fafc;
        padding: 1rem;
        border-radius: 1.2rem;
        border: 1px solid #e2e8f0;
    }

        .opt-box span {
            width: 35px;
            height: 35px;
            background: #fff;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            color: var(--c-secondary);
            border: 1px solid #e2e8f0;
            flex-shrink: 0;
        }

        .opt-box input {
            flex: 1;
            border: none;
            background: transparent;
            font-family: inherit;
            font-size: 1.1rem;
            font-weight: bold;
            outline: none;
        }

    .correct-selector {
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 1px dashed #e2e8f0;
        text-align: center;
    }

        .correct-selector label {
            font-weight: 900;
            color: var(--c-primary);
            margin-left: 1rem;
            font-size: 1.2rem;
        }

        .correct-selector select {
            padding: 0.8rem 2rem;
            border-radius: 1rem;
            border: 2px solid var(--c-secondary);
            font-family: inherit;
            font-weight: 900;
            font-size: 1.1rem;
            color: var(--c-primary);
        }

    .sticky-actions {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(10px);
        padding: 1.5rem 3rem;
        border-top: 2px solid var(--c-secondary);
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 1000;
    }

    .btn-save-all {
        background: var(--c-primary);
        color: var(--c-secondary);
        padding: 1.2rem 4rem;
        border-radius: 1.5rem;
        font-size: 1.5rem;
        font-weight: 900;
        border: none;
        cursor: pointer;
        box-shadow: 0 10px 20px rgba(10,50,84,0.2);
    }

        .btn-save-all:hover {
            background: var(--c-secondary);
            color: var(--c-primary);
        }

    .btn-add-q {
        background: var(--c-secondary);
        color: var(--c-white);
        padding: 1rem 2rem;
        border-radius: 1.2rem;
        font-weight: 900;
        font-size: 1.2rem;
        border: none;
        cursor: pointer;
    }
</style>

<div class="quiz-form">
    <form asp-controller="Admin" asp-action="SaveQuiz" method="post" enctype="multipart/form-data">
        <input type="hidden" name="CourseId" value="@Model.Id" />

        <div class="quiz-config">
            <div>
                <label class="form-label" style="color:#fff;">عنوان الاختبار</label>
                <input type="text" name="QuizTitle" required class="form-control" style="background:rgba(255,255,255,0.1); border-color:rgba(255,255,255,0.2); color:#fff;" />
            </div>
            <div>
                <label class="form-label" style="color:#fff;">المدة بالدقائق</label>
                <input type="number" name="DurationInMinutes" value="20" required class="form-control" style="background:rgba(255,255,255,0.1); border-color:rgba(255,255,255,0.2); color:#fff;" />
            </div>
        </div>

        <div id="questions">
            <!-- سيتم الحقن هنا -->
        </div>

        <div class="sticky-actions">
            <button type="button" class="btn-add-q" onclick="addQ()">+ إضافة سؤال جديد</button>
            <button type="submit" class="btn-save-all">حفظ ونشر الاختبار <i class="fa-solid fa-paper-plane"></i></button>
        </div>
    </form>
</div>

<script>
    let qCount = 0;
    function addQ() {
        const html = `
            <div class="q-card">
                <div class="q-num">${qCount + 1}</div>
                <div class="form-group">
                    <label class="form-label">نص السؤال أو [سؤال مصور]</label>
                    <textarea name="Questions[${qCount}].QuestionText" rows="2" class="form-control"></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label">رفع صورة للسؤال (اختياري)</label>
                    <input type="file" name="Questions[${qCount}].ImageFile" class="form-control" accept="image/*" />
                </div>
                <div class="options-setup">
                    <div class="opt-box"><span>أ</span><input type="text" name="Questions[${qCount}].OptionA" required /></div>
                    <div class="opt-box"><span>ب</span><input type="text" name="Questions[${qCount}].OptionB" required /></div>
                    <div class="opt-box"><span>ج</span><input type="text" name="Questions[${qCount}].OptionC" required /></div>
                    <div class="opt-box"><span>د</span><input type="text" name="Questions[${qCount}].OptionD" required /></div>
                </div>
                <div class="correct-selector">
                    <label>الإجابة الصحيحة هي:</label>
                    <select name="Questions[${qCount}].CorrectOption">
                        <option value="A">أ</option><option value="B">ب</option><option value="C">ج</option><option value="D">د</option>
                    </select>
                </div>
            </div>
        `;
        document.getElementById('questions').insertAdjacentHTML('beforeend', html);
        qCount++;
    }
    window.onload = addQ;
</script>