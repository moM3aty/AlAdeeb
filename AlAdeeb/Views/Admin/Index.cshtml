@model IEnumerable<AlAdeeb.Models.Course>
@{
    ViewData["Title"] = "لوحة القيادة";
    Layout = "_AdminLayout";
}

<style>
    /* استدعاء خط Hayah */
    @@font-face {
        font-family: 'Hayah';
        src: url('/fonts/Hayah.otf') format('opentype');
        font-weight: normal;
        font-style: normal;
    }

    :root {
        --c-primary: #0a3254;
        --c-primary-dark: #061d33;
        --c-secondary: #af8f42;
        --c-secondary-light: #cfa858;
        --c-bg: #f8f9fc;
        --c-white: #ffffff;
        --c-text-main: #1e293b;
        --c-text-muted: #64748b;
        --shadow-glow: 0 15px 35px -5px rgba(175, 143, 66, 0.2);
        --shadow-premium: 0 20px 40px -10px rgba(10, 50, 84, 0.12);
        --transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .admin-dash {
        font-family: 'Hayah', sans-serif;
        animation: fadeIn 0.6s ease-out;
        direction: rtl;
    }

    /* Welcome Banner */
    .dash-banner {
        background: linear-gradient(135deg, var(--c-primary-dark) 0%, var(--c-primary) 100%);
        border-radius: 2.5rem;
        padding: 4rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow-premium);
        margin-bottom: 3rem;
        flex-wrap: wrap;
        gap: 2rem;
        border: 1px solid rgba(175, 143, 66, 0.2);
    }

        .dash-banner::before {
            content: '';
            position: absolute;
            top: -50px;
            right: -50px;
            width: 300px;
            height: 300px;
            background: var(--c-secondary);
            border-radius: 50%;
            opacity: 0.1;
            filter: blur(60px);
        }

    .dash-text {
        position: relative;
        z-index: 10;
    }

        .dash-text h2 {
            font-size: 3.5rem;
            color: var(--c-white);
            margin: 0 0 0.8rem 0;
            font-weight: 900;
            line-height: 1.2;
        }

        .dash-text p {
            font-size: 1.4rem;
            color: rgba(255, 255, 255, 0.7);
            margin: 0;
            font-weight: bold;
        }

    .btn-create {
        background: var(--c-secondary);
        color: var(--c-primary);
        padding: 1.2rem 2.5rem;
        border-radius: 1.5rem;
        font-size: 1.4rem;
        font-weight: 900;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        box-shadow: var(--shadow-glow);
        transition: var(--transition);
        position: relative;
        z-index: 10;
        border: none;
    }

        .btn-create:hover {
            transform: translateY(-5px) scale(1.02);
            background: var(--c-secondary-light);
            box-shadow: 0 20px 40px rgba(175, 143, 66, 0.4);
        }

    /* Stats Grid */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
        margin-bottom: 4rem;
    }

    .stat-card {
        background: var(--c-white);
        border-radius: 2rem;
        padding: 2.5rem;
        display: flex;
        align-items: center;
        gap: 2rem;
        box-shadow: var(--shadow-premium);
        border: 1px solid rgba(255, 255, 255, 0.8);
        transition: var(--transition);
        position: relative;
        overflow: hidden;
        text-decoration: none;
    }

        .stat-card:hover {
            transform: translateY(-8px);
            border-color: var(--c-secondary);
            box-shadow: 0 30px 60px -15px rgba(10, 50, 84, 0.15);
        }

    .stat-icon {
        width: 5.5rem;
        height: 5.5rem;
        border-radius: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        flex-shrink: 0;
        transition: var(--transition);
    }

    .icon-blue {
        background: rgba(10, 50, 84, 0.05);
        color: var(--c-primary);
    }

    .icon-gold {
        background: rgba(175, 143, 66, 0.1);
        color: var(--c-secondary);
    }

    .icon-red {
        background: #fef2f2;
        color: #ef4444;
    }

    .stat-card:hover .stat-icon {
        transform: rotate(5deg) scale(1.1);
    }

    .stat-info h3 {
        font-size: 1.2rem;
        color: var(--c-text-muted);
        margin: 0 0 0.5rem 0;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .stat-info p {
        font-size: 3.5rem;
        color: var(--c-primary);
        margin: 0;
        font-weight: 900;
        font-family: Arial, sans-serif;
        line-height: 1;
    }

    /* Courses Section */
    .section-box {
        background: var(--c-white);
        border-radius: 2.5rem;
        box-shadow: var(--shadow-premium);
        border: 1px solid rgba(255, 255, 255, 0.8);
        overflow: hidden;
    }

    .section-head {
        background: #f8fafc;
        padding: 2rem 3rem;
        border-bottom: 2px solid #f1f5f9;
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

        .section-head h3 {
            font-size: 2rem;
            color: var(--c-primary);
            margin: 0;
            font-weight: 900;
        }

        .section-head i {
            color: var(--c-secondary);
            font-size: 2rem;
        }

    .courses-grid {
        padding: 3rem;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 2.5rem;
    }

    .course-item {
        background: #ffffff;
        border: 2px solid #f1f5f9;
        border-radius: 2rem;
        padding: 2.5rem;
        transition: var(--transition);
        display: flex;
        flex-direction: column;
        position: relative;
    }

        .course-item:hover {
            border-color: var(--c-secondary);
            box-shadow: 0 15px 35px rgba(10, 50, 84, 0.08);
            transform: translateY(-5px);
        }

    .status-line {
        position: absolute;
        top: 0;
        left: 2rem;
        right: 2rem;
        height: 6px;
        border-radius: 0 0 6px 6px;
    }

    .status-active {
        background: #2e7d32;
        box-shadow: 0 2px 10px rgba(46, 125, 50, 0.3);
    }

    .status-inactive {
        background: #94a3b8;
    }

    .c-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1.5rem;
        margin-top: 0.5rem;
    }

    .c-title {
        font-size: 1.8rem;
        color: var(--c-primary);
        font-weight: 900;
        margin: 0;
        line-height: 1.3;
    }

    .c-price {
        background: rgba(175, 143, 66, 0.1);
        color: var(--c-secondary);
        padding: 0.5rem 1rem;
        border-radius: 0.8rem;
        font-weight: 900;
        font-size: 1.2rem;
        font-family: Arial, sans-serif;
        border: 1px solid rgba(175, 143, 66, 0.2);
    }

    .c-desc {
        font-size: 1.2rem;
        color: var(--c-text-muted);
        margin: 0 0 2.5rem 0;
        line-height: 1.8;
        flex-grow: 1;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        font-weight: 600;
    }

    .c-actions {
        display: flex;
        gap: 1rem;
        border-top: 1px solid #f1f5f9;
        padding-top: 2rem;
    }

    .btn-manage {
        flex: 1;
        background: var(--c-primary);
        color: var(--c-secondary);
        text-align: center;
        padding: 1rem;
        border-radius: 1.2rem;
        text-decoration: none;
        font-weight: 900;
        font-size: 1.3rem;
        transition: var(--transition);
        border: 1px solid var(--c-primary);
    }

        .btn-manage:hover {
            background: var(--c-secondary);
            color: var(--c-primary);
            border-color: var(--c-secondary);
        }

    .btn-icon {
        width: 3.5rem;
        height: 3.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 1.2rem;
        background: #f8fafc;
        color: #64748b;
        transition: var(--transition);
        border: 1px solid #e2e8f0;
        cursor: pointer;
        font-size: 1.3rem;
        text-decoration: none;
    }

        .btn-icon:hover {
            background: var(--c-secondary);
            color: var(--c-white);
            border-color: var(--c-secondary);
            transform: scale(1.05);
        }

    .btn-del:hover {
        background: #ef4444;
        color: var(--c-white);
        border-color: #ef4444;
    }

    .empty-state {
        text-align: center;
        padding: 6rem 2rem;
        grid-column: 1 / -1;
    }

        .empty-state i {
            font-size: 6rem;
            color: #e2e8f0;
            margin-bottom: 2rem;
        }

        .empty-state h4 {
            font-size: 2.5rem;
            color: var(--c-primary);
            margin: 0 0 1rem 0;
            font-weight: 900;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="admin-dash">

    <div class="dash-banner">
        <div class="dash-text">
            <h2>نظرة عامة على المنصة</h2>
            <p>ملخص شامل لنشاط الدورات وحركة الطلاب اليوم.</p>
        </div>
        <a href="/Admin/CreateCourse" class="btn-create">
            <i class="fa-solid fa-plus"></i> إضافة دورة جديدة
        </a>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon icon-blue"><i class="fa-solid fa-users"></i></div>
            <div class="stat-info">
                <h3>الطلاب المسجلين</h3>
                <p>@ViewBag.TotalStudentsCount</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon icon-gold"><i class="fa-solid fa-layer-group"></i></div>
            <div class="stat-info">
                <h3>إجمالي الدورات</h3>
                <p>@ViewBag.TotalCoursesCount</p>
            </div>
        </div>
        <a href="/Admin/SubscriptionRequests" class="stat-card">
            <div class="stat-icon icon-red"><i class="fa-solid fa-wallet"></i></div>
            <div class="stat-info">
                <h3>طلبات معلقة</h3>
                <p>@ViewBag.PendingRequestsCount</p>
            </div>
            <i class="fa-solid fa-chevron-left" style="position: absolute; left: 2.5rem; color: var(--c-secondary); font-size: 2rem; opacity: 0.3;"></i>
        </a>
    </div>

    <div class="section-box">
        <div class="section-head">
            <i class="fa-solid fa-cubes"></i>
            <h3>إدارة الدورات الحالية</h3>
        </div>
        <div class="courses-grid">
            @if (Model != null && Model.Any())
            {
                foreach (var course in Model)
                {
                    <div class="course-item">
                        <div class="status-line @(course.IsActive ? "status-active" : "status-inactive")"></div>
                        <div class="c-header">
                            <h4 class="c-title">@course.Title</h4>
                            <span class="c-price">@course.Price ريال</span>
                        </div>
                        <p class="c-desc">@course.Description</p>
                        <div class="c-actions">
                            <a href="/Course/Details/@course.Id" class="btn-manage">إدارة المحتوى</a>
                            <a href="/Admin/EditCourse/@course.Id" class="btn-icon" title="تعديل الإعدادات"><i class="fa-solid fa-pen"></i></a>
                            <form asp-action="DeleteCourse" asp-route-id="@course.Id" method="post" onsubmit="return confirm('هل أنت متأكد من حذف الكورس نهائياً؟');" style="margin:0;">
                                <button type="submit" class="btn-icon btn-del" title="حذف الكورس"><i class="fa-solid fa-trash-can"></i></button>
                            </form>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="fa-solid fa-box-open"></i>
                    <h4>لا توجد دورات مضافة حالياً</h4>
                    <p style="font-size:1.4rem; color:var(--c-text-muted); margin-bottom:2.5rem;">ابدأ ببناء أول دورة تدريبية لاستقبال الطلاب.</p>
                    <a href="/Admin/CreateCourse" class="btn-create" style="box-shadow: none;">إضافة دورة الآن</a>
                </div>
            }
        </div>
    </div>
</div>