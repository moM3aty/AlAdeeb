@model IEnumerable<AlAdeeb.Models.Course>
@{
    ViewData["Title"] = "اللوحة الرئيسية";
    Layout = "_AdminLayout";
}

<style>
    /* تصميم البطاقة الترحيبية الفخمة */
    .welcome-widget {
        background: url('data:image/svg+xml;base64,'), linear-gradient(135deg, var(--c-primary-dark) 0%, var(--c-primary) 100%);
        border-radius: var(--radius-xl);
        padding: 3rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: var(--shadow-md);
        margin-bottom: 2.5rem;
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(175, 143, 66, 0.2);
    }

        .welcome-widget::after {
            content: '\f5d2';
            font-family: "Font Awesome 6 Free";
            font-weight: 900;
            position: absolute;
            left: -20px;
            top: -40px;
            font-size: 15rem;
            color: rgba(255,255,255,0.03);
            transform: rotate(-15deg);
            pointer-events: none;
        }

    .welcome-text h2 {
        font-size: 2.5rem;
        color: #FFF !important;
        margin: 0 0 0.5rem 0;
        font-family: 'Hayah', sans-serif;
    }

        .welcome-text h2 span {
            color: var(--c-secondary);
        }

    .welcome-text p {
        font-size: 1.1rem;
        color: rgba(255,255,255,0.8);
        margin: 0;
        font-weight: 600;
    }

    .btn-create-course {
        background: linear-gradient(135deg, var(--c-secondary), var(--c-secondary-light));
        color: var(--c-primary-dark);
        padding: 1rem 2rem;
        border-radius: 12px;
        font-weight: 800;
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        gap: 0.8rem;
        box-shadow: var(--shadow-glow);
        transition: var(--transition);
        border: none;
        position: relative;
        z-index: 2;
    }

        .btn-create-course:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(175, 143, 66, 0.5);
        }

    /* شبكة الإحصائيات الزجاجية */
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        margin-bottom: 3rem;
    }

    .kpi-card {
        background: var(--c-white);
        border-radius: var(--radius-lg);
        padding: 2rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        box-shadow: var(--shadow-sm);
        border: 1px solid rgba(0,0,0,0.04);
        transition: var(--transition);
        position: relative;
        overflow: hidden;
    }

        .kpi-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-md);
            border-color: rgba(175, 143, 66, 0.3);
        }

        .kpi-card::before {
            content: '';
            position: absolute;
            bottom: 0;
            right: 0;
            width: 100%;
            height: 4px;
            background: var(--c-secondary);
            transform: scaleX(0);
            transform-origin: right;
            transition: var(--transition);
        }

        .kpi-card:hover::before {
            transform: scaleX(1);
        }

    .kpi-icon {
        width: 5rem;
        height: 5rem;
        border-radius: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
    }

    .kpi-blue {
        background: #e0f2fe;
        color: #0284c7;
    }

    .kpi-gold {
        background: #fef3c7;
        color: #d97706;
    }

    .kpi-red {
        background: #fee2e2;
        color: #dc2626;
    }

    .kpi-info h3 {
        font-size: 0.9rem;
        color: var(--c-text-muted);
        margin: 0 0 0.3rem 0;
        font-weight: 800;
        text-transform: uppercase;
    }

    .kpi-info p {
        font-size: 2.5rem;
        color: var(--c-primary);
        margin: 0;
        font-weight: 900;
        font-family: Arial, sans-serif;
        line-height: 1;
    }

    /* قسم الدورات الفخم */
    .section-glass {
        background: var(--c-white);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-sm);
        border: 1px solid rgba(0,0,0,0.05);
        padding: 2rem;
    }

    .section-title {
        font-family: 'Hayah', sans-serif;
        font-size: 2rem;
        color: var(--c-primary);
        margin: 0 0 2rem 0;
        display: flex;
        align-items: center;
        gap: 1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid rgba(0,0,0,0.05);
    }

        .section-title i {
            color: var(--c-secondary);
        }

    .grid-courses {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 2rem;
    }

    .course-neo-card {
        background: var(--c-bg);
        border-radius: var(--radius-lg);
        padding: 1.5rem;
        border: 1px solid rgba(0,0,0,0.03);
        transition: var(--transition);
        display: flex;
        flex-direction: column;
    }

        .course-neo-card:hover {
            background: var(--c-white);
            box-shadow: var(--shadow-md);
            transform: translateY(-5px);
            border-color: rgba(10,50,84,0.1);
        }

    .c-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1rem;
    }

    .c-status {
        padding: 0.3rem 0.8rem;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

        .c-status.active {
            background: #dcfce7;
            color: #166534;
        }

        .c-status.inactive {
            background: #f1f5f9;
            color: #475569;
        }

        .c-status i {
            font-size: 0.6rem;
        }

    .c-price {
        font-family: Arial, sans-serif;
        font-weight: 900;
        color: var(--c-secondary);
        font-size: 1.2rem;
        background: rgba(175,143,66,0.1);
        padding: 0.3rem 0.8rem;
        border-radius: 8px;
    }

    .c-body h4 {
        font-family: 'Hayah', sans-serif;
        font-size: 1.6rem;
        color: var(--c-primary);
        margin: 0 0 0.5rem 0;
    }

    .c-body p {
        font-size: 0.95rem;
        color: var(--c-text-muted);
        line-height: 1.6;
        margin: 0 0 1.5rem 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        font-weight: 600;
    }

    .c-actions {
        display: flex;
        gap: 0.8rem;
        margin-top: auto;
        border-top: 1px solid rgba(0,0,0,0.05);
        padding-top: 1.5rem;
    }

    .btn-action {
        flex: 1;
        text-align: center;
        padding: 0.8rem;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.9rem;
        transition: var(--transition);
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        border: none;
    }

    .btn-mng {
        background: var(--c-primary-light);
        color: var(--c-white);
    }

        .btn-mng:hover {
            background: var(--c-primary);
            box-shadow: var(--shadow-sm);
        }

    .btn-icon {
        width: 45px;
        flex: none;
        background: #e2e8f0;
        color: #475569;
    }

        .btn-icon:hover {
            background: var(--c-secondary);
            color: var(--c-white);
        }

        .btn-icon.del:hover {
            background: #ef4444;
            color: var(--c-white);
        }

    @@media(max-width: 768px) {
        .dash-banner {
            flex-direction: column;
            text-align: center;
            padding: 2.5rem 1.5rem;
        }

        .welcome-widget::after {
            display: none;
        }
    }
</style>

<div class="dash-banner welcome-widget">
    <div class="dash-text ">
        <h2 style="color:#FFF;">نظرة عامة على <span style="color:#d1b46b;">المنصة</span></h2>
        <p style="color:#FFF;">تابع الإحصائيات، أدر المحتوى، وتحكم في كل شيء بسهولة تامة.</p>
    </div>
    <a href="/Admin/CreateCourse" class="btn-create-course">
        <i class="fa-solid fa-rocket"></i> إطلاق دورة جديدة
    </a>
</div>

<div class="kpi-grid">
    <div class="kpi-card">
        <div class="kpi-icon kpi-blue"><i class="fa-solid fa-user-graduate"></i></div>
        <div class="kpi-info">
            <h3>إجمالي الطلاب</h3>
            <p>@ViewBag.TotalStudentsCount</p>
        </div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon kpi-gold"><i class="fa-solid fa-cubes"></i></div>
        <div class="kpi-info">
            <h3>الدورات المتاحة</h3>
            <p>@ViewBag.TotalCoursesCount</p>
        </div>
    </div>
    <a href="/Admin/SubscriptionRequests" class="kpi-card" style="cursor: pointer; text-decoration:none;">
        <div class="kpi-icon kpi-red"><i class="fa-solid fa-bell"></i></div>
        <div class="kpi-info">
            <h3>طلبات بانتظار التفعيل</h3>
            <p>@ViewBag.PendingRequestsCount</p>
        </div>
        <i class="fa-solid fa-angle-left" style="position:absolute; left:1.5rem; font-size:1.5rem; color:#cbd5e1;"></i>
    </a>
</div>

<div class="section-glass">
    <h3 class="section-title"><i class="fa-solid fa-layer-group"></i> المسارات التعليمية الحالية</h3>

    <div class="grid-courses">
        @if (Model != null && Model.Any())
        {
            foreach (var course in Model)
            {
                <div class="course-neo-card">
                    <div class="c-top">
                        @if (course.IsActive)
                        {
                            <span class="c-status active"><i class="fa-solid fa-circle"></i> مفعل للطلاب</span>
                        }
                        else
                        {
                            <span class="c-status inactive"><i class="fa-solid fa-circle"></i> مسودة (مخفي)</span>
                        }
                        <span class="c-price">@course.Price ر.س</span>
                    </div>
                    <div class="c-body">
                        <h4>@course.Title</h4>
                        <p>@course.Description</p>
                    </div>
                    <div class="c-actions">
                        <a href="/Course/Details/@course.Id" class="btn-action btn-mng"><i class="fa-solid fa-photo-film"></i> إدارة المحتوى</a>
                        <a href="/Admin/EditCourse/@course.Id" class="btn-action btn-icon" title="تعديل"><i class="fa-solid fa-pen-clip"></i></a>
                        <form asp-action="DeleteCourse" asp-route-id="@course.Id" method="post" onsubmit="confirmAction(event, 'هل أنت متأكد من حذف الكورس نهائياً بكافة محتوياته؟');" style="margin:0;">
                            <button type="submit" class="btn-action btn-icon del" title="حذف"><i class="fa-solid fa-trash-can"></i></button>
                        </form>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="grid-column: 1/-1; text-align:center; padding: 4rem 1rem;">
                <i class="fa-solid fa-box-open" style="font-size: 5rem; color:#cbd5e1; margin-bottom: 1.5rem;"></i>
                <h4 style="font-family:'Hayah',sans-serif; font-size: 2rem; color:var(--c-primary); margin:0 0 1rem 0;">المنصة فارغة تماماً</h4>
                <p style="color:var(--c-text-muted); font-size:1.1rem; font-weight:600;">قم ببناء الدورة الأولى وابدأ في إضافة المحاضرات والاختبارات.</p>
            </div>
        }
    </div>
</div>