@model IEnumerable<AlAdeeb.Models.Course>
@{
    ViewData["Title"] = User.IsInRole("Admin") ? "لوحة التحكم الرئيسية" : "لوحة المعلم المساعد";
    Layout = "_AdminLayout";
}

<style>
    .dash-banner {
        background: url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyMCIgaGVpZ2h0PSIyMCI+PHBhdGggZD0iTTAgMGgyMHYyMEgweiIgZmlsbD0iI2FmOGY0MiIgZmlsbC1vcGFjaXR5PSIwLjA1Ii8+PC9zdmc+'), linear-gradient(135deg, var(--c-primary) 0%, var(--c-primary-dark) 100%);
        border-radius: var(--radius-xl);
        padding: 3rem;
        color: var(--c-white);
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: var(--shadow-md);
        margin-bottom: 2.5rem;
        position: relative;
        overflow: hidden;
    }

        .dash-banner::after {
            content: '\f5d2';
            font-family: "Font Awesome 6 Free";
            font-weight: 900;
            position: absolute;
            left: 1rem;
            top: -1rem;
            font-size: 12rem;
            color: rgba(255,255,255,0.03);
            pointer-events: none;
            transform: rotate(-15deg);
        }

    .dash-text h2 {
        font-family: 'Hayah', sans-serif;
        font-size: 2.5rem;
        margin: 0 0 0.5rem 0;
        line-height: 1.2;
    }

    .dash-text span {
        color: var(--c-secondary);
    }

    .dash-text p {
        margin: 0;
        font-size: 1.1rem;
        color: rgba(255,255,255,0.8);
        font-weight: 600;
    }

    .btn-create-course {
        background: var(--c-secondary);
        color: var(--c-primary-dark);
        padding: 1.2rem 2.5rem;
        border-radius: 1.5rem;
        font-size: 1.2rem;
        font-weight: 900;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        box-shadow: var(--shadow-glow);
        transition: var(--transition);
        position: relative;
        z-index: 10;
    }

        .btn-create-course:hover {
            transform: translateY(-3px);
            background: var(--c-secondary-light);
        }

    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        margin-bottom: 3rem;
    }

    .kpi-card {
        background: var(--c-white);
        border-radius: var(--radius-lg);
        padding: 1.5rem 2rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        box-shadow: var(--shadow-sm);
        border: 1px solid rgba(0,0,0,0.04);
        transition: var(--transition);
        position: relative;
        overflow: hidden;
    }

        .kpi-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-md);
            border-color: rgba(175, 143, 66, 0.2);
        }

    .kpi-icon {
        width: 4.5rem;
        height: 4.5rem;
        border-radius: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        flex-shrink: 0;
    }

    .kpi-blue {
        background: #eff6ff;
        color: #3b82f6;
    }

    .kpi-gold {
        background: rgba(175, 143, 66, 0.1);
        color: var(--c-secondary);
    }

    .kpi-red {
        background: #fef2f2;
        color: #ef4444;
    }

    .kpi-info h3 {
        margin: 0 0 0.5rem 0;
        font-size: 1rem;
        color: var(--c-text-muted);
        font-weight: 700;
    }

    .kpi-info p {
        margin: 0;
        font-size: 2.2rem;
        font-family: Arial, sans-serif;
        font-weight: 900;
        color: var(--c-primary);
        line-height: 1;
    }

    .section-title {
        font-family: 'Hayah', sans-serif;
        font-size: 2rem;
        color: var(--c-primary);
        margin: 0 0 1.5rem 0;
        display: flex;
        align-items: center;
        gap: 0.8rem;
    }

        .section-title i {
            color: var(--c-secondary);
            font-size: 1.6rem;
        }

    .courses-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 2rem;
    }

    .course-card {
        background: var(--c-white);
        border-radius: var(--radius-xl);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid rgba(0,0,0,0.05);
        transition: var(--transition);
        display: flex;
        flex-direction: column;
    }

        .course-card:hover {
            transform: translateY(-10px);
            box-shadow: var(--shadow-md);
            border-color: rgba(175, 143, 66, 0.3);
        }

    .c-cover {
        height: 180px;
        background: var(--c-primary);
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

        .c-cover img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.7;
            transition: var(--transition);
        }

    .course-card:hover .c-cover img {
        transform: scale(1.1);
        opacity: 0.9;
    }

    .c-cover i {
        position: absolute;
        font-size: 4rem;
        color: rgba(255,255,255,0.2);
    }

    .status-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        padding: 0.4rem 1rem;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        backdrop-filter: blur(5px);
    }

    .b-active {
        background: rgba(16, 185, 129, 0.9);
        color: #fff;
    }

    .b-inactive {
        background: rgba(239, 68, 68, 0.9);
        color: #fff;
    }

    .c-body {
        padding: 1.5rem;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .c-title {
        font-size: 1.3rem;
        color: var(--c-primary);
        margin: 0 0 1rem 0;
        font-weight: 900;
        line-height: 1.4;
    }

    .c-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
        font-weight: bold;
        color: var(--c-text-muted);
    }

    .c-price {
        font-family: Arial, sans-serif;
        font-size: 1.2rem;
        font-weight: 900;
        color: var(--c-secondary);
    }

    .c-actions {
        display: grid;
        grid-template-columns: 1fr auto auto;
        gap: 0.5rem;
        border-top: 1px solid #e2e8f0;
        padding-top: 1.2rem;
        margin-top: auto;
    }

    .btn-act {
        padding: 0.8rem;
        border-radius: 0.8rem;
        font-weight: 800;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        text-decoration: none;
        transition: var(--transition);
        border: none;
        cursor: pointer;
    }

    .btn-manage {
        background: var(--c-primary);
        color: var(--c-secondary);
        grid-column: 1;
    }

        .btn-manage:hover {
            background: var(--c-secondary);
            color: var(--c-primary);
        }

    .btn-icon {
        width: 42px;
        padding: 0;
    }

        .btn-icon.edit {
            background: #eff6ff;
            color: #3b82f6;
        }

            .btn-icon.edit:hover {
                background: #3b82f6;
                color: var(--c-white);
            }

        .btn-icon.del {
            background: #fef2f2;
            color: #ef4444;
            height: 100%;
        }

            .btn-icon.del:hover {
                background: #ef4444;
                color: var(--c-white);
            }

    @@media(max-width: 768px) {
        .dash-banner {
            flex-direction: column;
            text-align: center;
            padding: 2.5rem 1.5rem;
        }
    }
</style>

<div class="dash-banner welcome-widget">
    <div class="dash-text">
        <h2>نظرة عامة على <span>المنصة</span></h2>
        <p>@(User.IsInRole("Admin") ? "تابع الإحصائيات، أدر المحتوى، وتحكم في كل شيء بسهولة تامة." : "مرحباً بك، أدر الكورسات المسندة إليك وتابع أسئلة الطلاب.")</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a href="/Admin/CreateCourse" class="btn-create-course">
            <i class="fa-solid fa-rocket"></i> إطلاق دورة جديدة
        </a>
    }
</div>

@if (User.IsInRole("Admin"))
{
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-icon kpi-blue"><i class="fa-solid fa-user-graduate"></i></div>
            <div class="kpi-info">
                <h3>إجمالي الطلاب</h3>
                <p>@ViewBag.TotalStudentsCount</p>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon kpi-gold"><i class="fa-solid fa-cubes"></i></div>
            <div class="kpi-info">
                <h3>الدورات المتاحة</h3>
                <p>@ViewBag.TotalCoursesCount</p>
            </div>
        </div>
        <a href="/Admin/SubscriptionRequests" class="kpi-card" style="cursor: pointer; text-decoration:none;">
            <div class="kpi-icon kpi-red"><i class="fa-solid fa-bell"></i></div>
            <div class="kpi-info">
                <h3>طلبات بانتظار التفعيل</h3>
                <p>@ViewBag.PendingRequestsCount</p>
            </div>
            <i class="fa-solid fa-angle-left" style="position:absolute; left:1.5rem; font-size:1.5rem; color:#cbd5e1;"></i>
        </a>
    </div>
}

<div class="section-glass">
    <h3 class="section-title"><i class="fa-solid fa-layer-group"></i> المسارات التعليمية الحالية</h3>

    @if (Model != null && Model.Any())
    {
        <div class="courses-grid">
            @foreach (var course in Model)
            {
                <div class="course-card">
                    <div class="c-cover">
                        @if (!string.IsNullOrEmpty(course.ImageUrl))
                        {
                            <img src="@course.ImageUrl" alt="@course.Title" />
                        }
                        else
                        {

                            <i class="fa-solid fa-graduation-cap"></i>
                        }

                        @if (course.IsActive)
                        {
                            <div class="status-badge b-active"><i class="fa-solid fa-check"></i> مفعل للطلاب</div>
                        }
                        else
                        {

                            <div class="status-badge b-inactive"><i class="fa-solid fa-eye-slash"></i> مسودة (مخفي)</div>
                        }
                    </div>
                    <div class="c-body">
                        <h4 class="c-title">@course.Title</h4>
                        <div class="c-meta">
                            <span><i class="fa-solid fa-chalkboard-user"></i> المدرب: @(string.IsNullOrEmpty(course.TrainerName) ? "غير محدد" : course.TrainerName)</span>
                            <span class="c-price">@course.Price ريال</span>
                        </div>

                        <div class="c-actions">
                            <a href="/Course/Details/@course.Id" class="btn-act btn-manage"><i class="fa-solid fa-folder-open"></i> إدارة المحتوى</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a href="/Admin/EditCourse/@course.Id" class="btn-act btn-icon edit" title="تعديل الإعدادات"><i class="fa-solid fa-pen"></i></a>
                                <form asp-action="DeleteCourse" method="post" style="margin:0;" onsubmit="confirmAction(event, 'هل أنت متأكد من حذف هذه الدورة نهائياً بكل محتوياتها؟');">
                                    <input type="hidden" name="id" value="@course.Id" />
                                    <button type="submit" class="btn-act btn-icon del" title="حذف الدورة"><i class="fa-solid fa-trash-can"></i></button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div style="background:var(--c-white); border-radius:var(--radius-xl); padding: 5rem 2rem; text-align:center; box-shadow:var(--shadow-sm); border:1px solid rgba(0,0,0,0.05);">
            <i class="fa-solid fa-box-open" style="font-size: 5rem; color: #cbd5e1; margin-bottom: 1.5rem;"></i>
            <h3 style="font-family:'Hayah',sans-serif; font-size: 2rem; color:var(--c-primary); margin:0 0 0.5rem 0;">لا توجد دورات حالياً</h3>
            <p style="color:var(--c-text-muted); font-size: 1.1rem; font-weight:600;">@(User.IsInRole("Admin") ? "ابدأ بإنشاء أول دورة تعليمية لك من الزر بالأعلى." : "لم تقم الإدارة بتعيينك كمعلم لأي دورة حتى الآن.")</p>
        </div>
    }
</div>