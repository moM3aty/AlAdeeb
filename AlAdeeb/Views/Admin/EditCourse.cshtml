@model AlAdeeb.Models.Course
@{
    ViewData["Title"] = "تحديث بيانات الدورة";
    Layout = "_AdminLayout";
}

<style>
    .page-header {
        background: var(--c-white);
        border-radius: var(--radius-xl);
        padding: 2rem 2.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        box-shadow: var(--shadow-sm);
        border: 1px solid rgba(0,0,0,0.04);
        margin-bottom: 2rem;
    }

    @@media(min-width: 768px) {
        .page-header {
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
        }
    }

    .header-info {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .header-icon {
        width: 4.5rem;
        height: 4.5rem;
        background: rgba(10,50,84,0.05);
        color: var(--c-primary);
        border-radius: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
    }

    .header-text h2 {
        font-family: 'Hayah', sans-serif;
        font-size: 2.2rem;
        color: var(--c-primary);
        margin: 0;
        line-height: 1.2;
    }

    .header-text p {
        margin: 0;
        color: var(--c-text-muted);
        font-weight: 600;
        font-size: 0.95rem;
    }

    .form-card {
        background: var(--c-white);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-sm);
        border: 1px solid rgba(0,0,0,0.04);
        padding: 3rem;
        max-width: 1000px;
        margin: 0 auto;
    }

    .form-group {
        margin-bottom: 2rem;
    }

    .form-label {
        display: block;
        font-weight: 800;
        color: var(--c-primary);
        margin-bottom: 0.8rem;
        font-size: 1.1rem;
    }

        .form-label span {
            color: #ef4444;
        }

    .form-control {
        width: 100%;
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 1rem;
        padding: 1.2rem;
        font-family: inherit;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--c-primary);
        transition: var(--transition);
    }

        .form-control:focus {
            outline: none;
            background: var(--c-white);
            border-color: var(--c-secondary);
            box-shadow: 0 0 0 4px rgba(175, 143, 66, 0.1);
        }

    .grid-2 {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    @@media(min-width: 768px) {
        .grid-2 {
            grid-template-columns: 1fr 1fr;
        }
    }

    .price-wrapper {
        position: relative;
    }

    .price-icon {
        position: absolute;
        left: 1.5rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.3rem;
        color: #10b981;
    }

    .price-input {
        padding-left: 3.5rem;
        font-family: Arial, sans-serif;
        font-size: 1.4rem;
        font-weight: 900;
    }

    .toggle-box {
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 1rem;
        padding: 1.2rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        cursor: pointer;
        transition: var(--transition);
        height: 100%;
    }

        .toggle-box:hover {
            border-color: var(--c-secondary);
        }

        .toggle-box input {
            width: 1.5rem;
            height: 1.5rem;
            accent-color: var(--c-secondary);
            cursor: pointer;
        }

    .toggle-text h4 {
        margin: 0 0 0.3rem 0;
        font-size: 1.1rem;
        color: var(--c-primary);
        font-weight: 800;
    }

    .toggle-text p {
        margin: 0;
        font-size: 0.9rem;
        color: var(--c-text-muted);
        font-weight: 600;
    }

    .form-actions {
        display: flex;
        gap: 1.5rem;
        margin-top: 3rem;
        border-top: 1px solid #e2e8f0;
        padding-top: 2.5rem;
    }

    .btn-save {
        flex: 2;
        background: var(--c-primary);
        color: var(--c-secondary);
        border: none;
        padding: 1.2rem;
        border-radius: 1rem;
        font-size: 1.3rem;
        font-weight: 800;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        transition: var(--transition);
        box-shadow: var(--shadow-md);
    }

        .btn-save:hover {
            background: var(--c-secondary);
            color: var(--c-primary);
            transform: translateY(-3px);
        }

    .btn-cancel {
        flex: 1;
        background: #f1f5f9;
        color: #64748b;
        text-align: center;
        padding: 1.2rem;
        border-radius: 1rem;
        font-size: 1.2rem;
        font-weight: 800;
        transition: var(--transition);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .btn-cancel:hover {
            background: #e2e8f0;
            color: var(--c-primary);
        }

    .val-error {
        color: #ef4444;
        font-size: 0.9rem;
        font-weight: 700;
        display: block;
        margin-top: 0.5rem;
    }
</style>

<div class="page-header">
    <div class="header-info">
        <div class="header-icon"><i class="fa-solid fa-pen-clip"></i></div>
        <div class="header-text">
            <h2>تحديث بيانات الدورة</h2>
            <p>تعديل مسار الدورة، التكلفة، أو تعيين معلم مساعد لإدارتها.</p>
        </div>
    </div>
</div>

<div class="form-card">
    <form asp-controller="Admin" asp-action="EditCourse" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImageUrl" />

        <div class="form-group">
            <label asp-for="Title" class="form-label">عنوان الدورة <span>*</span></label>
            <input asp-for="Title" required class="form-control" />
            <span asp-validation-for="Title" class="val-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Description" class="form-label">النبذة الوصفية <span>*</span></label>
            <textarea asp-for="Description" rows="4" required class="form-control"></textarea>
            <span asp-validation-for="Description" class="val-error"></span>
        </div>

        <div class="grid-2">
            <div class="form-group" style="margin: 0;">
                <label asp-for="Price" class="form-label">تكلفة الاشتراك (ريال) <span>*</span></label>
                <div class="price-wrapper">
                    <input asp-for="Price" type="number" step="0.01" required class="form-control price-input" />
                    <i class="fa-solid fa-money-bill-wave price-icon"></i>
                </div>
                <span asp-validation-for="Price" class="val-error"></span>
            </div>

            <div class="form-group" style="margin: 0;">
                <label asp-for="OldPrice" class="form-label">السعر القديم (لعمل خصم - اختياري)</label>
                <div class="price-wrapper">
                    <input asp-for="OldPrice" type="number" step="0.01" class="form-control price-input" style="color: #ef4444;" />
                    <i class="fa-solid fa-tag price-icon" style="color: #ef4444;"></i>
                </div>
            </div>

            <div class="form-group" style="margin: 0;">
                <label asp-for="AccessDurationMonths" class="form-label">صلاحية الدورة (بالشهور)</label>
                <input asp-for="AccessDurationMonths" type="number" class="form-control" placeholder="اتركه فارغاً لصلاحية مفتوحة..." />
            </div>

            <div class="form-group" style="margin: 0;">
                <label asp-for="TeacherId" class="form-label">تعيين معلم مساعد (اختياري)</label>
                <select asp-for="TeacherId" class="form-control" style="cursor: pointer;">
                    <option value="">-- بدون معلم (إدارة شخصية) --</option>
                    @if (ViewBag.Teachers != null)
                    {
                        foreach (var teacher in ViewBag.Teachers)
                        {
                            <option value="@teacher.Id">@teacher.FullName</option>
                        }
                    }
                </select>
            </div>

            <!-- بيانات المدرب -->
            <div class="form-group" style="margin: 0; grid-column: 1 / -1; background:#f8fafc; padding:2rem; border-radius:1rem; border:1px dashed #cbd5e1;">
                <h4 style="margin-top:0; color:var(--c-primary); font-family:'Hayah'; font-size:1.5rem;"><i class="fa-solid fa-chalkboard-user"></i> بيانات المدرب (للتسويق)</h4>
                <div class="grid-2" style="margin-top:1rem;">
                    <div style="margin:0;">
                        <label asp-for="TrainerName" class="form-label">اسم المدرب المعتمد للمادة</label>
                        <input asp-for="TrainerName" class="form-control" placeholder="مثال: أ. صلاح عبد العال" style="background:#fff;" />
                    </div>
                    <div style="margin:0;">
                        <label asp-for="TrainerBio" class="form-label">نبذة قصيرة عن المدرب</label>
                        <input asp-for="TrainerBio" class="form-control" placeholder="مثال: خبير في تدريب القدرات..." style="background:#fff;" />
                    </div>
                </div>
            </div>

            <div class="form-group" style="margin: 0; grid-column: 1 / -1;">
                <label class="form-label" style="visibility: hidden; display:none;">التفعيل</label>
                <label class="toggle-box">
                    <input asp-for="IsActive" type="checkbox" />
                    <div class="toggle-text">
                        <h4>الدورة مفعلة ونشطة</h4>
                        <p>إذا تم الإلغاء، لن تظهر للطلاب في المتجر.</p>
                    </div>
                </label>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-save"><i class="fa-solid fa-floppy-disk"></i> حفظ التحديثات</button>
            <a href="/Admin/Index" class="btn-cancel">إلغاء وتراجع</a>
        </div>
    </form>
</div>