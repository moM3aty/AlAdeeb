@model IEnumerable<AlAdeeb.Models.ApplicationUser>
@{
    ViewData["Title"] = "مجتمع الطلاب";
    Layout = "_AdminLayout";
}

<div class="max-w-7xl mx-auto space-y-8 animate-fade-in pb-20">

    <!-- هيدر الصفحة والبحث -->
    <div class="bg-white border border-slate-200 p-8 rounded-[2rem] shadow-sm flex flex-col lg:flex-row justify-between items-center gap-8 relative overflow-hidden">
        <div class="absolute -left-20 -top-20 w-64 h-64 bg-primary/5 rounded-full blur-3xl pointer-events-none"></div>

        <div class="flex items-center gap-5 relative z-10 w-full lg:w-auto">
            <div class="w-16 h-16 bg-gradient-to-br from-indigo-50 to-blue-50 text-primary rounded-2xl flex items-center justify-center text-3xl shadow-inner shrink-0 border border-white">
                <i class="fa-solid fa-user-graduate"></i>
            </div>
            <div>
                <h2 class="text-2xl md:text-3xl font-black text-slate-900 mb-1 tracking-tight">إدارة المتدربين</h2>
                <p class="text-slate-500 font-medium text-sm">متابعة حسابات الطلاب، التواصل السريع، والتحكم بالبيانات.</p>
            </div>
        </div>

        <!-- شريط البحث (مظهر عصري، يحتاج ربط بالباك إند لاحقاً للفلترة) -->
        <div class="w-full lg:w-96 relative z-10">
            <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none">
                <i class="fa-solid fa-magnifying-glass text-slate-400"></i>
            </div>
            <input type="text" class="w-full pl-4 pr-12 py-3.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all font-medium text-sm" placeholder="ابحث بالاسم أو رقم الجوال..." />
        </div>
    </div>

    <!-- جدول البيانات -->
    <div class="bg-white rounded-[2rem] shadow-sm border border-slate-200 overflow-hidden">

        <!-- شريط معلومات الجدول -->
        <div class="bg-slate-50/50 border-b border-slate-100 px-6 py-4 flex justify-between items-center">
            <span class="text-sm font-black text-slate-600 flex items-center gap-2">
                <i class="fa-solid fa-list-ul text-slate-400"></i> قائمة الطلاب
            </span>
            <span class="bg-primary/10 text-primary text-xs font-black px-3 py-1 rounded-full border border-primary/20">
                إجمالي: @(Model?.Count() ?? 0)
            </span>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-right border-collapse">
                    <thead class="bg-white border-b border-slate-100">
                        <tr>
                            <th class="px-6 py-4 font-black text-xs text-slate-400 uppercase tracking-widest w-1/3">بيانات الطالب</th>
                            <th class="px-6 py-4 font-black text-xs text-slate-400 uppercase tracking-widest text-center">رقم التواصل</th>
                            <th class="px-6 py-4 font-black text-xs text-slate-400 uppercase tracking-widest text-center">تاريخ التسجيل</th>
                            <th class="px-6 py-4 font-black text-xs text-slate-400 uppercase tracking-widest text-center">إجراءات</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        @foreach (var student in Model)
                        {
                            <tr class="hover:bg-slate-50/80 transition-colors group">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-4">
                                        <!-- الصورة الرمزية بتصميم عصري -->
                                        <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-slate-100 to-slate-200 text-slate-600 flex items-center justify-center font-black text-lg shadow-inner border border-white shrink-0 group-hover:from-primary group-hover:to-indigo-600 group-hover:text-white transition-all">
                                            @student.FullName.Substring(0, 1)
                                        </div>
                                        <div>
                                            <span class="font-bold text-slate-900 text-base block leading-none mb-1">@student.FullName</span>
                                            <span class="text-[11px] font-bold text-slate-400 bg-slate-100 px-2 py-0.5 rounded-md">عضو نشط</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="text-slate-600 font-mono font-bold bg-slate-50 border border-slate-100 px-3 py-1.5 rounded-lg text-sm" dir="ltr">@student.PhoneNumber</span>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="text-slate-500 text-sm font-medium flex items-center justify-center gap-1.5">
                                        <i class="fa-regular fa-calendar text-slate-400"></i> @student.CreatedAt.ToString("yyyy/MM/dd")
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <div class="flex justify-center gap-2 opacity-100 lg:opacity-0 group-hover:opacity-100 transition-opacity">
                                        <a href="https://wa.me/@student.PhoneNumber" target="_blank" class="w-9 h-9 flex items-center justify-center bg-emerald-50 text-emerald-600 rounded-lg hover:bg-emerald-500 hover:text-white transition-colors border border-emerald-100" title="مراسلة واتساب">
                                            <i class="fa-brands fa-whatsapp text-lg"></i>
                                        </a>
                                        <form asp-action="DeleteStudent" asp-route-id="@student.Id" method="post" onsubmit="return confirm('حذف الطالب سيلغي جميع اشتراكاته وبياناته، هل أنت متأكد من الحذف النهائي؟');">
                                            <button type="submit" class="w-9 h-9 flex items-center justify-center bg-rose-50 text-rose-500 rounded-lg hover:bg-rose-500 hover:text-white transition-colors border border-rose-100" title="إزالة من المنصة">
                                                <i class="fa-solid fa-user-xmark"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-20 px-4">
                <div class="w-24 h-24 bg-slate-50 rounded-[2rem] flex items-center justify-center mx-auto mb-5 border border-dashed border-slate-200">
                    <i class="fa-solid fa-users-slash text-4xl text-slate-300"></i>
                </div>
                <h4 class="text-xl font-black text-slate-800 mb-2">لا يوجد متدربين بعد</h4>
                <p class="text-slate-500 font-medium text-sm">بمجرد تسجيل الطلاب وإنشاء حساباتهم، سيظهرون في هذه القائمة.</p>
            </div>
        }
    </div>
</div>