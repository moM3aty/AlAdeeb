@model IEnumerable<AlAdeeb.Models.ApplicationUser>
@{
    ViewData["Title"] = "قاعدة بيانات الطلاب";
    Layout = "_AdminLayout";
}

<style>
    .page-header {
        background: var(--c-white);
        border-radius: var(--radius-xl);
        padding: 2rem 2.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        box-shadow: var(--shadow-sm);
        border: 1px solid rgba(0,0,0,0.04);
        margin-bottom: 2rem;
    }

    @@media(min-width: 768px) {
        .page-header {
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
        }
    }

    .header-info {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .header-icon {
        width: 4.5rem;
        height: 4.5rem;
        background: rgba(10,50,84,0.05);
        color: var(--c-primary);
        border-radius: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
    }

    .header-text h2 {
        font-family: 'Hayah', sans-serif;
        font-size: 2.2rem;
        color: var(--c-primary);
        margin: 0;
        line-height: 1.2;
    }

    .header-text p {
        margin: 0;
        color: var(--c-text-muted);
        font-weight: 600;
        font-size: 0.95rem;
    }

    .search-box {
        position: relative;
        width: 100%;
        max-width: 400px;
    }

        .search-box i {
            position: absolute;
            right: 1.2rem;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
        }

        .search-box input {
            width: 100%;
            background: #f8fafc;
            border: 2px solid #e2e8f0;
            border-radius: 1rem;
            padding: 0.8rem 1rem 0.8rem 2.5rem;
            font-family: inherit;
            font-weight: 600;
            color: var(--c-primary);
            transition: var(--transition);
        }

            .search-box input:focus {
                border-color: var(--c-secondary);
                outline: none;
                background: var(--c-white);
                box-shadow: 0 0 0 4px rgba(175, 143, 66, 0.1);
            }

    .data-card {
        background: var(--c-white);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-sm);
        border: 1px solid rgba(0,0,0,0.04);
        overflow: hidden;
    }

    .table-container {
        overflow-x: auto;
    }

    .modern-table {
        width: 100%;
        border-collapse: collapse;
        text-align: right;
    }

        .modern-table th {
            background: #f8fafc;
            padding: 1.2rem 1.5rem;
            font-size: 0.85rem;
            color: var(--c-text-muted);
            text-transform: uppercase;
            font-weight: 800;
            border-bottom: 2px solid #e2e8f0;
            white-space: nowrap;
        }

        .modern-table td {
            padding: 1.2rem 1.5rem;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
            transition: var(--transition);
        }

        .modern-table tr:hover td {
            background: rgba(10,50,84,0.02);
        }

        .modern-table tr:last-child td {
            border-bottom: none;
        }

    .student-cell {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .s-avatar {
        width: 45px;
        height: 45px;
        background: linear-gradient(135deg, var(--c-primary), var(--c-primary-light));
        color: var(--c-white);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        font-weight: 900;
        font-family: 'Hayah', sans-serif;
        box-shadow: var(--shadow-sm);
    }

    .s-name {
        font-weight: 700;
        color: var(--c-primary);
        display: block;
        font-size: 1rem;
        margin-bottom: 0.2rem;
    }

    .s-badge {
        font-size: 0.7rem;
        background: #e0f2fe;
        color: #0284c7;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        font-weight: 800;
    }

    .phone-tag {
        font-family: Arial, sans-serif;
        font-weight: 800;
        color: #475569;
        background: #f1f5f9;
        padding: 0.4rem 0.8rem;
        border-radius: 8px;
        direction: ltr;
        display: inline-block;
    }

    .date-tag {
        font-size: 0.9rem;
        color: #64748b;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .action-btns {
        display: flex;
        gap: 0.5rem;
    }

    .btn-act {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        cursor: pointer;
        transition: var(--transition);
        font-size: 1.1rem;
        text-decoration: none;
    }

    .btn-view {
        background: #eff6ff;
        color: #3b82f6;
    }

        .btn-view:hover {
            background: #3b82f6;
            color: #fff;
        }

    .btn-wa {
        background: #dcfce7;
        color: #16a34a;
    }

        .btn-wa:hover {
            background: #16a34a;
            color: #fff;
        }

    .btn-del {
        background: #fee2e2;
        color: #dc2626;
    }

        .btn-del:hover {
            background: #dc2626;
            color: #fff;
        }
</style>

<div class="page-header">
    <div class="header-info">
        <div class="header-icon"><i class="fa-solid fa-users-viewfinder"></i></div>
        <div class="header-text">
            <h2>شؤون الطلاب</h2>
            <p>إدارة بيانات المتدربين، وسائل التواصل، وسجل الانضمام.</p>
        </div>
    </div>
    <div class="search-box">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" placeholder="بحث باسم الطالب أو رقم الجوال..." />
    </div>
</div>

<div class="data-card">
    @if (Model != null && Model.Any())
    {
        <div class="table-container">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th>الاسم والبيانات</th>
                        <th>رقم الجوال (واتساب)</th>
                        <th>عدد الأجهزه</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in Model)
                    {
                        <tr>
                            <td>
                                <div class="student-cell">
                                    <div class="s-avatar">@student.FullName.Substring(0, 1)</div>
                                    <div>
                                        <span class="s-name">@student.FullName</span>
                                        <span class="s-badge">عضو بالمنصة</span>
                                    </div>
                                </div>
                            </td>
                            <td><span class="phone-tag">@student.PhoneNumber</span></td>

                            <!-- عمود الأجهزة المضافة حديثاً -->
                            <td>
                                <form asp-action="UpdateDeviceLimit" method="post" style="display:inline-flex; gap:0.5rem; align-items:center; margin:0;">
                                    <input type="hidden" name="studentId" value="@student.Id" />
                                    <input type="number" name="newLimit" value="@student.AllowedDevicesCount" min="1" max="5" style="width:60px; padding:0.4rem; border:1px solid #cbd5e1; border-radius:8px; text-align:center; font-weight:bold; font-family:Arial;" />
                                    <button type="submit" class="btn-act btn-wa" title="حفظ حد الأجهزة" style="width:30px; height:30px;"><i class="fa-solid fa-save"></i></button>
                                </form>
                            </td>

                            <td>
                                <div class="action-btns">
                                    <a href="/Admin/StudentProfile/@student.Id" class="btn-act btn-view" title="الملف الشامل للطالب"><i class="fa-solid fa-address-card"></i></a>
                                    <a href="https://wa.me/@student.PhoneNumber" target="_blank" class="btn-act btn-wa" title="مراسلة عبر واتساب"><i class="fa-brands fa-whatsapp"></i></a>
                                    <form asp-action="DeleteStudent" asp-route-id="@student.Id" method="post" onsubmit="confirmAction(event, 'إزالة الطالب نهائياً من قاعدة البيانات سيحذف جميع سجلاته وإجاباته؟');" style="margin:0;">
                                        <button type="submit" class="btn-act btn-del" title="إزالة الحساب"><i class="fa-solid fa-user-xmark"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div style="text-align:center; padding: 5rem 2rem;">
            <i class="fa-solid fa-folder-open" style="font-size: 4rem; color:#cbd5e1; margin-bottom: 1rem;"></i>
            <h3 style="font-family:'Hayah',sans-serif; color:var(--c-primary); font-size:1.8rem;">لا يوجد طلاب حالياً</h3>
            <p style="color:#64748b; font-weight:600;">لم يقم أي طالب بإنشاء حساب على المنصة بعد.</p>
        </div>
    }
</div>