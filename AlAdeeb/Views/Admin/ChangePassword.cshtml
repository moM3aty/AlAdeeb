@{
    ViewData["Title"] = "تغيير كلمة المرور";
    Layout = "_AdminLayout";
}

<style>
    .pass-card {
        background: var(--c-white);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-sm);
        padding: 3rem;
        max-width: 600px;
        margin: 0 auto;
        border: 1px solid rgba(0,0,0,0.04);
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        display: block;
        font-weight: 800;
        color: var(--c-primary);
        margin-bottom: 0.5rem;
    }

    .form-control {
        width: 100%;
        padding: 1rem 1.2rem;
        border-radius: 1rem;
        border: 2px solid #e2e8f0;
        font-family: Arial, sans-serif;
        font-size: 1.2rem;
        font-weight: bold;
        background: #f8fafc;
        transition: 0.3s;
        direction: ltr;
        text-align: right;
        letter-spacing: 2px;
    }

        .form-control:focus {
            border-color: var(--c-secondary);
            background: #fff;
            outline: none;
        }

    .btn-save {
        width: 100%;
        background: var(--c-primary);
        color: var(--c-secondary);
        padding: 1.2rem;
        border-radius: 1rem;
        font-size: 1.3rem;
        font-weight: 900;
        border: none;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.8rem;
        margin-top: 1rem;
    }

        .btn-save:hover {
            background: var(--c-secondary);
            color: var(--c-primary);
            transform: translateY(-3px);
        }
</style>

<div class="pass-card">
    <div style="text-align:center; margin-bottom:2rem;">
        <i class="fa-solid fa-shield-halved" style="font-size:4rem; color:var(--c-secondary); margin-bottom:1rem;"></i>
        <h2 style="font-family:'Hayah'; color:var(--c-primary); font-size:2rem; margin:0;">تأمين الحساب</h2>
        <p style="color:#64748b; font-weight:bold;">يرجى اختيار كلمة مرور قوية للحفاظ على أمان المنصة.</p>
    </div>

    <form asp-action="ChangePassword" method="post">
        <div class="form-group">
            <label class="form-label">كلمة المرور الحالية</label>
            <input type="password" name="currentPassword" required class="form-control" placeholder="••••••••" />
        </div>

        <div class="form-group">
            <label class="form-label">كلمة المرور الجديدة</label>
            <input type="password" name="newPassword" required class="form-control" placeholder="••••••••" />
        </div>

        <button type="submit" class="btn-save"><i class="fa-solid fa-check"></i> حفظ كلمة المرور</button>
    </form>
</div>