@model IEnumerable<AlAdeeb.Models.SubscriptionRequest>
@{
    ViewData["Title"] = "إدارة الاشتراكات";
    Layout = "_AdminLayout";
}

<style>
    .page-header {
        background: url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyMCIgaGVpZ2h0PSIyMCI+PHBhdGggZD0iTTAgMGgyMHYyMEgweiIgZmlsbD0iI2FmOGY0MiIgZmlsbC1vcGFjaXR5PSIwLjA1Ii8+PC9zdmc+'), var(--c-white);
        border-radius: var(--radius-xl);
        padding: 2.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        box-shadow: var(--shadow-sm);
        border: 1px solid rgba(175,143,66,0.2);
        margin-bottom: 2.5rem;
        border-right: 8px solid var(--c-secondary);
    }

    @@media(min-width: 768px) {
        .page-header {
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
        }
    }

    .header-info {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .header-icon {
        width: 5rem;
        height: 5rem;
        background: rgba(175,143,66,0.1);
        color: var(--c-secondary);
        border-radius: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
    }

    .header-text h2 {
        font-family: 'Hayah', sans-serif;
        font-size: 2.2rem;
        color: var(--c-primary);
        margin: 0 0 0.3rem 0;
        line-height: 1.2;
    }

    .header-text p {
        margin: 0;
        color: var(--c-text-muted);
        font-weight: 700;
        font-size: 1rem;
    }

    .pending-alert {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
        padding: 0.8rem 1.5rem;
        border-radius: 50px;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 0.8rem;
        font-size: 1.1rem;
    }

        .pending-alert i {
            animation: pulse 1.5s infinite;
        }

    .requests-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 2rem;
    }

    .req-card {
        background: var(--c-white);
        border-radius: var(--radius-lg);
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: var(--transition);
    }

        .req-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-md);
            border-color: rgba(175,143,66,0.2);
        }

    .r-head {
        background: #f8fafc;
        padding: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        border-bottom: 1px solid #e2e8f0;
    }

    .r-avatar {
        width: 3.5rem;
        height: 3.5rem;
        background: var(--c-primary);
        color: var(--c-secondary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-family: 'Hayah', sans-serif;
        font-weight: 900;
    }

    .r-info h4 {
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--c-primary);
        margin: 0 0 0.2rem 0;
    }

    .r-info p {
        font-size: 0.85rem;
        color: var(--c-text-muted);
        font-family: Arial, sans-serif;
        font-weight: 700;
        margin: 0;
        direction: ltr;
        text-align: right;
    }

    .status-badge {
        padding: 0.4rem 0.8rem;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: bold;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        white-space: nowrap;
    }

    .r-body {
        padding: 1.5rem;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .course-pill {
        background: rgba(10,50,84,0.03);
        border: 1px solid rgba(10,50,84,0.08);
        padding: 0.8rem;
        border-radius: 10px;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

        .course-pill small {
            font-size: 0.75rem;
            color: #94a3b8;
            font-weight: 800;
            text-transform: uppercase;
        }

        .course-pill strong {
            font-size: 1rem;
            color: var(--c-primary);
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

    .date-pill {
        display: flex;
        justify-content: space-between;
        font-size: 0.85rem;
        font-weight: 700;
        color: #64748b;
    }

        .date-pill span:last-child {
            font-family: Arial, sans-serif;
        }

    .btn-receipt {
        background: #f1f5f9;
        color: var(--c-primary);
        padding: 1rem;
        border-radius: 10px;
        text-align: center;
        font-weight: 800;
        border: 1px solid #e2e8f0;
        transition: var(--transition);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

        .btn-receipt:hover {
            background: var(--c-secondary);
            color: var(--c-white);
            border-color: var(--c-secondary);
        }

    .r-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        padding: 1.5rem;
        border-top: 1px dashed #e2e8f0;
        background: #fdfdfd;
    }

    .btn-do {
        border: none;
        padding: 1rem;
        border-radius: 10px;
        font-family: inherit;
        font-weight: 800;
        font-size: 1rem;
        cursor: pointer;
        transition: var(--transition);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        width: 100%;
    }

    .btn-approve {
        background: #16a34a;
        color: #fff;
        box-shadow: 0 4px 10px rgba(22,163,74,0.2);
    }

        .btn-approve:hover {
            background: #15803d;
            transform: translateY(-2px);
        }

    .btn-reject {
        background: #fff;
        color: #dc2626;
        border: 1px solid #fecaca;
    }

        .btn-reject:hover {
            background: #fef2f2;
        }
</style>

<div class="page-header">
    <div class="header-info">
        <div class="header-icon"><i class="fa-solid fa-file-invoice-dollar"></i></div>
        <div class="header-text">
            <h2>إدارة الاشتراكات والتحويلات</h2>
            <p>تفعيل، رفض، أو إيقاف وصول الطلاب للدورات بسهولة.</p>
        </div>
    </div>
    @if (ViewBag.PendingCount != null && ViewBag.PendingCount > 0)
    {
        <div class="pending-alert">
            <i class="fa-solid fa-circle-exclamation"></i> لديك @ViewBag.PendingCount طلبات جديدة قيد المراجعة
        </div>
    }
</div>

@if (Model != null && Model.Any())
{
    <div class="requests-grid">
        @foreach (var req in Model)
        {
            <div class="req-card">
                <div class="r-head">
                    <div class="r-avatar">@req.Student.FullName.Substring(0, 1)</div>
                    <div class="r-info">
                        <h4>@req.Student.FullName</h4>
                        <p>@req.Student.PhoneNumber</p>
                    </div>
                    <div style="margin-right:auto;">
                        @if (req.Status == "Approved")
                        {
                            <span class="status-badge" style="background:#dcfce7; color:#166534;"><i class="fa-solid fa-circle-check"></i> مفعل</span>
                        }
                        else if (req.Status == "Rejected")
                        {
                            <span class="status-badge" style="background:#fee2e2; color:#dc2626;"><i class="fa-solid fa-circle-xmark"></i> موقوف / مرفوض</span>
                        }
                        else
                        {
                            <span class="status-badge" style="background:#fef9c3; color:#d97706;"><i class="fa-solid fa-clock"></i> مراجعة</span>
                        }
                    </div>
                </div>
                <div class="r-body">
                    <div class="course-pill">
                        <small>دورة الاشتراك</small>
                        <strong><i class="fa-solid fa-graduation-cap" style="color:var(--c-secondary);"></i> @req.Course.Title</strong>
                    </div>
                    <div class="date-pill">
                        <span>تاريخ الطلب:</span>
                        <span>@req.RequestDate.ToString("yyyy-MM-dd HH:mm")</span>
                    </div>
                    @if (!string.IsNullOrEmpty(req.ReceiptImagePath))
                    {
                        <a href="@req.ReceiptImagePath" target="_blank" class="btn-receipt">
                            <i class="fa-solid fa-image"></i> استعراض إيصال التحويل
                        </a>
                    }
                    else
                    {
                        <div style="text-align:center; color:#dc2626; background:#fef2f2; padding:0.8rem; border-radius:10px; font-weight:bold; font-size:0.9rem;">
                            <i class="fa-solid fa-triangle-exclamation"></i> الطالب لم يرفق صورة الإيصال
                        </div>
                    }
                </div>
                <div class="r-actions" style="@(req.Status != "Pending" ? "grid-template-columns: 1fr;" : "")">
                    @if (req.Status == "Pending")
                    {
                        <form asp-action="UpdateSubscriptionStatus" method="post" style="margin:0;" onsubmit="confirmAction(event, 'هل أنت متأكد من تفعيل حساب الطالب؟', 'نعم، تفعيل', '#16a34a')">
                            <input type="hidden" name="requestId" value="@req.Id" />
                            <input type="hidden" name="status" value="Approved" />
                            <button type="submit" class="btn-do btn-approve"><i class="fa-solid fa-check-double"></i> تفعيل החساب</button>
                        </form>
                        <form asp-action="UpdateSubscriptionStatus" method="post" style="margin:0;" onsubmit="confirmAction(event, 'هل أنت متأكد من رفض الطلب؟ لن يتمكن الطالب من الدخول للكورس.', 'نعم، رفض', '#dc2626')">
                            <input type="hidden" name="requestId" value="@req.Id" />
                            <input type="hidden" name="status" value="Rejected" />
                            <button type="submit" class="btn-do btn-reject"><i class="fa-solid fa-xmark"></i> رفض</button>
                        </form>
                    }
                    else if (req.Status == "Approved")
                    {
                        <form asp-action="UpdateSubscriptionStatus" method="post" style="margin:0;" onsubmit="confirmAction(event, 'هل أنت متأكد من إيقاف اشتراك الطالب وحرمانه من الدخول للمنصة؟', 'نعم، إيقاف الاشتراك', '#dc2626')">
                            <input type="hidden" name="requestId" value="@req.Id" />
                            <input type="hidden" name="status" value="Rejected" />
                            <button type="submit" class="btn-do btn-reject"><i class="fa-solid fa-ban"></i> إيقاف وحظر الاشتراك</button>
                        </form>
                    }
                    else if (req.Status == "Rejected")
                    {
                        <form asp-action="UpdateSubscriptionStatus" method="post" style="margin:0;" onsubmit="confirmAction(event, 'هل أنت متأكد من إعادة تفعيل حساب الطالب مرة أخرى؟', 'نعم، تفعيل', '#16a34a')">
                            <input type="hidden" name="requestId" value="@req.Id" />
                            <input type="hidden" name="status" value="Approved" />
                            <button type="submit" class="btn-do btn-approve"><i class="fa-solid fa-rotate-left"></i> إعادة تفعيل الاشتراك</button>
                        </form>
                    }
                </div>
            </div>
        }
    </div>
}
else
{
    <div style="background:var(--c-white); border-radius:var(--radius-xl); padding: 6rem 2rem; text-align:center; box-shadow:var(--shadow-sm); border:1px solid rgba(0,0,0,0.05);">
        <i class="fa-solid fa-inbox" style="font-size: 5rem; color: #cbd5e1; margin-bottom: 1.5rem; opacity:0.8;"></i>
        <h3 style="font-family:'Hayah',sans-serif; font-size: 2.2rem; color:var(--c-primary); margin:0 0 0.5rem 0;">لا توجد أي سجلات للاشتراكات!</h3>
        <p style="color:var(--c-text-muted); font-size: 1.1rem; font-weight:600;">بمجرد قيام الطلاب بطلب الاشتراك، ستظهر بياناتهم هنا.</p>
    </div>
}