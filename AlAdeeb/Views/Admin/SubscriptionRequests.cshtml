@model IEnumerable<AlAdeeb.Models.SubscriptionRequest>
@{
    ViewData["Title"] = "الاشتراكات المالية";
    Layout = "_AdminLayout";
}

<style>
    .page-container {
        animation: fadeIn 0.5s ease;
    }

    .page-header {
        background: var(--c-white);
        border-radius: 2rem;
        padding: 2.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        justify-content: space-between;
        align-items: center;
        box-shadow: var(--shadow-soft);
        border: 1px solid rgba(10,50,84,0.05);
        margin-bottom: 2.5rem;
    }

    @@media(min-width: 768px) {
        .page-header {
            flex-direction: row;
        }
    }

    .header-info {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .header-icon {
        width: 4.5rem;
        height: 4.5rem;
        background: rgba(175,143,66,0.1);
        color: var(--c-secondary);
        border-radius: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
    }

    .header-text h2 {
        font-size: 2rem;
        color: var(--c-primary);
        font-weight: 900;
        margin: 0 0 0.3rem 0;
    }

    .header-text p {
        font-size: 1rem;
        color: #64748b;
        margin: 0;
        font-weight: bold;
    }

    .pending-badge {
        background: #fef2f2;
        color: #ef4444;
        padding: 0.8rem 1.5rem;
        border-radius: 1rem;
        font-weight: 900;
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        gap: 0.8rem;
        border: 1px solid #fecaca;
    }

    .pulse-dot {
        width: 12px;
        height: 12px;
        background: #ef4444;
        border-radius: 50%;
        box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7);
        animation: ping 1.5s infinite cubic-bezier(0.66, 0, 0, 1);
    }

    .requests-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 2rem;
    }

    .req-card {
        background: var(--c-white);
        border-radius: 1.5rem;
        border: 1px solid #e2e8f0;
        overflow: hidden;
        box-shadow: var(--shadow-soft);
        transition: var(--transition);
        display: flex;
        flex-direction: column;
    }

        .req-card:hover {
            transform: translateY(-5px);
            border-color: rgba(175,143,66,0.3);
            box-shadow: 0 15px 35px rgba(10,50,84,0.1);
        }

    .req-header {
        background: #f8fafc;
        padding: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        border-bottom: 1px solid #e2e8f0;
    }

    .student-avatar {
        width: 3.5rem;
        height: 3.5rem;
        background: var(--c-primary);
        color: var(--c-white);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 900;
        border: 2px solid var(--c-secondary);
        flex-shrink: 0;
    }

    .student-info h4 {
        font-size: 1.2rem;
        color: var(--c-primary);
        font-weight: 900;
        margin: 0 0 0.2rem 0;
        line-height: 1.2;
    }

    .student-info p {
        font-size: 0.9rem;
        color: #64748b;
        font-family: Arial, sans-serif;
        font-weight: bold;
        margin: 0;
        direction: ltr;
        text-align: right;
    }

    .req-body {
        padding: 1.5rem;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .course-tag {
        background: rgba(175,143,66,0.05);
        border: 1px solid rgba(175,143,66,0.2);
        padding: 0.8rem 1rem;
        border-radius: 0.8rem;
    }

        .course-tag span {
            display: block;
            font-size: 0.75rem;
            color: #94a3b8;
            font-weight: 900;
            text-transform: uppercase;
            margin-bottom: 0.2rem;
        }

        .course-tag strong {
            font-size: 1.1rem;
            color: var(--c-primary);
            font-weight: 900;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

    .time-tag {
        font-size: 0.9rem;
        color: #64748b;
        font-weight: bold;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .time-tag span:last-child {
            font-family: Arial, sans-serif;
            direction: ltr;
        }

    .btn-receipt {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        background: #f1f5f9;
        color: var(--c-primary);
        padding: 0.8rem;
        border-radius: 0.8rem;
        text-decoration: none;
        font-weight: 900;
        transition: var(--transition);
        border: 1px solid #e2e8f0;
    }

        .btn-receipt:hover {
            background: var(--c-secondary);
            color: var(--c-primary);
            border-color: var(--c-secondary);
        }

    .no-receipt {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        background: #fef2f2;
        color: #ef4444;
        padding: 0.8rem;
        border-radius: 0.8rem;
        font-weight: 900;
        border: 1px solid #fecaca;
    }

    .req-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.8rem;
        padding: 1.5rem;
        border-top: 1px dashed #e2e8f0;
    }

    .btn-approve {
        background: #2e7d32;
        color: #fff;
        border: none;
        padding: 0.8rem;
        border-radius: 0.8rem;
        font-family: inherit;
        font-size: 1.1rem;
        font-weight: 900;
        cursor: pointer;
        transition: var(--transition);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

        .btn-approve:hover {
            background: #1b5e20;
            box-shadow: 0 5px 15px rgba(46,125,50,0.3);
            transform: translateY(-2px);
        }

    .btn-reject {
        background: #fff;
        color: #ef4444;
        border: 1px solid #fecaca;
        padding: 0.8rem;
        border-radius: 0.8rem;
        font-family: inherit;
        font-size: 1.1rem;
        font-weight: 900;
        cursor: pointer;
        transition: var(--transition);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

        .btn-reject:hover {
            background: #fef2f2;
            border-color: #ef4444;
        }

    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        background: var(--c-white);
        border-radius: 2rem;
        box-shadow: var(--shadow-soft);
    }

        .empty-state i {
            font-size: 5rem;
            color: #2e7d32;
            margin-bottom: 1.5rem;
            opacity: 0.2;
        }

        .empty-state h3 {
            font-size: 2rem;
            color: var(--c-primary);
            margin: 0 0 0.5rem 0;
            font-weight: 900;
        }

        .empty-state p {
            font-size: 1.2rem;
            color: #64748b;
            margin: 0;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes ping {
        70%, 100% {
            transform: scale(2);
            opacity: 0;
        }
    }
</style>

<div class="page-container">

    <div class="page-header">
        <div class="header-info">
            <div class="header-icon"><i class="fa-solid fa-file-invoice-dollar"></i></div>
            <div class="header-text">
                <h2>الاشتراكات المعلقة</h2>
                <p>راجع إيصالات التحويل البنكي وقم بتفعيل حسابات الطلاب.</p>
            </div>
        </div>
        <div class="pending-badge">
            <div class="pulse-dot"></div>
            <span>@(Model?.Count() ?? 0) طلبات تحتاج مراجعة</span>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="requests-grid">
            @foreach (var request in Model)
            {
                <div class="req-card">
                    <div class="req-header">
                        <div class="student-avatar">@request.Student.FullName.Substring(0, 1)</div>
                        <div class="student-info">
                            <h4>@request.Student.FullName</h4>
                            <p><i class="fa-solid fa-phone"></i> @request.Student.PhoneNumber</p>
                        </div>
                    </div>

                    <div class="req-body">
                        <div class="course-tag">
                            <span>الدورة المطلوبة</span>
                            <strong><i class="fa-solid fa-book-open"></i> @request.Course.Title</strong>
                        </div>

                        <div class="time-tag">
                            <span>وقت الطلب:</span>
                            <span>@request.RequestDate.ToString("yyyy-MM-dd HH:mm")</span>
                        </div>

                        @if (!string.IsNullOrEmpty(request.ReceiptImagePath))
                        {
                            <a href="@request.ReceiptImagePath" target="_blank" class="btn-receipt">
                                <i class="fa-solid fa-image"></i> عرض الإيصال المرفق
                            </a>
                        }
                        else
                        {
                            <div class="no-receipt">
                                <i class="fa-solid fa-triangle-exclamation"></i> لم يتم إرفاق إيصال
                            </div>
                        }
                    </div>

                    <div class="req-actions">
                        <form asp-action="UpdateSubscriptionStatus" method="post" style="margin:0;">
                            <input type="hidden" name="requestId" value="@request.Id" />
                            <input type="hidden" name="status" value="Approved" />
                            <button type="submit" class="btn-approve w-full"><i class="fa-solid fa-check"></i> تفعيل</button>
                        </form>

                        <form asp-action="UpdateSubscriptionStatus" method="post" style="margin:0;">
                            <input type="hidden" name="requestId" value="@request.Id" />
                            <input type="hidden" name="status" value="Rejected" />
                            <button type="submit" class="btn-reject w-full" onclick="return confirm('هل أنت متأكد من رفض الطلب؟');"><i class="fa-solid fa-xmark"></i> رفض</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="fa-solid fa-shield-check"></i>
            <h3>كل شيء منجز!</h3>
            <p>لا توجد أي طلبات اشتراك معلقة في الوقت الحالي.</p>
        </div>
    }
</div>