<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - منصة الأديب</title>

    <!-- خطوط وأيقونات -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
    <link type="image/x-icon" rel="icon" href="~/images/logo.png" /> 
    <style>
        @@font-face {
            font-family: 'Hayah';
            src: url('/fonts/Hayah.otf') format('opentype');
        }

        :root {
            --c-primary: #0a3254;
            --c-primary-light: #124b7a;
            --c-primary-dark: #051b2e;
            --c-secondary: #af8f42;
            --c-secondary-light: #d1b46b;
            --c-bg: #f3f6f9;
            --c-white: #ffffff;
            --c-text-main: #1e293b;
            --c-text-muted: #64748b;
            --shadow-sm: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            --shadow-md: 0 10px 30px -5px rgba(10, 50, 84, 0.08);
            --shadow-glow: 0 10px 25px -5px rgba(175, 143, 66, 0.4);
            --radius-md: 1rem;
            --radius-lg: 1.5rem;
            --radius-xl: 2rem;
            --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            font-family: 'Cairo', sans-serif;
            background-color: var(--c-bg);
            margin: 0;
            display: flex;
            height: 100vh;
            overflow: hidden;
            color: var(--c-text-main);
        }

        * {
            box-sizing: border-box;
        }

        h1, h2, h3, .logo-text {
            font-family: 'Hayah', sans-serif;
        }

        a {
            text-decoration: none;
        }

        /* ================= Sidebar ================= */
        .sidebar {
            width: 300px;
            background: linear-gradient(180deg, var(--c-primary-dark) 0%, var(--c-primary) 100%);
            color: var(--c-white);
            display: flex;
            flex-direction: column;
            transition: var(--transition);
            z-index: 100;
            box-shadow: 4px 0 24px rgba(0,0,0,0.1);
            position: relative;
            overflow: hidden;
        }

            .sidebar::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjEiIGZpbGw9InJnYmEoMjU1LDI1NSwyNTUsMC4wNSkiLz48L3N2Zz4=');
                z-index: 0;
                pointer-events: none;
            }

        .sidebar-header {
            height: 90px;
            display: flex;
            align-items: center;
            padding: 0 1.5rem;
            background: rgba(0,0,0,0.2);
            border-bottom: 1px solid rgba(255,255,255,0.05);
            gap: 1rem;
            position: relative;
            z-index: 1;
            backdrop-filter: blur(10px);
        }

        .sidebar-logo {
            width: 45px;
            height: 45px;
            background: linear-gradient(135deg, var(--c-secondary), var(--c-secondary-light));
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: var(--c-white);
            box-shadow: var(--shadow-glow);
        }

        .logo-text {
            font-size: 1.8rem;
            font-weight: 900;
            color: var(--c-white);
            margin: 0;
            letter-spacing: 1px;
        }

            .logo-text span {
                color: var(--c-secondary);
            }

        .nav-menu {
            flex: 1;
            overflow-y: auto;
            padding: 2rem 1.2rem;
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
            position: relative;
            z-index: 1;
        }

            .nav-menu::-webkit-scrollbar {
                width: 4px;
            }

            .nav-menu::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,0.2);
                border-radius: 10px;
            }

        .nav-group {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.4);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin: 1.5rem 1rem 0.5rem 0;
            font-weight: 800;
        }

        .nav-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.8rem 1rem;
            color: rgba(255,255,255,0.7);
            border-radius: 12px;
            font-size: 0.95rem;
            font-weight: 700;
            transition: var(--transition);
            border: 1px solid transparent;
        }

        .nav-item-content {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .nav-item i {
            font-size: 1.2rem;
            width: 24px;
            text-align: center;
            transition: var(--transition);
        }

        .nav-item:hover, .nav-item.active {
            background: rgba(255,255,255,0.1);
            color: var(--c-white);
            border-color: rgba(255,255,255,0.05);
            transform: translateX(-5px);
        }

            .nav-item.active i {
                color: var(--c-secondary);
            }

            .nav-item:hover i {
                transform: scale(1.1);
                color: var(--c-secondary-light);
            }

        .badge-pulse {
            background: #ef4444;
            color: #fff;
            font-size: 0.75rem;
            padding: 0.2rem 0.6rem;
            border-radius: 50px;
            font-weight: 700;
            box-shadow: 0 0 10px rgba(239, 68, 68, 0.5);
        }

        /* ================= Main Wrapper ================= */
        .main-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
            background: var(--c-bg);
        }

        .topbar {
            height: 80px;
            background: rgba(255,255,255,0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            border-bottom: 1px solid rgba(0,0,0,0.05);
            z-index: 50;
            position: sticky;
            top: 0;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .menu-toggle {
            background: var(--c-white);
            border: 1px solid rgba(0,0,0,0.05);
            border-radius: 10px;
            width: 40px;
            height: 40px;
            display: none;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            color: var(--c-primary);
            cursor: pointer;
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
        }

            .menu-toggle:hover {
                background: var(--c-primary);
                color: var(--c-white);
            }

        .page-title h1 {
            font-size: 1.5rem;
            color: var(--c-primary);
            margin: 0;
        }

        .page-title p {
            font-size: 0.85rem;
            color: var(--c-text-muted);
            margin: 0;
            font-weight: 600;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .btn-view-site {
            background: var(--c-primary-light);
            color: var(--c-white);
            padding: 0.6rem 1.2rem;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
            box-shadow: var(--shadow-sm);
        }

            .btn-view-site:hover {
                background: var(--c-primary);
                transform: translateY(-2px);
            }

        .admin-profile {
            display: flex;
            align-items: center;
            gap: 1rem;
            background: var(--c-white);
            border-radius: 15px;
            border: 1px solid rgba(0,0,0,0.05);
            box-shadow: var(--shadow-sm);
            cursor: pointer;
            transition: var(--transition);
            padding: 5px 15px;
        }

            .admin-profile:hover {
                box-shadow: var(--shadow-md);
            }

            .admin-profile img {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                object-fit: cover;
            }

        .admin-info h4 {
            margin: 0;
            font-size: 0.9rem;
            color: var(--c-primary);
            font-weight: 700;
        }

        .admin-info p {
            margin: 0;
            font-size: 0.75rem;
            color: var(--c-secondary);
            font-weight: 700;
        }

        /* ================= Content Area ================= */
        .content-area {
            flex: 1;
            overflow-y: auto;
            padding: 2.5rem;
            position: relative;
        }

            .content-area::-webkit-scrollbar {
                width: 6px;
            }

            .content-area::-webkit-scrollbar-thumb {
                background: #cbd5e1;
                border-radius: 10px;
            }

                .content-area::-webkit-scrollbar-thumb:hover {
                    background: var(--c-secondary);
                }

        .admin-alert {
            background: #f0fdf4;
            color: #166534;
            padding: 1rem 1.5rem;
            border-radius: var(--radius-md);
            border: 1px solid #bbf7d0;
            margin-bottom: 2rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            font-weight: 600;
            font-size: 1rem;
            animation: slideDown 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: var(--shadow-sm);
        }

        /* ================= Mobile Overlay ================= */
        .sidebar-overlay {
            position: fixed;
            inset: 0;
            background: rgba(10,50,84,0.4);
            backdrop-filter: blur(4px);
            z-index: 90;
            display: none;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        @@media(max-width: 1024px) {
            .sidebar {
                position: fixed;
                right: -300px;
                top: 0;
                bottom: 0;
            }

                .sidebar.open {
                    right: 0;
                }

            .menu-toggle {
                display: flex;
            }

            .sidebar-overlay.active {
                display: block;
                opacity: 1;
            }

            .page-title p {
                display: none;
            }

            .topbar-right .btn-view-site span, .topbar-right .admin-info {
                display: none;
            }

            .content-area {
                padding: 1.5rem;
            }
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* تأثيرات الظهور للعناصر بالداخل */
        .animate-fade-in {
            animation: fadeIn 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>

    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <aside class="sidebar" id="adminSidebar">
        <div class="sidebar-header">
            <div class="sidebar-logo"><img src="~/images/logo-transparent.png" width="100px" style="background:#fff;padding:10px;border-radius:15px;" alt="الأديب" /></div>
            <h2 class="logo-text">إدارة <span>الأديب</span></h2>
        </div>

        <div class="nav-menu">
            <div class="nav-group"><i class="fa-solid fa-server"></i> نظرة عامة</div>
            <a href="/Admin/Index" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                <div class="nav-item-content"><i class="fa-solid fa-chart-line"></i> دوراتي / لوحة التحكم</div>
            </a>

            @if (User.IsInRole("Admin"))
            {
                <div class="nav-group"><i class="fa-solid fa-wallet"></i> العمليات المالية</div>
                <a href="/Admin/SubscriptionRequests" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "SubscriptionRequests" ? "active" : "")">
                    <div class="nav-item-content"><i class="fa-solid fa-file-invoice-dollar"></i> مراجعة الطلبات</div>
                    @if (ViewBag.PendingRequestsCount != null && ViewBag.PendingRequestsCount > 0)
                    {
                        <span class="badge-pulse">@ViewBag.PendingRequestsCount</span>
                    }
                </a>

                <div class="nav-group"><i class="fa-solid fa-users"></i> الإدارة العليا</div>
                <a href="/Admin/CreateCourse" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "CreateCourse" ? "active" : "")">
                    <div class="nav-item-content"><i class="fa-solid fa-square-plus"></i> إضافة دورة جديدة</div>
                </a>
                <a href="/Admin/StudentsList" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "StudentsList" ? "active" : "")">
                    <div class="nav-item-content"><i class="fa-solid fa-user-gear"></i> قاعدة بيانات الطلاب</div>
                </a>
                <a href="/Admin/TeachersList" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "TeachersList" ? "active" : "")">
                    <div class="nav-item-content"><i class="fa-solid fa-chalkboard-user"></i> فريق المعلمين</div>
                </a>
            }

            <div class="nav-group"><i class="fa-solid fa-satellite-dish"></i> التفاعل والبثوث</div>
            <a href="/Live/ManageLiveSessions" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Live" ? "active" : "")">
                <div class="nav-item-content"><i class="fa-solid fa-video"></i> إدارة البث المباشر</div>
            </a>
            <a href="/Admin/Discussions" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Discussions" ? "active" : "")">
                <div class="nav-item-content"> <i class="fa-solid fa-comments"></i> منتدى النقاشات </div>
            </a>

            <div style="margin-top: auto; padding-top: 2rem;">
                <a href="/Account/Logout" class="nav-item" style="background: rgba(239, 68, 68, 0.1); color: #fca5a5; justify-content: center; gap: 0.5rem;">
                    <i class="fa-solid fa-power-off"></i> تسجيل الخروج
                </a>
            </div>
        </div>
    </aside>

    <div class="main-wrapper">
        <header class="topbar">
            <div class="topbar-left">
                <button class="menu-toggle" onclick="toggleSidebar()"><i class="fa-solid fa-bars"></i></button>
                <div class="page-title">
                    <h1>@ViewData["Title"]</h1>
                    <p>مرحباً بك في مركز التحكم الشامل لمنصة الأديب.</p>
                </div>
            </div>
            <div class="topbar-right">
                <a href="/" target="_blank" class="btn-view-site">
                    <i class="fa-solid fa-arrow-up-right-from-square"></i> <span>الموقع الخارجي</span>
                </a>
                <div class="admin-profile">
                    <div class="admin-info">
                        <h4>@User.Identity.Name</h4>
                        <p>@(User.IsInRole("Admin") ? "المدير العام" : "معلم مساعد")</p>
                    </div>
                    <img src="~/images/Salah.jpg" alt="Admin" onerror="this.src='https://ui-avatars.com/api/?name=@User.Identity.Name&background=0a3254&color=af8f42';" />
                </div>
            </div>
        </header>

        <main class="content-area">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="admin-alert">
                    <i class="fa-solid fa-circle-check" style="font-size: 1.5rem;"></i>
                    <span>@TempData["SuccessMessage"]</span>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="admin-alert" style="background: #fef2f2; color: #991b1b; border-color: #fecaca;">
                    <i class="fa-solid fa-circle-exclamation" style="font-size: 1.5rem;"></i>
                    <span>@TempData["ErrorMessage"]</span>
                </div>
            }

            <div class="animate-fade-in">
                @RenderBody()
            </div>
        </main>
    </div>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('adminSidebar');
            const overlay = document.getElementById('sidebarOverlay');
            sidebar.classList.toggle('open');
            if (sidebar.classList.contains('open')) {
                overlay.classList.add('active');
            } else {
                overlay.classList.remove('active');
            }
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>