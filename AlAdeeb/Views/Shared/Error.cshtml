@model ErrorViewModel
@{
    ViewData["Title"] = "عذراً، حدث خطأ";
}

<style>
    @@font-face {
        font-family: 'Hayah';
        src: url('/fonts/Hayah.otf') format('opentype');
    }

    :root {
        --c-primary: #0a3254;
        --c-secondary: #af8f42;
        --c-bg: #f4f7f9;
        --c-white: #ffffff;
    }

    .error-page {
        font-family: 'Hayah', sans-serif;
        background-color: var(--c-bg);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        direction: rtl;
        position: relative;
        overflow: hidden;
    }

    .bg-pattern {
        position: absolute;
        inset: 0;
        background-image: repeating-linear-gradient(45deg, rgba(10,50,84,0.03) 0, rgba(10,50,84,0.03) 2px, transparent 2px, transparent 10px);
        z-index: 0;
    }

    .error-card {
        background: var(--c-white);
        border-radius: 3rem;
        padding: 4rem 3rem;
        text-align: center;
        max-width: 500px;
        width: 100%;
        box-shadow: 0 20px 50px rgba(0,0,0,0.05);
        border: 1px solid rgba(175,143,66,0.2);
        position: relative;
        z-index: 10;
        animation: fadeUp 0.6s ease;
    }

    .error-icon {
        width: 6rem;
        height: 6rem;
        background: #fef2f2;
        color: #dc2626;
        border-radius: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        margin: 0 auto 2rem auto;
        transform: rotate(10deg);
        box-shadow: inset 0 0 0 2px #fca5a5;
    }

    .error-title {
        font-size: 2.5rem;
        color: var(--c-primary);
        font-weight: 900;
        margin: 0 0 1rem 0;
    }

    .error-desc {
        font-size: 1.2rem;
        color: #64748b;
        margin: 0 0 2.5rem 0;
        line-height: 1.6;
    }

    .owner-msg {
        background: rgba(10,50,84,0.03);
        border: 1px solid rgba(10,50,84,0.1);
        border-radius: 1.5rem;
        padding: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        text-align: right;
        margin-bottom: 2.5rem;
    }

    .owner-img {
        width: 3.5rem;
        height: 3.5rem;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--c-secondary);
        flex-shrink: 0;
    }

    .owner-text h4 {
        font-size: 1.1rem;
        color: var(--c-primary);
        font-weight: 900;
        margin: 0 0 0.2rem 0;
    }

    .owner-text p {
        font-size: 0.9rem;
        color: #64748b;
        margin: 0;
        font-family: Arial, sans-serif;
        font-weight: bold;
    }

    .btn-home {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        background: var(--c-primary);
        color: var(--c-secondary);
        width: 100%;
        padding: 1.2rem;
        border-radius: 1.2rem;
        font-size: 1.4rem;
        font-weight: 900;
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 10px 20px rgba(10,50,84,0.2);
    }

        .btn-home:hover {
            background: var(--c-secondary);
            color: var(--c-primary);
            transform: translateY(-3px);
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="error-page">
    <div class="bg-pattern"></div>

    <div class="error-card">
        <div class="error-icon"><i class="fa-solid fa-triangle-exclamation"></i></div>

        <h1 class="error-title">أوبس! حدث خطأ</h1>
        <p class="error-desc">عذراً، يبدو أن هناك مشكلة غير متوقعة قد حدثت أثناء معالجة طلبك بالموقع.</p>

        <div class="owner-msg">
            <img src="~/images/Salah.jpg" alt="أ. صلاح عبد العال" class="owner-img" onerror="this.src='https://ui-avatars.com/api/?name=صلاح+عبدالعال&background=0a3254&color=af8f42';" />
            <div class="owner-text">
                <h4>أ. صلاح عبد العال</h4>
                <p>لا تقلق! لقد قمنا بتسجيل الخطأ والفريق التقني يعمل على حله فوراً.</p>
            </div>
        </div>

        <a href="/" class="btn-home">
            <i class="fa-solid fa-house"></i> العودة للصفحة الرئيسية
        </a>
    </div>
</div>