@model IEnumerable<AlAdeeb.Models.LiveSession>
@{
    ViewData["Title"] = "غرفة البثوث";
    Layout = "_AdminLayout";
}

<div class="max-w-7xl mx-auto space-y-8 animate-fade-in pb-20">

    <!-- هيدر الصفحة -->
    <div class="bg-dark rounded-[2rem] p-8 overflow-hidden shadow-lg relative">
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>
        <div class="relative z-10 flex flex-col md:flex-row items-center gap-6 text-center md:text-right">
            <div class="w-20 h-20 bg-rose-500/20 text-rose-400 rounded-2xl flex items-center justify-center text-4xl border border-rose-500/30 shrink-0 shadow-[0_0_30px_rgba(244,63,94,0.2)]">
                <i class="fa-solid fa-satellite-dish animate-pulse"></i>
            </div>
            <div>
                <h2 class="text-3xl font-black text-white mb-2 tracking-tight">غرفة التحكم بالبث المباشر</h2>
                <p class="text-slate-400 font-medium">نظّم مواعيد محاضرات Zoom وادمج التسجيلات التلقائية للطلاب.</p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- 1. فورم الجدولة (تصميم كارت طافي) -->
        <div class="bg-white p-8 rounded-[2rem] shadow-sm border border-slate-200 h-fit lg:sticky lg:top-28">
            <div class="flex items-center gap-3 mb-6 pb-4 border-b border-slate-100">
                <div class="w-10 h-10 bg-indigo-50 text-primary rounded-xl flex items-center justify-center text-lg"><i class="fa-solid fa-calendar-plus"></i></div>
                <h3 class="text-lg font-black text-slate-800">جدولة لقاء جديد</h3>
            </div>

            <form asp-controller="Live" asp-action="CreateLiveSession" method="post" class="space-y-5">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">الكورس المستهدف</label>
                    <select name="CourseId" required class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary font-bold text-slate-700 cursor-pointer transition-all">
                        <option value="" disabled selected>-- حدد الكورس --</option>
                        @if (ViewBag.Courses != null)
                        {
                            foreach (var course in ViewBag.Courses)
                            {
                                <option value="@course.Id">@course.Title</option>
                            }
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">موضوع اللقاء</label>
                    <input type="text" name="Title" required class="w-full bg-white border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary font-bold text-slate-800 transition-all shadow-sm" placeholder="مثال: مراجعة القطع..." />
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">رابط القاعة (Zoom)</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i class="fa-solid fa-link text-slate-300"></i></div>
                        <input type="url" name="LiveUrl" required class="w-full bg-white border border-slate-200 rounded-xl py-3 pr-3 pl-10 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary font-mono text-left text-sm transition-all shadow-sm" dir="ltr" placeholder="https://zoom.us/j/..." />
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">التاريخ والتوقيت</label>
                    <input type="datetime-local" name="ScheduledDate" required class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary font-mono text-slate-700 font-bold transition-all" />
                </div>
                <div class="pt-2">
                    <button type="submit" class="w-full bg-primary text-white py-3.5 rounded-xl font-black text-[15px] hover:bg-indigo-600 transition-all shadow-lg shadow-indigo-500/30 hover:-translate-y-0.5 flex items-center justify-center gap-2">
                        <i class="fa-solid fa-paper-plane"></i> اعتماد الموعد
                    </button>
                </div>
            </form>
        </div>

        <!-- 2. قائمة البثوث السابقة والقادمة (تصميم بطاقات عصرية) -->
        <div class="lg:col-span-2 space-y-6">
            <h3 class="text-lg font-black text-slate-800 mb-2 flex items-center gap-2"><i class="fa-solid fa-clock-rotate-left text-slate-400"></i> سجل البثوث والمحاضرات</h3>

            @if (Model != null && Model.Any())
            {
                foreach (var session in Model)
                {
                    <div class="bg-white p-6 rounded-[2rem] shadow-sm border border-slate-100 hover:shadow-md hover:border-slate-200 transition-all relative group overflow-hidden">

                        <!-- الشريط الجانبي للحالة -->
                        <div class="absolute right-0 top-0 h-full w-1.5 @(session.IsCompleted ? "bg-emerald-500" : "bg-amber-400")"></div>

                        <div class="flex justify-between items-start mb-4 pl-2">
                            <div>
                                @if (!session.IsCompleted)
                                {
                                    <span class="inline-flex items-center gap-1.5 bg-amber-50 text-amber-700 text-[10px] font-black uppercase tracking-wider px-2.5 py-1 rounded-md mb-2 border border-amber-200">
                                        <span class="w-1.5 h-1.5 bg-amber-500 rounded-full animate-ping"></span> مبرمج قريباً
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 bg-emerald-50 text-emerald-700 text-[10px] font-black uppercase tracking-wider px-2.5 py-1 rounded-md mb-2 border border-emerald-200">
                                        <i class="fa-solid fa-check text-emerald-500"></i> مكتمل
                                    </span>
                                }
                                <h4 class="font-black text-slate-900 text-xl leading-tight">@session.Title</h4>
                            </div>
                        </div>

                        <div class="flex flex-wrap items-center gap-3 text-sm font-medium mb-6 bg-slate-50 p-3 rounded-xl border border-slate-100">
                            <span class="text-slate-600 flex items-center gap-1.5"><i class="fa-regular fa-calendar-days text-primary"></i> <span dir="ltr">@session.ScheduledDate.ToString("yyyy-MMM-dd hh:mm tt")</span></span>
                            <span class="text-slate-300">|</span>
                            <span class="text-slate-600 flex items-center gap-1.5"><i class="fa-solid fa-book-open text-primary"></i> @session.Course.Title</span>
                        </div>

                        @if (!session.IsCompleted)
                        {
                            <div class="border-t border-slate-100 pt-5">
                                <p class="text-[11px] font-bold text-slate-400 mb-2 uppercase tracking-widest">إرفاق التسجيل (للمشاهدة لاحقاً)</p>
                                <form asp-controller="Live" asp-action="UploadRecording" method="post" class="flex flex-col sm:flex-row gap-2">
                                    <input type="hidden" name="sessionId" value="@session.Id" />
                                    <input type="url" name="recordedUrl" required class="flex-1 bg-white border border-slate-200 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-emerald-500/30 focus:border-emerald-500 font-mono text-left text-sm transition-all" dir="ltr" placeholder="رابط يوتيوب أو السحابة..." />
                                    <button type="submit" class="bg-emerald-50 text-emerald-600 border border-emerald-200 px-6 py-2.5 rounded-xl font-bold hover:bg-emerald-500 hover:text-white transition-all flex items-center justify-center gap-2 shrink-0">
                                        <i class="fa-solid fa-cloud-arrow-up"></i> حفظ وإنهاء
                                    </button>
                                </form>
                            </div>
                        }
                        else
                        {
                            <div class="border-t border-slate-100 pt-4">
                                <a href="@session.RecordedVideoUrl" target="_blank" class="inline-flex items-center justify-center gap-2 w-full sm:w-auto bg-slate-900 text-white px-6 py-2.5 rounded-xl font-bold text-sm hover:bg-primary transition-colors shadow-md">
                                    <i class="fa-solid fa-play-circle"></i> عرض التسجيل المرفوع للطالب
                                </a>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="bg-white p-12 rounded-[2rem] text-center border border-slate-100 shadow-sm">
                    <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4 border border-dashed border-slate-200">
                        <i class="fa-solid fa-video-slash text-3xl text-slate-300"></i>
                    </div>
                    <h4 class="text-xl font-black text-slate-700 mb-1">لا توجد بثوث مسجلة</h4>
                    <p class="text-slate-500 text-sm">سيتم عرض قائمة المحاضرات المباشرة هنا بمجرد جدولتها.</p>
                </div>
            }
        </div>
    </div>
</div>