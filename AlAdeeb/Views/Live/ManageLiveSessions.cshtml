@model IEnumerable<AlAdeeb.Models.LiveSession>
@{
    ViewData["Title"] = "البثوث المباشرة";
    Layout = "_AdminLayout";
}

<style>
    .page-header {
        background: url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyMCIgaGVpZ2h0PSIyMCI+PHBhdGggZD0iTTAgMGgyMHYyMEgweiIgZmlsbD0iI2FmOGY0MiIgZmlsbC1vcGFjaXR5PSIwLjA1Ii8+PC9zdmc+'), var(--c-primary-dark);
        border-radius: var(--radius-xl);
        padding: 3rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        box-shadow: var(--shadow-md);
        margin-bottom: 2.5rem;
        border-right: 8px solid #ef4444;
        color: var(--c-white);
        position: relative;
        overflow: hidden;
    }

    @@media(min-width: 768px) {
        .page-header {
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
        }
    }

    .header-info {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        position: relative;
        z-index: 2;
    }

    .header-icon {
        width: 5.5rem;
        height: 5.5rem;
        background: rgba(239,68,68,0.1);
        color: #ef4444;
        border-radius: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        border: 1px solid rgba(239,68,68,0.2);
    }

        .header-icon i {
            animation: pulse 2s infinite;
        }

    .header-text h2 {
        font-family: 'Hayah', sans-serif;
        font-size: 2.5rem;
        margin: 0 0 0.5rem 0;
        line-height: 1.2;
    }

    .header-text p {
        margin: 0;
        color: rgba(255,255,255,0.7);
        font-weight: 700;
        font-size: 1.1rem;
    }

    .grid-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2.5rem;
    }

    @@media(min-width: 1024px) {
        .grid-layout {
            grid-template-columns: 1fr 2fr;
        }
    }

    /* Form Card */
    .form-card {
        background: var(--c-white);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-sm);
        border: 1px solid rgba(0,0,0,0.04);
        padding: 2.5rem;
        height: fit-content;
        position: sticky;
        top: 100px;
    }

    .fc-title {
        display: flex;
        align-items: center;
        gap: 1rem;
        border-bottom: 1px solid #e2e8f0;
        padding-bottom: 1.5rem;
        margin-bottom: 1.5rem;
    }

        .fc-title i {
            font-size: 1.5rem;
            color: var(--c-secondary);
        }

        .fc-title h3 {
            font-family: 'Hayah', sans-serif;
            font-size: 1.6rem;
            color: var(--c-primary);
            margin: 0;
        }

    .form-group {
        margin-bottom: 1.5rem;
    }

        .form-group label {
            display: block;
            font-weight: 800;
            color: var(--c-primary);
            margin-bottom: 0.5rem;
            font-size: 0.95rem;
            text-transform: uppercase;
        }

    .form-control {
        width: 100%;
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 1rem;
        padding: 1rem 1.2rem;
        font-family: inherit;
        font-size: 1rem;
        font-weight: 700;
        color: var(--c-primary);
        transition: var(--transition);
    }

        .form-control:focus {
            outline: none;
            background: var(--c-white);
            border-color: var(--c-secondary);
            box-shadow: 0 0 0 4px rgba(175, 143, 66, 0.1);
        }

    .btn-submit {
        width: 100%;
        background: var(--c-primary);
        color: var(--c-secondary);
        border: none;
        padding: 1.2rem;
        border-radius: 1rem;
        font-size: 1.2rem;
        font-weight: 900;
        font-family: inherit;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        transition: var(--transition);
        box-shadow: var(--shadow-sm);
        margin-top: 1rem;
    }

        .btn-submit:hover {
            background: var(--c-secondary);
            color: var(--c-primary);
            transform: translateY(-3px);
            box-shadow: var(--shadow-md);
        }

    /* Sessions List */
    .sessions-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .s-card {
        background: var(--c-white);
        border-radius: var(--radius-lg);
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        position: relative;
        transition: var(--transition);
    }

        .s-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-md);
            border-color: rgba(175,143,66,0.3);
        }

    .s-indicator {
        position: absolute;
        right: 0;
        top: 0;
        height: 100%;
        width: 6px;
    }

    .s-pending {
        background: #f59e0b;
    }

    .s-completed {
        background: #10b981;
    }

    .s-body {
        padding: 2rem 2.5rem;
    }

    .s-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1.2rem;
    }

        .s-head h4 {
            font-family: 'Hayah', sans-serif;
            font-size: 1.8rem;
            color: var(--c-primary);
            margin: 0 0 0.5rem 0;
            line-height: 1.2;
        }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 1rem;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 800;
        text-transform: uppercase;
    }

    .badge-pending {
        background: #fffbeb;
        color: #b45309;
        border: 1px solid #fde68a;
    }

    .badge-completed {
        background: #ecfdf5;
        color: #047857;
        border: 1px solid #a7f3d0;
    }

    .s-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        background: #f8fafc;
        padding: 1rem 1.5rem;
        border-radius: 1rem;
        border: 1px solid #e2e8f0;
        margin-bottom: 1.5rem;
    }

        .s-meta div {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            font-size: 0.95rem;
            font-weight: 700;
            color: #64748b;
        }

            .s-meta div i {
                color: var(--c-primary);
                font-size: 1.2rem;
            }

            .s-meta div span {
                font-family: Arial, sans-serif;
                direction: ltr;
            }

    .s-action {
        border-top: 1px dashed #e2e8f0;
        padding-top: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .action-note {
        font-size: 0.85rem;
        color: #94a3b8;
        font-weight: 800;
        text-transform: uppercase;
        margin: 0;
    }

    .form-row {
        display: flex;
        gap: 1rem;
    }

    .btn-upload {
        background: #10b981;
        color: #fff;
        border: none;
        padding: 0 1.5rem;
        border-radius: 1rem;
        font-weight: 800;
        cursor: pointer;
        transition: var(--transition);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-shrink: 0;
    }

        .btn-upload:hover {
            background: #059669;
        }

    .btn-view {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        background: var(--c-primary);
        color: var(--c-secondary);
        padding: 1rem 2rem;
        border-radius: 1rem;
        font-weight: 800;
        text-decoration: none;
        transition: var(--transition);
    }

        .btn-view:hover {
            background: var(--c-secondary);
            color: var(--c-primary);
        }

    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.6;
            transform: scale(1.1);
        }
    }
</style>

<div class="page-header">
    <div class="header-info">
        <div class="header-icon"><i class="fa-solid fa-satellite-dish"></i></div>
        <div class="header-text">
            <h2>غرفة البثوث والمحاضرات</h2>
            <p>قم بجدولة المواعيد للطلاب ورفع التسجيلات تلقائياً لمراجعتها لاحقاً.</p>
        </div>
    </div>
</div>

<div class="grid-layout">

    <div class="form-card">
        <div class="fc-title">
            <i class="fa-solid fa-calendar-plus"></i>
            <h3>جدولة لقاء جديد</h3>
        </div>
        <form asp-controller="Live" asp-action="CreateLiveSession" method="post">
            <div class="form-group">
                <label>الكورس المستهدف</label>
                <select name="CourseId" required class="form-control" style="cursor: pointer;">
                    <option value="" disabled selected>-- اختر المسار التعليمي --</option>
                    @if (ViewBag.Courses != null)
                    {
                        foreach (var course in ViewBag.Courses)
                        {
                            <option value="@course.Id">@course.Title</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group">
                <label>موضوع اللقاء / العنوان</label>
                <input type="text" name="Title" required class="form-control" placeholder="مثال: مراجعة شاملة لأسئلة التناظر..." />
            </div>
            <div class="form-group">
                <label>رابط القاعة (Zoom / Meet)</label>
                <input type="url" name="LiveUrl" required class="form-control" dir="ltr" placeholder="https://zoom.us/j/..." style="text-align:left;" />
            </div>
            <div class="form-group">
                <label>تاريخ وتوقيت البث</label>
                <input type="datetime-local" name="ScheduledDate" required class="form-control" style="font-family: Arial; direction: ltr;" />
            </div>
            <button type="submit" class="btn-submit">
                <i class="fa-solid fa-paper-plane"></i> اعتماد الموعد
            </button>
        </form>
    </div>

    <div class="sessions-list">
        @if (Model != null && Model.Any())
        {
            foreach (var session in Model)
            {
                <div class="s-card">
                    <div class="s-indicator @(session.IsCompleted ? "s-completed" : "s-pending")"></div>
                    <div class="s-body">
                        <div class="s-head">
                            <div>
                                @if (!session.IsCompleted)
                                {
                                    <div class="status-badge badge-pending"><i class="fa-solid fa-clock"></i> مبرمج قريباً</div>
                                }
                                else
                                {
                                    <div class="status-badge badge-completed"><i class="fa-solid fa-check-double"></i> مكتمل وتم الرفع</div>
                                }
                                <h4 style="margin-top: 1rem;">@session.Title</h4>
                            </div>
                        </div>

                        <div class="s-meta">
                            <div><i class="fa-regular fa-calendar-days"></i> <span>@session.ScheduledDate.ToString("yyyy/MM/dd hh:mm tt")</span></div>
                            <div><i class="fa-solid fa-book-open"></i> @session.Course.Title</div>
                        </div>

                        <div class="s-action">
                            @if (!session.IsCompleted)
                            {
                                <p class="action-note">إرفاق التسجيل بعد انتهاء المحاضرة:</p>
                                <form asp-controller="Live" asp-action="UploadRecording" method="post" class="form-row">
                                    <input type="hidden" name="sessionId" value="@session.Id" />
                                    <input type="url" name="recordedUrl" required class="form-control" dir="ltr" placeholder="رابط يوتيوب أو التخزين السحابي..." style="padding: 0.8rem 1rem;" />
                                    <button type="submit" class="btn-upload"><i class="fa-solid fa-cloud-arrow-up"></i> حفظ</button>
                                </form>
                            }
                            else
                            {
                                <a href="@session.RecordedVideoUrl" target="_blank" class="btn-view">
                                    <i class="fa-solid fa-play-circle"></i> عرض التسجيل المرفوع للطالب
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="background:var(--c-white); border-radius:var(--radius-xl); padding: 5rem 2rem; text-align:center; box-shadow:var(--shadow-sm); border:1px solid rgba(0,0,0,0.05); height: 100%; display:flex; flex-direction:column; justify-content:center;">
                <i class="fa-solid fa-video-slash" style="font-size: 5rem; color: #cbd5e1; margin-bottom: 1.5rem;"></i>
                <h3 style="font-family:'Hayah',sans-serif; font-size: 2rem; color:var(--c-primary); margin:0 0 0.5rem 0;">لا توجد بثوث مجدولة</h3>
                <p style="color:var(--c-text-muted); font-size: 1.1rem; font-weight:600;">قم بجدولة البث الأول من القائمة الجانبية ليظهر للطلاب.</p>
            </div>
        }
    </div>
</div>