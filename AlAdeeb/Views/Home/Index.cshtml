@{
    ViewData["Title"] = "الرئيسية";
}

<style>
    /* ... احتفظ بنفس تنسيقاتك السابقة هنا، سنضيف فقط تنسيقات الأقسام الجديدة ... */
    @@font-face {
        font-family: 'Hayah';
        src: url('/fonts/Hayah.otf') format('opentype');
        font-weight: normal;
        font-style: normal;
    }

    :root {
        --c-primary: #0a3254;
        --c-primary-dark: #061d33;
        --c-secondary: #af8f42;
        --c-secondary-light: #cfa858;
        --c-bg: #f8f9fc;
        --c-white: #ffffff;
        --c-text-main: #1e293b;
        --c-text-muted: #64748b;
        --shadow-glow: 0 15px 35px -5px rgba(175, 143, 66, 0.3);
        --shadow-card: 0 20px 40px -10px rgba(10, 50, 84, 0.1);
        --transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    body {
        font-family: 'Hayah', sans-serif;
        background-color: var(--c-bg);
        margin: 0;
        padding: 0;
        overflow-x: hidden;
    }

    /* Hero Section */
    .hero-section {
        position: relative;
        background: linear-gradient(135deg, var(--c-primary-dark) 0%, var(--c-primary) 100%);
        min-height: 90vh;
        display: flex;
        align-items: center;
        overflow: hidden;
        direction: rtl;
    }

    .hero-bg-shapes {
        position: absolute;
        inset: 0;
        z-index: 0;
        overflow: hidden;
    }

    .hero-blob-1 {
        position: absolute;
        top: -20%;
        right: -10%;
        width: 600px;
        height: 600px;
        background: var(--c-secondary);
        border-radius: 50%;
        filter: blur(150px);
        opacity: 0.15;
        animation: floatShape 12s infinite alternate ease-in-out;
    }

    .hero-blob-2 {
        position: absolute;
        bottom: -20%;
        left: -10%;
        width: 500px;
        height: 500px;
        background: var(--c-white);
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.05;
        animation: floatShape 15s infinite alternate-reverse ease-in-out;
    }

    .hero-container {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 2rem;
        position: relative;
        z-index: 10;
        display: grid;
        grid-template-columns: 1fr;
        gap: 4rem;
        align-items: center;
        width: 100%;
    }

    @@media (min-width: 992px) {
        .hero-container {
            grid-template-columns: 1.2fr 1fr;
        }
    }

    .hero-content {
        animation: fadeUp 1s ease forwards;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(175, 143, 66, 0.3);
        padding: 0.6rem 1.8rem;
        border-radius: 50px;
        color: var(--c-secondary-light);
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 2rem;
        backdrop-filter: blur(10px);
    }

        .hero-badge i {
            animation: pulseGlow 2s infinite;
        }

    .hero-title {
        font-size: clamp(3rem, 6vw, 5rem);
        font-weight: 900;
        color: var(--c-white);
        line-height: 1.2;
        margin-bottom: 1.5rem;
    }

        .hero-title span {
            color: var(--c-secondary);
            background: -webkit-linear-gradient(0deg, var(--c-secondary-light), var(--c-secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .hero-description {
        font-size: 1.4rem;
        color: rgba(255, 255, 255, 0.85);
        line-height: 1.8;
        margin-bottom: 3rem;
        max-width: 650px;
    }

    .hero-actions {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .btn-primary {
        background: var(--c-secondary);
        color: var(--c-primary-dark);
        padding: 1.2rem 2.8rem;
        border-radius: 1.2rem;
        font-size: 1.3rem;
        font-weight: 900;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        box-shadow: var(--shadow-glow);
        transition: var(--transition);
        border: none;
        cursor: pointer;
    }

        .btn-primary:hover {
            transform: translateY(-5px);
            background: var(--c-secondary-light);
            box-shadow: 0 20px 40px -5px rgba(175, 143, 66, 0.5);
        }

    .btn-outline {
        background: rgba(255, 255, 255, 0.05);
        color: var(--c-white);
        padding: 1.2rem 2.8rem;
        border-radius: 1.2rem;
        font-size: 1.3rem;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        border: 1px solid rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        transition: var(--transition);
    }

        .btn-outline:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--c-secondary);
            color: var(--c-secondary);
        }

    .hero-visual {
        position: relative;
        animation: fadeLeft 1s ease forwards;
        display: none;
    }

    @@media (min-width: 992px) {
        .hero-visual {
            display: block;
        }
    }

    .visual-frame {
        position: relative;
        width: 100%;
        aspect-ratio: 1;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0) 100%);
        border: 4px solid rgba(175, 143, 66, 0.3);
        backdrop-filter: blur(20px);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 30px 60px rgba(0,0,0,0.3);
        transform: perspective(1000px) rotateY(-10deg);
        transform-style: preserve-3d;
        transition: var(--transition);
        padding: 1rem;
    }

    .hero-visual:hover .visual-frame {
        transform: perspective(1000px) rotateY(0deg);
        border-color: var(--c-secondary);
    }

    .visual-frame img {
        border-radius: 50%;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .float-card-1, .float-card-2 {
        position: absolute;
        padding: 0.5rem 1rem;
        border-radius: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1.2rem;
    }

    .float-card-1 {
        top: 10%;
        right: -20px;
        background: var(--c-white);
        box-shadow: var(--shadow-card);
        transform: translateZ(80px);
        animation: floatY 5s infinite ease-in-out;
    }

        .float-card-1 i {
            color: var(--c-secondary);
            font-size: 2rem;
        }

        .float-card-1 span {
            color: var(--c-primary);
            font-weight: 900;
            font-size: 1.5rem;
        }

    .float-card-2 {
        bottom: 15%;
        left: -30px;
        background: var(--c-primary);
        box-shadow: 0 20px 40px rgba(10,50,84,0.4);
        transform: translateZ(60px);
        animation: floatY 6s infinite ease-in-out reverse;
        border: 1px solid rgba(175,143,66,0.3);
    }

        .float-card-2 i, .float-card-2 span {
            color: var(--c-white);
            font-size: 1.5rem;
            font-weight: 900;
        }

    /* Stats Section */
    .stats-section {
        position: relative;
        z-index: 20;
        margin-top: -6rem;
        padding: 0 2rem;
        max-width: 1250px;
        margin-left: auto;
        margin-right: auto;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        background: var(--c-white);
        border-radius: 2rem;
        box-shadow: 0 20px 50px rgba(10, 50, 84, 0.15);
        border: 1px solid rgba(10, 50, 84, 0.05);
        padding: 3rem 2rem;
        gap: 2rem;
    }

    @@media (min-width: 768px) {
        .stats-grid {
            grid-template-columns: repeat(4, 1fr);
        }

        .stat-item:not(:last-child)::after {
            content: '';
            position: absolute;
            left: -1rem;
            top: 20%;
            height: 60%;
            width: 1px;
            background: rgba(10, 50, 84, 0.1);
        }
    }

    .stat-item {
        text-align: center;
        position: relative;
    }

    .stat-value {
        font-size: 3.5rem;
        font-weight: 900;
        color: var(--c-primary);
        font-family: Arial, sans-serif;
        margin-bottom: 0.5rem;
        line-height: 1;
    }

    .stat-label {
        font-size: 1.2rem;
        color: var(--c-secondary);
        font-weight: 900;
    }

    /* Placement Test Section (NEW) */
    .placement-section {
        padding: 6rem 2rem;
        background: url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyMCIgaGVpZ2h0PSIyMCI+PHBhdGggZD0iTTAgMGgyMHYyMEgweiIgZmlsbD0iI2FmOGY0MiIgZmlsbC1vcGFjaXR5PSIwLjA1Ii8+PC9zdmc+'), var(--c-bg);
        text-align: center;
    }

    .placement-card {
        max-width: 900px;
        margin: 0 auto;
        background: var(--c-white);
        border-radius: 2rem;
        padding: 4rem 2rem;
        box-shadow: var(--shadow-card);
        border: 2px dashed var(--c-secondary);
        position: relative;
        overflow: hidden;
    }

    .placement-icon {
        width: 5rem;
        height: 5rem;
        background: var(--c-secondary);
        color: var(--c-white);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        margin: 0 auto 1.5rem;
        box-shadow: var(--shadow-glow);
    }

    .placement-card h2 {
        font-size: 2.5rem;
        color: var(--c-primary);
        font-weight: 900;
        margin-bottom: 1rem;
    }

    .placement-card p {
        font-size: 1.2rem;
        color: var(--c-text-muted);
        margin-bottom: 2.5rem;
        line-height: 1.6;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
    }

    /* Promo Video Section (NEW) */
    .promo-section {
        padding: 6rem 2rem 10rem;
        background: var(--c-primary-dark);
        position: relative;
    }

    .promo-container {
        max-width: 1000px;
        margin: 0 auto;
        text-align: center;
    }

    .promo-header h2 {
        color: var(--c-white);
        font-size: 3rem;
        font-weight: 900;
        margin-bottom: 1rem;
    }

    .promo-header p {
        color: var(--c-secondary);
        font-size: 1.3rem;
        margin-bottom: 3rem;
        font-weight: bold;
    }

    .promo-video-wrapper {
        position: relative;
        padding-bottom: 56.25%;
        height: 0;
        border-radius: 2rem;
        overflow: hidden;
        box-shadow: 0 30px 60px rgba(0,0,0,0.5);
        border: 3px solid rgba(175,143,66,0.5);
    }

        .promo-video-wrapper iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
        }

    /* Features Section */
    .features-section {
        padding: 8rem 2rem 6rem;
        background: var(--c-bg);
        direction: rtl;
        max-width: 1280px;
        margin: 0 auto;
    }

    .section-header {
        text-align: center;
        margin-bottom: 5rem;
    }

    .section-title {
        font-size: 3.5rem;
        font-weight: 900;
        color: var(--c-primary);
        margin-bottom: 1rem;
    }

    .section-subtitle {
        font-size: 1.4rem;
        color: var(--c-text-muted);
        max-width: 700px;
        margin: 0 auto;
        line-height: 1.6;
    }

    .features-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2.5rem;
    }

    @@media (min-width: 768px) {
        .features-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .feature-card {
        background: var(--c-white);
        border-radius: 2rem;
        padding: 3.5rem 2rem;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
        border: 1px solid transparent;
        transition: var(--transition);
        position: relative;
        overflow: hidden;
    }

        .feature-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
            background: var(--c-secondary);
            transform: scaleX(0);
            transition: var(--transition);
            transform-origin: right;
        }

        .feature-card:hover {
            transform: translateY(-15px);
            box-shadow: var(--shadow-card);
            border-color: rgba(175, 143, 66, 0.1);
        }

            .feature-card:hover::before {
                transform: scaleX(1);
            }

    .f-icon-wrapper {
        width: 6rem;
        height: 6rem;
        background: rgba(10, 50, 84, 0.03);
        border-radius: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 2rem auto;
        color: var(--c-primary);
        font-size: 2.8rem;
        transition: var(--transition);
    }

    .feature-card:hover .f-icon-wrapper {
        background: var(--c-primary);
        color: var(--c-secondary);
        transform: rotate(10deg);
    }

    .feature-card h3 {
        font-size: 1.8rem;
        font-weight: 900;
        color: var(--c-primary);
        margin-bottom: 1.2rem;
    }

    .feature-card p {
        font-size: 1.2rem;
        color: var(--c-text-muted);
        line-height: 1.8;
    }

    /* Steps Section */
    .steps-section {
        background: var(--c-white);
        padding: 8rem 2rem;
    }

    .steps-container {
        max-width: 1280px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr;
        gap: 5rem;
        align-items: center;
    }

    @@media (min-width: 992px) {
        .steps-container {
            grid-template-columns: 1fr 1fr;
        }
    }

    .steps-content h2 {
        font-size: 3.5rem;
        font-weight: 900;
        color: var(--c-primary);
        margin-bottom: 3rem;
    }

    .step-item {
        display: flex;
        gap: 2rem;
        margin-bottom: 2.5rem;
    }

    .step-number {
        width: 4.5rem;
        height: 4.5rem;
        background: var(--c-secondary);
        color: var(--c-white);
        border-radius: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 900;
        font-family: Arial, sans-serif;
        flex-shrink: 0;
        box-shadow: 0 10px 20px rgba(175,143,66,0.3);
    }

    .step-text h3 {
        font-size: 1.8rem;
        font-weight: 900;
        color: var(--c-primary);
        margin: 0 0 0.5rem 0;
    }

    .step-text p {
        font-size: 1.2rem;
        color: var(--c-text-muted);
        line-height: 1.7;
        margin: 0;
    }

    .steps-image {
        position: relative;
        border-radius: 2rem;
        overflow: hidden;
        box-shadow: var(--shadow-card);
    }

        .steps-image img {
            width: 100%;
            height: auto;
            display: block;
        }

    /* CTA Section */
    .cta-section {
        background: linear-gradient(135deg, var(--c-primary) 0%, #051b2e 100%);
        padding: 6rem 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .cta-section::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: radial-gradient(rgba(175,143,66,0.2) 2px, transparent 2px);
            background-size: 20px 20px;
            opacity: 0.5;
        }

    .cta-content {
        position: relative;
        z-index: 10;
        max-width: 800px;
        margin: 0 auto;
    }

        .cta-content h2 {
            font-size: 3.5rem;
            color: var(--c-white);
            font-weight: 900;
            margin-bottom: 1.5rem;
        }

        .cta-content p {
            font-size: 1.4rem;
            color: rgba(255,255,255,0.8);
            margin-bottom: 3rem;
            line-height: 1.6;
        }

    /* Mobile Queries */
    @@media (max-width: 768px) {
        .hero-section {
            padding: 8rem 0 4rem;
            min-height: auto;
        }

        .hero-container {
            gap: 2rem;
            text-align: center;
        }

        .hero-title {
            font-size: 2.8rem;
        }

        .hero-description {
            font-size: 1.2rem;
            margin: 0 auto 2rem auto;
        }

        .hero-actions {
            flex-direction: column;
            gap: 1rem;
        }

        .btn-primary, .btn-outline {
            width: 100%;
            justify-content: center;
        }

        .stats-section {
            margin-top: -3rem;
            padding: 0 1rem;
        }

        .stats-grid {
            padding: 2rem 1.5rem;
            gap: 1.5rem;
        }

        .stat-value {
            font-size: 2.5rem;
        }

        .stat-label {
            font-size: 1rem;
        }

        .features-section, .placement-section, .promo-section, .steps-section, .cta-section {
            padding: 4rem 1.5rem;
        }

        .section-title, .placement-card h2, .promo-header h2, .cta-content h2 {
            font-size: 2.2rem;
        }

        .section-subtitle, .placement-card p, .promo-header p, .cta-content p {
            font-size: 1.1rem;
        }

        .steps-content h2 {
            font-size: 2.2rem;
            text-align: center;
        }
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(40px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeLeft {
        from {
            opacity: 0;
            transform: translateX(-40px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes floatShape {
        0% {
            transform: translate(0,0) scale(1);
        }

        100% {
            transform: translate(30px, 30px) scale(1.1);
        }
    }

    @@keyframes floatY {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-20px);
        }
    }

    @@keyframes pulseGlow {
        0%, 100% {
            opacity: 1;
            text-shadow: 0 0 10px rgba(175, 143, 66, 0.5);
        }

        50% {
            opacity: 0.5;
            text-shadow: none;
        }
    }
</style>

<div class="premium-home">

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="hero-bg-shapes">
            <div class="hero-blob-1"></div>
            <div class="hero-blob-2"></div>
        </div>

        <div class="hero-container">
            <div class="hero-content">
                <div class="hero-badge">
                    <i class="fa-solid fa-crown"></i> المنصة رقم #1 للقدرات
                </div>

                <h1 class="hero-title">
                    الدرجة النهائية تبدأ من <br><span>الأديب</span>
                </h1>

                <p class="hero-description">
                    أقوى منصة تعليمية تضمن لك تأسيساً صلباً وتدريباً مكثفاً على كافة مهارات القدرات اللفظي بأحدث استراتيجيات الحل السريع مع خبير القدرات أ. صلاح عبد العال.
                </p>

                <div class="hero-actions">
                    <a href="/Account/Register" class="btn-primary">
                        ابدأ رحلة الـ 100% <i class="fa-solid fa-rocket"></i>
                    </a>
                    <a href="/Student/BrowseCourses" class="btn-outline">
                        تصفح الدورات <i class="fa-solid fa-compass"></i>
                    </a>
                </div>
            </div>

            <div class="hero-visual">
                <div class="visual-frame">
                    <img src="~/images/Salah.jpg" alt="أ. صلاح عبد العال" onerror="this.src='https://ui-avatars.com/api/?name=صلاح+عبدالعال&background=0a3254&color=af8f42&size=600';" />
                    <div class="float-card-1">
                        <i class="fa-solid fa-bullseye"></i>
                        <span>علامة كاملة 100%</span>
                    </div>
                    <div class="float-card-2">
                        <i class="fa-solid fa-stopwatch"></i>
                        <span>شفرات للحل السريع</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-value">+@ViewBag.TotalStudentsDisplay</div>
                <div class="stat-label">طالب وطالبة يثقون بنا</div>
            </div>
            <div class="stat-item">
                <div class="stat-value">100%</div>
                <div class="stat-label">نسبة رضا الطلاب</div>
            </div>
            <div class="stat-item">
                <div class="stat-value">+@ViewBag.CoursesCount</div>
                <div class="stat-label">دورة تدريبية متخصصة</div>
            </div>
            <div class="stat-item">
                <div class="stat-value">24/7</div>
                <div class="stat-label">دعم فني وتواصل مباشر</div>
            </div>
        </div>
    </section>

    <!-- Placement Test Section (تحديد المستوى) -->
    <section class="placement-section">
        <div class="placement-card">
            <div class="placement-icon"><i class="fa-solid fa-clipboard-check"></i></div>
            <h2>أين تقف الآن؟ اختبر مستواك مجاناً</h2>
            <p>قبل أن تبدأ، دعنا نحدد مستواك الحالي بدقة عبر اختبار تشخيصي شامل يحاكي اختبار قياس الفعلي. ستظهر نتيجتك فور الانتهاء لتعرف نقاط قوتك وضعفك.</p>
            <a href="/Student/TakeQuiz/1" class="btn-primary" style="margin: 0 auto;">
                ابدأ اختبار تحديد المستوى <i class="fa-solid fa-pen-nib"></i>
            </a>
        </div>
    </section>

    <!-- Promo Video Section (الفيديو الترويجي) -->
    <section class="promo-section">
        <div class="promo-container">
            <div class="promo-header">
                <h2>اكتشف منصة الأديب</h2>
