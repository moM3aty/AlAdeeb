@{
    ViewData["Title"] = "الرئيسية";
}

<style>
    @@font-face {
        font-family: 'Hayah';
        src: url('/fonts/Hayah.otf') format('opentype');
    }

    :root {
        --c-primary: #0a3254;
        --c-primary-light: #124b7a;
        --c-secondary: #af8f42;
        --c-secondary-light: #d1b46b;
        --c-bg: #f8fafc;
        --c-white: #ffffff;
        --transition: all 0.4s ease;
    }

    body {
        background-color: var(--c-bg);
        margin: 0;
        padding: 0;
        direction: rtl;
    }

    /* 1. Hero Section - قسم الاستقبال */
    .hero {
        background: linear-gradient(135deg, var(--c-primary) 0%, #031424 100%);
        color: var(--c-white);
        padding: 9rem 2rem 7rem 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .hero::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(175,143,66,0.15) 0%, transparent 60%);
            pointer-events: none;
        }

    .hero-content {
        position: relative;
        z-index: 10;
        max-width: 900px;
        margin: 0 auto;
        animation: fadeUp 1s ease;
    }

    .hero h1 {
        font-family: 'Hayah', sans-serif;
        font-size: clamp(2.8rem, 5vw, 4.5rem);
        margin-bottom: 1.5rem;
        text-shadow: 0 10px 20px rgba(0,0,0,0.5);
        font-weight: 900;
        line-height: 1.2;
    }

        .hero h1 span {
            color: var(--c-secondary);
        }

    .hero p {
        font-size: clamp(1.1rem, 2vw, 1.4rem);
        color: #cbd5e1;
        margin: 0 auto 3rem auto;
        line-height: 1.8;
        font-weight: bold;
    }

    .hero-btns {
        display: flex;
        gap: 1.2rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-gold {
        background: linear-gradient(135deg, var(--c-secondary), var(--c-secondary-light));
        color: var(--c-primary);
        padding: 1.2rem 3rem;
        border-radius: 50px;
        font-size: 1.3rem;
        font-weight: 900;
        text-decoration: none;
        box-shadow: 0 10px 20px rgba(175,143,66,0.4);
        transition: var(--transition);
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
    }

        .btn-gold:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(175,143,66,0.6);
        }

    .btn-outline-w {
        background: rgba(255,255,255,0.05);
        border: 2px solid rgba(255,255,255,0.2);
        color: var(--c-white);
        padding: 1.2rem 3rem;
        border-radius: 50px;
        font-size: 1.3rem;
        font-weight: 900;
        text-decoration: none;
        transition: var(--transition);
        backdrop-filter: blur(10px);
    }

        .btn-outline-w:hover {
            background: var(--c-white);
            color: var(--c-primary);
            border-color: var(--c-white);
            transform: translateY(-5px);
        }

    /* 2. Stats Section - الإحصائيات */
    .stats-section {
        padding: 4rem 2rem;
        background: var(--c-white);
        border-bottom: 1px solid #e2e8f0;
        position: relative;
        z-index: 2;
        margin-top: -3rem;
        border-radius: 3rem 3rem 0 0;
        box-shadow: 0 -10px 30px rgba(0,0,0,0.1);
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 2.5rem;
        max-width: 1200px;
        margin: 0 auto;
        text-align: center;
    }

    .stat-item {
        padding: 1rem;
        transition: var(--transition);
    }

        .stat-item:hover {
            transform: translateY(-10px);
        }

    .stat-value {
        font-size: 3.5rem;
        color: var(--c-secondary);
        font-family: Arial, sans-serif;
        font-weight: 900;
        margin-bottom: 0.5rem;
        text-shadow: 0 5px 10px rgba(175,143,66,0.2);
    }

    .stat-label {
        font-size: 1.2rem;
        color: var(--c-primary);
        font-weight: 900;
        font-family: 'Hayah';
    }

    /* 3. Placement Test Section - تحديد المستوى */
    .placement-section {
        padding: 6rem 2rem;
        background: #fffcf2;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .placement-card {
        max-width: 800px;
        margin: 0 auto;
        background: var(--c-white);
        padding: 4rem 3rem;
        border-radius: 2rem;
        box-shadow: 0 20px 50px rgba(175,143,66,0.15);
        border: 2px dashed #fde047;
        position: relative;
        z-index: 2;
        transition: var(--transition);
    }

        .placement-card:hover {
            transform: translateY(-10px);
            border-color: var(--c-secondary);
        }

        .placement-card h2 {
            font-family: 'Hayah';
            font-size: clamp(2.2rem, 4vw, 2.8rem);
            color: var(--c-primary);
            margin-bottom: 1rem;
        }

        .placement-card p {
            font-size: 1.2rem;
            color: #64748b;
            margin-bottom: 2.5rem;
            line-height: 1.8;
            font-weight: bold;
        }

    /* 4. Promo Video Section - الفيديو الترويجي */
    .promo-section {
        padding: 6rem 2rem;
        background: var(--c-primary);
        color: white;
        text-align: center;
        position: relative;
    }

    .promo-container {
        max-width: 1000px;
        margin: 0 auto;
        position: relative;
        z-index: 2;
    }

    .promo-header h2 {
        font-family: 'Hayah';
        font-size: clamp(2.5rem, 4vw, 3.5rem);
        color: var(--c-secondary);
        margin-bottom: 1rem;
    }

    .promo-video-wrapper {
        position: relative;
        padding-bottom: 56.25%;
        height: 0;
        overflow: hidden;
        border-radius: 1.5rem;
        box-shadow: 0 30px 60px rgba(0,0,0,0.6);
        border: 4px solid rgba(255,255,255,0.1);
        transition: var(--transition);
    }

        .promo-video-wrapper:hover {
            border-color: var(--c-secondary);
        }

        .promo-video-wrapper iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
        }

    /* 5. Features Section - مميزات المنصة */
    .features-section {
        padding: 7rem 2rem;
        background: var(--c-bg);
    }

    .section-title {
        text-align: center;
        margin-bottom: 5rem;
    }

        .section-title h2 {
            font-family: 'Hayah';
            font-size: clamp(2.5rem, 4vw, 3.5rem);
            color: var(--c-primary);
            margin: 0 0 1rem 0;
        }

        .section-title p {
            font-size: 1.2rem;
            color: #64748b;
            max-width: 600px;
            margin: 0 auto;
            font-weight: bold;
        }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2.5rem;
        max-width: 1300px;
        margin: 0 auto;
    }

    .feature-card {
        background: var(--c-white);
        padding: 3.5rem 2.5rem;
        border-radius: 1.5rem;
        text-align: center;
        box-shadow: 0 15px 35px rgba(10,50,84,0.05);
        transition: var(--transition);
        border: 1px solid rgba(10,50,84,0.03);
    }

        .feature-card:hover {
            transform: translateY(-15px);
            box-shadow: 0 25px 50px rgba(175,143,66,0.15);
            border-color: rgba(175,143,66,0.3);
        }

    .feature-icon {
        width: 6rem;
        height: 6rem;
        background: rgba(175,143,66,0.1);
        color: var(--c-secondary);
        border-radius: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.8rem;
        margin: 0 auto 2rem auto;
        transition: var(--transition);
    }

    .feature-card:hover .feature-icon {
        background: var(--c-secondary);
        color: var(--c-white);
        transform: rotate(10deg);
    }

    .feature-card h3 {
        font-family: 'Hayah';
        font-size: 1.8rem;
        color: var(--c-primary);
        margin: 0 0 1rem 0;
    }

    .feature-card p {
        color: #64748b;
        font-size: 1.1rem;
        line-height: 1.7;
        margin: 0;
        font-weight: bold;
    }

    /* 6. Testimonials Section - آراء الطلاب */
    .testimonials-section {
        padding: 7rem 2rem;
        background: var(--c-white);
        position: relative;
        overflow: hidden;
    }

        .testimonials-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(rgba(175,143,66,0.05) 2px, transparent 2px);
            background-size: 30px 30px;
            pointer-events: none;
        }

    .testi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 2.5rem;
        max-width: 1300px;
        margin: 0 auto;
        position: relative;
        z-index: 2;
    }

    .testi-card {
        background: var(--c-bg);
        padding: 3rem 2.5rem;
        border-radius: 1.5rem;
        border: 1px solid #e2e8f0;
        position: relative;
        transition: var(--transition);
    }

        .testi-card:hover {
            background: var(--c-white);
            box-shadow: 0 20px 40px rgba(10,50,84,0.1);
            border-color: var(--c-secondary);
            transform: translateY(-5px);
        }

    .quote-icon {
        position: absolute;
        top: 2rem;
        left: 2rem;
        font-size: 4rem;
        color: rgba(175,143,66,0.1);
    }

    .stars {
        color: #fbbf24;
        font-size: 1.2rem;
        margin-bottom: 1.5rem;
    }

    .testi-text {
        font-size: 1.2rem;
        color: var(--c-primary);
        line-height: 1.8;
        font-weight: bold;
        margin-bottom: 2rem;
        font-family: Arial, sans-serif;
    }

    .testi-author {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        border-top: 1px solid #e2e8f0;
        padding-top: 1.5rem;
    }

    .author-avatar {
        width: 4rem;
        height: 4rem;
        background: var(--c-primary);
        color: var(--c-secondary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        font-weight: 900;
        font-family: 'Hayah';
    }

    .author-info h4 {
        margin: 0;
        color: var(--c-primary);
        font-size: 1.3rem;
        font-weight: 900;
    }

    .author-info p {
        margin: 0;
        color: #10b981;
        font-size: 1rem;
        font-weight: bold;
    }

    /* 7. Call to Action - الختام */
    .cta-section {
        background: linear-gradient(135deg, var(--c-secondary) 0%, #ca8a04 100%);
        padding: 6rem 2rem;
        text-align: center;
        color: var(--c-white);
    }

    .cta-container {
        max-width: 800px;
        margin: 0 auto;
    }

        .cta-container h2 {
            font-family: 'Hayah';
            font-size: clamp(2.5rem, 4vw, 3.8rem);
            margin-bottom: 1.5rem;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .cta-container p {
            font-size: 1.4rem;
            margin-bottom: 3rem;
            font-weight: bold;
            opacity: 0.9;
        }

    .btn-dark {
        background: var(--c-primary);
        color: var(--c-white);
        padding: 1.4rem 4rem;
        border-radius: 50px;
        font-size: 1.5rem;
        font-weight: 900;
        text-decoration: none;
        box-shadow: 0 15px 30px rgba(10,50,84,0.3);
        transition: var(--transition);
        display: inline-block;
    }

        .btn-dark:hover {
            background: #061c33;
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(10,50,84,0.5);
            color: var(--c-secondary);
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(40px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<!-- 1. Hero Section -->
<section class="hero">
    <div class="hero-content">
        <h1>منصة الأديب للقدرات اللفظي</h1>
        <p>الوجهة الأولى لتأسيس وتدريب قدراتك، مع أقوى محاكي اختبارات ذكي يضمن لك الوصول للعلامة الكاملة 100% بإذن الله.</p>
        <div class="hero-btns">
            <a href="/Student/BrowseCourses" class="btn-gold"><i class="fa-solid fa-rocket"></i> ابدأ التعلم الآن</a>
            @if (!User.Identity.IsAuthenticated)
            {
                <a href="/Account/Login" class="btn-outline-w"><i class="fa-solid fa-user-lock"></i> تسجيل الدخول</a>
            }
        </div>
    </div>
</section>

<!-- 2. Stats Section -->
<section class="stats-section">
    <div class="stats-grid">
        <div class="stat-item"><div class="stat-value">+@ViewBag.TotalStudentsDisplay</div><div class="stat-label">طالب وطالبة يثقون بنا</div></div>
        <div class="stat-item"><div class="stat-value">100%</div><div class="stat-label">نسبة رضا وتفوق الطلاب</div></div>
        <div class="stat-item"><div class="stat-value">+@ViewBag.CoursesCount</div><div class="stat-label">برنامج تدريبي متخصص</div></div>
        <div class="stat-item"><div class="stat-value">24/7</div><div class="stat-label">دعم فني وتواصل مستمر</div></div>
    </div>
</section>

<!-- 3. Placement Test Section -->
@if (ViewBag.PlacementTestQuizId != null && ViewBag.PlacementTestQuizId > 0)
{
    <section class="placement-section">
        <div class="placement-card">
            <i class="fa-solid fa-clipboard-check" style="font-size: 5rem; color: var(--c-secondary); margin-bottom: 1.5rem; filter: drop-shadow(0 10px 10px rgba(175,143,66,0.3));"></i>
            <h2>أين تقف الآن؟ اختبر مستواك مجاناً</h2>
            <p>دعنا نحدد مستواك الحالي بدقة عبر اختبار تشخيصي ذكي يحاكي اختبار قياس الفعلي. ستظهر نتيجتك فور الانتهاء لتعرف نقاط قوتك وضعفك والمسار الأنسب لتطويرك.</p>
            <a href="/Student/TakeQuiz/@ViewBag.PlacementTestQuizId" class="btn-gold" style="display:inline-flex;">ابدأ الاختبار التشخيصي <i class="fa-solid fa-arrow-left"></i></a>
        </div>
    </section>
}

<!-- 4. Promo Video Section -->
@if (!string.IsNullOrEmpty((string)ViewBag.PromoVideoUrl))
{
    string embedUrl = (string)ViewBag.PromoVideoUrl;
    if (embedUrl.Contains("watch?v=")) embedUrl = embedUrl.Replace("watch?v=", "embed/");
    else if (embedUrl.Contains("youtu.be/")) embedUrl = embedUrl.Replace("youtu.be/", "youtube.com/embed/");

    <section class="promo-section">
        <div class="promo-container">
            <div class="promo-header">
                <h2>اكتشف منصة الأديب</h2>
                <p style="font-size: 1.3rem; color: #cbd5e1; margin-bottom: 3rem; font-weight: bold;">شاهد كيف نصنع التفوق ونغير مفهوم المذاكرة التقليدية</p>
            </div>

            <div class="promo-video-wrapper" style="position: relative;" oncontextmenu="return false;">

                     <!-- iframe Video -->
                <iframe src="@embedUrl?rel=0&modestbranding=1&controls=1&iv_load_policy=3&disablekb=1&autoplay=1&mute=1" title="فيديو ترويجي لمنصة الأديب" allow="autoplay; encrypted-media; gyroscope; picture-in-picture" frameborder="0" allowfullscreen oncontextmenu="return false;"></iframe>
            </div>
        </div>
    </section>
}

<!-- 5. Features Section -->
<section class="features-section">
    <div class="section-title">
        <h2>لماذا منصة الأديب هي خيارك الأفضل؟</h2>
        <p>نحن لا نقدم مجرد فيديوهات مسجلة، بل نصنع تجربة تعليمية تفاعلية متكاملة تقودك نحو الـ 100%.</p>
    </div>
    <div class="features-grid">
        <div class="feature-card">
            <div class="feature-icon"><i class="fa-solid fa-brain"></i></div>
            <h3>محاكي قياس الذكي</h3>
            <p>اختبارات عشوائية تسحب من بنك أسئلة ضخم لتوفير تجربة مطابقة تماماً لاختبار قياس الحقيقي، مع تصحيح فوري.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon"><i class="fa-solid fa-route"></i></div>
            <h3>مسار تعليمي متدرج</h3>
            <p>لن تتجاوز أي خطوة قبل إتقانها! نظامنا المبتكر يجبرك على اجتياز الاختبارات لفتح الدروس التالية لضمان الفهم العميق.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon"><i class="fa-solid fa-shield-halved"></i></div>
            <h3>بيئة آمنة ومركزة</h3>
            <p>حماية كاملة لحسابك، وتجربة خالية من التشتت الإعلاني مع مشغل فيديوهات مخصص وملازم تفاعلية جاهزة للطباعة.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon"><i class="fa-solid fa-comments"></i></div>
            <h3>تواصل مباشر ومستمر</h3>
            <p>منتدى نقاشات تفاعلي أسفل كل دورة لطرح الأسئلة، بالإضافة إلى بثوث مباشرة مجدولة للمراجعة المباشرة مع المدرب.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon"><i class="fa-solid fa-trophy"></i></div>
            <h3>لوحة شرف تنافسية</h3>
            <p>تنافس مع زملائك وتصدر لوحة الشرف الخاصة بالدورة بناءً على متوسط نتائجك في الاختبارات لزيادة حماسك وشغفك.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon"><i class="fa-solid fa-certificate"></i></div>
            <h3>شهادات اجتياز معتمدة</h3>
            <p>احصل على شهادة تفوق فور اجتيازك للاختبار النهائي، توثق مجهودك ونسبة إنجازك في الدورة التدريبية.</p>
        </div>
    </div>
</section>

<!-- 6. Testimonials Section -->
<section class="testimonials-section" id="testimonials">
    <div class="section-title">
        <h2>قصص نجاح أبطالنا</h2>
        <p>آراء بعض الطلاب الذين حققوا طموحاتهم وتفوقوا في القدرات مع منصة الأديب.</p>
    </div>
    <div class="testi-grid">
        <div class="testi-card">
            <i class="fa-solid fa-quote-left quote-icon"></i>
            <div class="stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
            <p class="testi-text">"منصة رائعة جداً، المحاكي فادني بشكل كبير في كسر رهبة الاختبار الحقيقي، وأسئلة التجميعات بالبنك مطابقة تماماً لما جاءني في قياس الفعلي."</p>
            <div class="testi-author">
                <div class="author-avatar">أ</div>
                <div class="author-info">
                    <h4>أحمد عبدالله</h4>
                    <p><i class="fa-solid fa-arrow-trend-up"></i> درجة 98% - اللفظي</p>
                </div>
            </div>
        </div>
        <div class="testi-card">
            <i class="fa-solid fa-quote-left quote-icon"></i>
            <div class="stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
            <p class="testi-text">"شرح الأستاذ صلاح لا يعلى عليه، يبسط المعلومة بشكل عجيب. ونظام إجبار الترتيب في الدروس خلاني ألتزم وأذاكر صح بدون ما أراكم الدروس."</p>
            <div class="testi-author">
                <div class="author-avatar">س</div>
                <div class="author-info">
                    <h4>سارة محمد</h4>
                    <p><i class="fa-solid fa-arrow-trend-up"></i> درجة 100% - اللفظي</p>
                </div>
            </div>
        </div>
        <div class="testi-card">
            <i class="fa-solid fa-quote-left quote-icon"></i>
            <div class="stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
            <p class="testi-text">"لوحة الشرف خلتني أتحمس أراجع وأجيب درجات أعلى في الاختبارات عشان أطلع المركز الأول. شكراً لمنصة الأديب على هذا الإبداع!"</p>
            <div class="testi-author">
                <div class="author-avatar">خ</div>
                <div class="author-info">
                    <h4>خالد فهد</h4>
                    <p><i class="fa-solid fa-arrow-trend-up"></i> درجة 97% - اللفظي</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 7. Call to Action -->
<section class="cta-section">
